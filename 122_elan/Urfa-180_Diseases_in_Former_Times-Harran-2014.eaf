    <TIER LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Corpus:Harran03">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
                <ANNOTATION_VALUE>awwali b-zimānāt, awwali b-zimānāt demek ki ᵊzlime ṣāyb-u wuǧaʕ, ṣāyb-u wuǧaʕ han-nōba ʕaman ṣayb-u wuǧaʕ min… min… minǧarib.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a2"
                TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>ṣāyb-u iš-midrī-ni wuǧaʕ-in, awwali ygūlū-l-u al-ʕarab, awwali ygūlū-l-u al-ʕarab m-al-wiǧih al-ma… ʕaman mū ḏ̣ārbīn mū miṯil alḥaz yuḏ̣urbūn āše.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3"
                TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>huwwa badawi demek az-zlime, badawi, w ṣāyb-u ǧdiri. ygūlūn al-wuǧaʕ aṣ ṣāyb-u yaʕni aǧ-ǧdiri ši-ysāwi?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a4"
                TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>aǧ-ǧdiri yidʕī-´ b-nōba yunquš aǧ-ǧdiri aǧ-ǧilid naqiš, yaʕni yḥafir aǧ-ǧilid.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>w hal-u gāymīn ytiʕawwaḏūn-u, mā ʕād yrīdūn-u, w gāyim huwwa ᵊmxallīn-u w rāḥlīn ᵊmxallīn-u w rāyḥīn.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>w ḏ̣āll huwwa ydaḥḥiǧ il-ḥāl-u w nahāṛ demek ki ad-dinye lēl w ǧūʕān.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>ᵊbgaḷb al-bēt yḥūs hū az-zlime yḥūṣ min wuǧʕ-u yišxal, ᵊǧrūḥ kull al-məṭāriḥ ᵊǧrūḥ w hīčiḏ yišxalin. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a8"
                TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>w gāyim ši-msāwi? ǧāy ʕala ǧīrān-u gāyil: arīd arūḥ ʕala ǧīrān-i tā yšūf ǧīrān-u biʕīdīn. ad-dinye ḏ̣alma ʕalatrīk ᵊsrāǧ māmin, šakle māmin.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>w gāyim ytikammaš ytikammaš inn-u gāḏ̣b-ill-u b-īd-u miṯil al-ʕūd w ytikammaš w yimši.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a10"
                TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>wakt-inn-u yimši demek ki šī čalib. aḷḷa yḥaššim nāy… mihni yaʕni. ḏ̣āwi ʕind iṯum al-bāb, ʕind iṯum bāb ǧīrān-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>ač-čalib zād aswad, mā yšūf-u az-zlime. w ǧāyib w dāyis ḏēl ač-čālib. wakt-in dāyis ḏēl ač-čalib, ʕāḏ̣ḏ̣ az-zlime min sāg-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a12"
                TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>wakt-in ʕāḏ̣ḏ̣ az-zlime min sāg-u, w gāyim yiddi gāyim yiddi sāg ač-č… sāg az-zlime, sinn, nāb ač-čalib ᵊb-sāg az-zlime, ᵊb-sāg riǧl-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a13"
                TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>w gāyim yiddi w yiddi yiddi yiddi yiddi w-az-zlime ṭaybān! w ṣāyre hnīt-u šifāt-u ṣāyir min nāb čalib!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a14"
                TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>aw ṭaybān w ḥitt huwwa zāti mū rāyid ahal-u gāyil: ahal-i daššarō-ni, mart-i w ʕiǧyān-i āni zāti āni māni rāyid-hum. salāmt-ak w-al-ʕāfye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
