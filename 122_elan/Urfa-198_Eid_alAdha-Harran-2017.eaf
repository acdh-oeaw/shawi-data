    <TIER LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Corpus:Harran02">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
                <ANNOTATION_VALUE>hā, ʕugub haftatēn, aš-šahar ʕugub-ma arūḥ baʕad yōm āni, aš-šahar wāḥad ʕīd aḏ̣-ḏ̣aḥiyye. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a2"
                TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>ʕīd aḏ̣-ḏ̣aḥiyye, xōǧam, aṣ-ṣubuḥ ᵊngūm yōm-in ṣalāt al-ʕīd aṣ-ṣubuḥ as-sāʕa xamse ngūm āni w Fārūq, ᵊngūm ntuwaḏ̣ḏ̣a.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3"
                TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>w-ᵊrrūḥ ʕa-l-ǧāmiʕ, ʕala ṣalāt al-ʕīd, āni w Fārūq ᵊnṣalli ṣalāt al-ʕīd.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a4"
                TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>ʕugub-ma nuṭluʕ m-aǧ-ǧāmiʕ, niǧi ʕa-d-darib, ḏāk an-nahāṛ al-ᵊfranne yčallṭin, bass as-sammūn šīʸ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>ē, nāxuḏ sammūnāt sitte sabʕa ʕašər sammūnāt, āni w Fārūq.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>w niǧi ʕa-l-bēt w w Amīne ssāwī-l-ne fuṭūr w tiǧʕid al-ʕiǧyān kull-hum, w nəfṭər.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>nəfṭər fuṭūr ᵊnsāwi fuṭūr-ne baʕdēn-ma nsāwi fuṭūr, ᵊngūm āni w Fārūq, Özlem zād nōbāt tiǧi ᵊbsāgit-ne.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a8"
                TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>ᵊrrūḥ ʕa-l-ᵊhniyye, ʕa-l-māgaf, b-al-ʕīd ᵊb-kull məṭraḥ šī māgaf, yamm bēt-ne ybīʕūn ḥalāl yaʕni al-mā… al-ᵊhniyye čiṯīr al-baladiyye ssāwi məṭāriḥ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>kull məkān ybīʕūn ᵊhniyye ḥalāl, qanam, qanam, bəgaṛ iš-ma trīd. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a10"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>bəgaṛ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>bəgaṛ, bəgaṛ, ē bəgaṛ zād ybīʕūn-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a14"
                TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>ē, bəgaṛ, tiyāsīn kull-min ʕala gūǧ-u. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a16"
                TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>lā, ǧimal mā ʕid-ne, lā, iḥne bāʕir yaʕni ǧimal mā ʕid-ne.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a17"
                TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts34">
                <ANNOTATION_VALUE>ā xayyo, ᵊnrūḥ ʕād ʕalē-´, ʕa-l-māgaf, iḥne nrūḥ akṯar an-nōbāt āni w Fārūq ᵊnrūḥ ʕala hnīt al yamm-ne ʕa-ǧ ǧirīb-in-ne. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a18"
                TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>ᵊnrūḥ qādi ngūm ndaḥḥiǧ ʕala ʕa-d-duwāb ᵊndaḥḥiǧ al-xərfān al-ᵊkbāṛ, ač-čabiš, iḥne nāxuḏ duwāb kull sine, āni w Fārūq.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a19"
                TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>ᵊndaḥḥǧ-in-na ʕala ṯnēne, nāxḏ-il-ne nʕaǧtēn, ᵊntinaggā-hin zēn, ᵊndaḥḥǧ-il-hin ndaḥḥiǧ l-āḏān-hin, ᵊndaḥḥiǧ l-ᵊsnūn-hin.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a20"
                TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
                <ANNOTATION_VALUE>al ᵊsnūn-hin ᵊmkassarāt mā ṣṣīr ḏ̣aḥiyye, al iḏin-he mašrūma mā ṣṣīr ḏ̣aḥiyye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a21"
                TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts42">
                <ANNOTATION_VALUE>yaʕni dīn-ne mā yigbaḷ ʕalē-hin. ta-ngūl al-iḏin hīčiḏ mašrūme, mā ṣṣīr ḏ̣aḥiyye. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a22"
                TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts46">
                <ANNOTATION_VALUE>mā ṣṣīr ḏ̣aḥiyye, mā yigbaḷūn al-xawāǧe ygūlūn in-ha ḥarām.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a24"
                TIME_SLOT_REF1="ts47" TIME_SLOT_REF2="ts48">
                <ANNOTATION_VALUE>ᵊndaḥḥǧ-il-ne ʕala ḏ̣aḥīt-in zēne, ᵊṯnēne ntinagga wəḥde liyye wəḥde l-Amīne. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a25"
                TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts50">
                <ANNOTATION_VALUE>hā, w-ᵊnǧīb-hin ʕād ʕa-l-bēt, w-ᵊnsammi bismiḷḷa w-āni axušš b-al-ḥōš w nugḏ̣ub ʕād, Amīne tugḏ̣ub tinṭī-hin mayye, tisgī-hin. tā mā t… ʕatšānāt tā yišraban mayye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a26"
                TIME_SLOT_REF1="ts51" TIME_SLOT_REF2="ts52">
                <ANNOTATION_VALUE>tā mā… hā mū yrīdin yinḏabḥin? nisgī-hin mayye. ā baʕad-ma nisgī-hin mayye ʕād ᵊnsammi bismiḷḷa, wəḥdit-in wəḥde ʕād Amīne tgūl: āni nṭēt-ak wukāle. hāḏi l-Amīne w hāḏi liyye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a27"
                TIME_SLOT_REF1="ts53" TIME_SLOT_REF2="ts54">
                <ANNOTATION_VALUE>ᵊhnīt Amīne aḏbaḥ-ha, Amīne agūl-l-he: tənṭīn-ni wukāle tā_rīd aḏbaḥ ḏ̣aḥīt-ič? ᵊtgūl: ī, āni wakkalt-ak ʕala ḏ̣aḥīt-i.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a28"
                TIME_SLOT_REF1="ts55" TIME_SLOT_REF2="ts56">
                <ANNOTATION_VALUE>w-asammi bismiḷḷa aǧabbil-he ǧible, w-agṭaʕ kallit-he. yugḏ̣ubūn-he al-ʕiǧyān yšiddūn-he abruk fōg-ha w nigṭaʕ kallit-he.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a29"
                TIME_SLOT_REF1="ts57" TIME_SLOT_REF2="ts58">
                <ANNOTATION_VALUE>w-ᵊnrudd ʕād al-uxṛa ḏīč, haḏīč zād ᵊnsammi bismiḷḷa liyye zād agūl bismiḷḷa, allāhu akbar, zād agṭaʕ kallit-he, nirmī-he.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a30"
                TIME_SLOT_REF1="ts59" TIME_SLOT_REF2="ts60">
                <ANNOTATION_VALUE>Amīne w Ǧamīle w Malak ʕād yugḏ̣ubun ʕād ygūmin yislaxin-he, yislaxin-he ᵊb-nōba lummun-ma guṭma tihni al-ḥaywān, ᵊtrūḥ rūḥ-ha tuṭluʕ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a31"
                TIME_SLOT_REF1="ts61" TIME_SLOT_REF2="ts62">
                <ANNOTATION_VALUE>yislaxin-he, nugḏ̣ub ʕādēn yuṭluʕun al-laḥam. tuṭluʕ al-məṣārīn w-aškāl aǧ-ǧigar w-al-fənduwwa, al-ᵊhniyyāt tuṭluḥ-ḥun ʕayre.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a32"
                TIME_SLOT_REF1="ts63" TIME_SLOT_REF2="ts64">
                <ANNOTATION_VALUE>al-fənduwwa māmiš yaʕni tōm… ē ǧigar-he w məṣārīn-he w čaršit-he. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a33"
                TIME_SLOT_REF1="ts65" TIME_SLOT_REF2="ts66">
                <ANNOTATION_VALUE>baʕdēn-ma tuṭluḥ-ḥun ḏanne, nugḏ̣ub ʕād al-laḥam, nuǧrud al-laḥam. nuǧrud al-laḥam hēne nkawwm-u nsāwī-´ kōm. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a34"
                TIME_SLOT_REF1="ts67" TIME_SLOT_REF2="ts68">
                <ANNOTATION_VALUE>nugḏ̣ub ʕād al-laḥam, ᵊnsāwī-´ ṯalṯ ᵊkwām. yaʕni göz kararı ta-ngūl, al-laḥam ta-ngūl ᵊšgadd ᵊṭlaʕat ᵊnʕaǧe? ʕišrīn kīlo: sabʕa hēne, sabʕa hēne w sabʕa hēne. göz kararı yaʕni nsāwi hniyye ṯalṯ ᵊkwām.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a35"
                TIME_SLOT_REF1="ts71" TIME_SLOT_REF2="ts72">
                <ANNOTATION_VALUE>ē, kōm, ᵊnsāwi Amīne tgūm ᵊssāwi ʕād göz kararı ʕala kīlow, kīlow. ᵊtsāwi ʕašər ᵊḥṣaṣṣ, ta-ngūl sitt sabiʕ ašr ᵊḥṣaṣṣ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a37"
                TIME_SLOT_REF1="ts73" TIME_SLOT_REF2="ts74">
                <ANNOTATION_VALUE>l-al-fuqāra, ta-ngūl ǧīrān-ne al mā yiḏbaḥūn, l-as-sūriyyīn. ᵊndarrib-hin. w kōm linne l-ahal-ne.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a38"
                TIME_SLOT_REF1="ts75" TIME_SLOT_REF2="ts76">
                <ANNOTATION_VALUE>ta-ngūl aqraba ᵊngūl l-al-gaṛāyəb, l-umm-i l-ahal-i l-abū-ye w-il-ᵊMḥimmad ʕAli, il-Fārūq l-axūt-i l-al-ᵊhniyye. Amīne zād l-uxut-he, l-umm-ha l-axū-ha.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a39"
                TIME_SLOT_REF1="ts77" TIME_SLOT_REF2="ts78">
                <ANNOTATION_VALUE>aḏe zād al-kōm hāḏa tfarrǧ-u. w-al-kōm hāḏa yḏ̣all-in-ne b-al-bēt. ᵊhnīne al-bēt ʕād hāḏa Amīne ʕād ᵊtgūm ᵊtgaṭṭʕ-u. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a40"
                TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts80">
                <ANNOTATION_VALUE>nǧarrd-u nāxḏ-u ʕa-l-gaṣṣāb ᵊnsāwī-´ laḥam qīyme, miššān qīymāli miššān tabsi kabāb.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a41"
                TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts82">
                <ANNOTATION_VALUE>w-aǧ-ǧigar w-al… ad-dalāk wala ač-čabde wala haḏanne zād tugruḏ̣-hin ᵊnsāwī-hin ᵊnḥuṭṭ ʕa-l-mangaḷ nišwī-hin ᵊnsāwī-hin kabāb.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a42"
                TIME_SLOT_REF1="ts83" TIME_SLOT_REF2="ts84">
                <ANNOTATION_VALUE>hā baʕad-ma nsāwi al-kabāb, yigḏ̣i l-kabāb, ᵊngūm ʕād al-ḥammām, Amīne tiḥmī-n-ne l-ḥammām ᵊngūm ᵊnqassil ᵊnbaddil ᵊhdūm-ne.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a43"
                TIME_SLOT_REF1="ts85" TIME_SLOT_REF2="ts86">
                <ANNOTATION_VALUE>w-ᵊnqassil ᵊntinaḏ̣ḏ̣af iḥne kull-ne ᵊb-nōba l-ʕēle.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a44"
                TIME_SLOT_REF1="ts87" TIME_SLOT_REF2="ts88">
                <ANNOTATION_VALUE>āw, w nirkab at-taqṣi nrūḥ awwal nōb ʕala ahal-i, nʕayyid ahal-i. abū-ye w-umm-i nʕayyid-hum. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a45"
                TIME_SLOT_REF1="ts89" TIME_SLOT_REF2="ts90">
                <ANNOTATION_VALUE>ʕugub-ma nʕayyid abū-ye w-umm-i ʕād niǧi ʕa-l-bēt, nirkab ᵊnrūḥ ʕala Ḥarrān.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a46"
                TIME_SLOT_REF1="ts91" TIME_SLOT_REF2="ts92">
                <ANNOTATION_VALUE>ʕa-l-miǧanne.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a47"
                TIME_SLOT_REF1="ts95" TIME_SLOT_REF2="ts96">
                <ANNOTATION_VALUE>ē, ᵊnrūḥ ʕa-š-šēx Ḥayāt al-Ḥarrāni ǧidd-ne. ᵊnrūḥ ᵊnʕayyd-u huwwa awwal nōb w baʕdēn nʕayyid mayytīn-ne.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a49"
                TIME_SLOT_REF1="ts97" TIME_SLOT_REF2="ts98">
                <ANNOTATION_VALUE>Amīne trūḥ ʕal abū-ha, ʕala xāl-ha. hā, āni zād arūḥ ʕala ǧidd-i, ʕala ḥabbābt-i, ʕala ʕamām-i.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a50"
                TIME_SLOT_REF1="ts99" TIME_SLOT_REF2="ts100">
                <ANNOTATION_VALUE>al-miǧanne kull-hum ᵊnʕayyid-hum, nəgra al-fātḥe ʕind-hum. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a51"
                TIME_SLOT_REF1="ts101" TIME_SLOT_REF2="ts102">
                <ANNOTATION_VALUE>ʕugub-ma nʕayyid-hum, niǧi ʕād nirkab al-pikab, w-ᵊrrūḥ ʕal ahal Amīne, ʕal Aqčaqale. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a52"
                TIME_SLOT_REF1="ts105" TIME_SLOT_REF2="ts106">
                <ANNOTATION_VALUE>ē, ʕala Tall Abyaḏ̣. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a54"
                TIME_SLOT_REF1="ts107" TIME_SLOT_REF2="ts108">
                <ANNOTATION_VALUE>ᵊrrūḥ zād nugʕud sāʕtēn ᵊnʕayyid Amīne umm-ha w ahal ʕamām-he, nʕayyid al-ᵊkbāṛ yaʕni.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a55"
                TIME_SLOT_REF1="ts109" TIME_SLOT_REF2="ts110">
                <ANNOTATION_VALUE>nugʕud zād sāʕtēn hīčiḏ ṯalāṯ ǧirīb l-al-məġrib. aw nirkab pikab-ne w niǧi ʕa-l-bēt, ʕal Urfa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a56"
                TIME_SLOT_REF1="ts111" TIME_SLOT_REF2="ts112">
                <ANNOTATION_VALUE>niǧi ʕād ʕal Urfa, Urfa zād b-al-ʕīd ṣidīǧ-ne miṯil ᵊḥčāyt-ak al al aʕarf-u, al-akbar min-ne ʕamām-ne, əṣdigā-ne zād ᵊnrūḥ ᵊnʕayyid-hum. al-azġar min-ne yiǧūn huṃṃa yʕayydūn-ne.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a57"
                TIME_SLOT_REF1="ts113" TIME_SLOT_REF2="ts114">
                <ANNOTATION_VALUE>aw hīčiḏ arbaʕ tiyyām yigḏ̣i l-ʕīd, baʕdēn-ma yigḏ̣i l-ʕīd ʕād, ʕugub al-ʕīd kull-min yrūḥ ʕala šuġl-u. w salāmt-ak w-al-ʕāfye hāḏi hiyye daʕwīt misʕalt aḏ̣-ḏ̣aḥiyye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
