    <TIER LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Corpus:Ceylanpinar02">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts3">
                <ANNOTATION_VALUE>w čān yiǧūn-ne b-al-lēl, ta-ngūl ḥarāmiyye iḥne ᵊngūl qazu ḏīč… </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3"
                TIME_SLOT_REF1="ts4" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>qazu, iḥne agul-l-ak ṯalāṯīn arbaʕīn biʕīr bass ḥalāl ahal-i yaʕni.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a4"
                TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts9">
                <ANNOTATION_VALUE>w xayyo ad-dinye miqrib, ʕa-d-dāyir ygūm… yigūlū-l-ha ᵊswām ʕala gabǝḷ, al-ʕālam ᵊttiqayyat ʕala ḥāl-he ʕind al-ʕaše… </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>ī, yōm-in aaa, iḥne niltahi ntaʕašše qādi, al mū hātu… w-ᵊb-ḏīč an-nōba yidikkūn-he. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a8"
                TIME_SLOT_REF1="ts14" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>ʕa-l-ʕašiyye ama al-ʕālam miltahye mīhi miftakre.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>al-ʕaše xayyo yiǧūn ʕa-l-ʕaše w hiyye ᵊssīr-il-he xayyo mā tšūf  bass miṯil an-niyārīn b-as-sime. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts23">
                <ANNOTATION_VALUE>w haḏōle ǧāyīn-in-ne qazu ǧāyīn-ne al-Fidʕān. Fidʕān ygūl gōm al-ʕUgbēn mā ʕUgbēn. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a13"
                TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>maʕā-hum wāḥad-in Šarābi huwwa al ydallī-hum qādi al-baxat. w gāmū yintaxūn ʕalē-na b-al-lēl: arūm arūm, arūm arūm! w-yāxḏūn bāʕir-ne.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a14"
                TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>xaḏaw bāʕir-ne ʕid-ne aaa čam wəḥde mʕaǧǧlīn-hin waṛa l-bēt. haḏanne wāldāt ǧidīd. abū-y mʕaǧǧil-hin čān yʕagglūn al-ᵊbiʕīr hīčiḏ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a15"
                TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>xayyo al… al-ḥīrān az-zġār rāḥan maʕa l… maʕa l-bāʕir haḏīč, ī ḥallaw ʕugul-ha w rāḥaw. w-haḏannīč ḏ̣allan al… al-baʕārīn ummahāt-hin.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a16"
                TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>an-nōba ummahāt-hin yā xayy-i yibčin yā ḥaǧǧ-i yāba, miṯil-ma, hal-kubur damʕat al-baʕīr yibčin ʕala ḥāl-hin </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a19"
                TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>xaḏaw al-bāʕir xayyo. fizʕat aǧ-ǧimāʕa mā ʕid-he slāḥ w huṃṃa zād, huṃṃa, xayyo ǧāyīn ᵊmsāwīn tidbīr huṃṃa. haḏōl ygūlū-l-hum al-Fidʕān m-al-ʕUgbēne w-čān yaxḏūn bāʕir-ne.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a20"
                TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
                <ANNOTATION_VALUE>ḥinne ʕād ahal-ne hāy ᵊBrāhim hināk ᵊb-Sūriyye linne guwāye. ḏāk az-zimān al-ᵊFransāwi, šēx-ne čān ᵊmsāwī-l-hum al-Fransāwi šuʕbit ʕaskariyye, ᵊrḥamt ᵊMḥammad al-Ḥilu, balčī-kum samʕānīn ᵊb-šēx ʕAdwān.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a21"
                TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts42">
                <ANNOTATION_VALUE>w yrūḥ abū-ye iḥna ʕād gabǝḷ-ne al-bāʕir qāli čiṯīr ʕala ahal-he. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a23"
                TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts46">
                <ANNOTATION_VALUE>qīmatliyye, kull-min zād yintaxi b-biʕīr-u, āni rāʕi al-ᵊflān, iḥne ʕād ᵊngūl-il-hin al-Balhāt.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a24"
                TIME_SLOT_REF1="ts47" TIME_SLOT_REF2="ts49">
                <ANNOTATION_VALUE>w-abū-y ygūl ʕād l-aš-šēx wēn Abu Ḥilu yigūl? waḷḷa al-Balhāt ᵊnxāḏan. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a26"
                TIME_SLOT_REF1="ts50" TIME_SLOT_REF2="ts52">
                <ANNOTATION_VALUE>wēn as-sūr al-ʕadwāniyyāt? yigūl l-aš-šēx.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a27"
                TIME_SLOT_REF1="ts53" TIME_SLOT_REF2="ts54">
                <ANNOTATION_VALUE>gālaw: wal mā ʕind-ak, waḷḷa alle araddid-hin, yēlōn-hin ᵊb-xašim Sinǧār! Sinǧār hāḏa. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a29"
                TIME_SLOT_REF1="ts57" TIME_SLOT_REF2="ts58">
                <ANNOTATION_VALUE>yifzaʕ ʕalē-hin xayyo ḏāk az-zimān bi-wakt al-Fransāwi, demek ki yindallūn wēn yiṭubbin. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a30"
                TIME_SLOT_REF1="ts59" TIME_SLOT_REF2="ts60">
                <ANNOTATION_VALUE>gālaw: ṭabbēna ʕal-hin win ygūl abū-ye ygūl win-hum ǧaʕad yṣannʕūn al… al-ᵊḥwār az-zaġīr.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a31"
                TIME_SLOT_REF1="ts61" TIME_SLOT_REF2="ts62">
                <ANNOTATION_VALUE>gālaw yḥiṭṭūn-hin silmān ʕād win-hum ᵊmsāwīn širāšib. mā titxasūn? āni ḏīč an-nōba  asāwi… yitxasūn hāḏanne ḥīrān Maḥmūd haha hāḏi hiyye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a32"
                TIME_SLOT_REF1="ts63" TIME_SLOT_REF2="ts64">
                <ANNOTATION_VALUE>w-yraddid ʕād abū-ye yǧīb al-bāʕir w ǧī yḥadi ʕalē-hin w-iḥne ʕind al-Baggāra ʕind, ʕind al… ǧāb-he ʕād ᵊb-guwwit ǧimāʕat-ne hināk. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a33"
                TIME_SLOT_REF1="ts65" TIME_SLOT_REF2="ts67">
                <ANNOTATION_VALUE>w čān ḥarām w čān qazu. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a35"
                TIME_SLOT_REF1="ts69" TIME_SLOT_REF2="ts70">
                <ANNOTATION_VALUE>w-āxuḏ w-mā_xuḏ. w-hīčiḏ činna ʕāyšīn w maʕāš ʕāyšīn ᵊb-hač-čōl ᵊbyūt šaʕar. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a37"
                TIME_SLOT_REF1="ts73" TIME_SLOT_REF2="ts74">
                <ANNOTATION_VALUE>ᵊbyūt šaʕar.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a38"
                TIME_SLOT_REF1="ts75" TIME_SLOT_REF2="ts76">
                <ANNOTATION_VALUE>ē xayyo, gabǝḷ hīčiḏ, iḥne tā-ngūl ʕašāyir iḥne ᵊb-hal-mikān hāḏa al-Milliyye. ᵊb-zimān nās ᵊtqīr tāxuḏ māl nās zād, yiǧūn mn-al… mn-as-Sʕūdiyye, min ʕArʕar.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a39"
                TIME_SLOT_REF1="ts77" TIME_SLOT_REF2="ts78">
                <ANNOTATION_VALUE>yiǧī-ne hāḏa rayyis al-ᵊʕNizi ygūlū-l-u ibin Miǧlād. w hū šāyil sabiʕ biyārig. māmiš ḥikūme lā b-Sūriyye wala b-Turkiyye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a40"
                TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts80">
                <ANNOTATION_VALUE>w-yiǧī-ne min hēne xayyo, w nās tuḏ̣rub w nās ᵊssannid bī-´ w-mā ytisannad w-yiḏ̣all yuṭrud-ne, iḥne ʕād ta-ngūl ᵊBrāhīm Bāša b-hal-mikān hāḏa. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a41"
                TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts82">
                <ANNOTATION_VALUE>lummun alḥaz yigūlū-l-u Riǧlit Fāris aǧ-Ǧarbe. hāḏi ʕNize kull-he, w ǧāt-ne tuṭrud bī-ne ad-darib.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a42"
                TIME_SLOT_REF1="ts83" TIME_SLOT_REF2="ts84">
                <ANNOTATION_VALUE>al yirūḥ min al… Qōrānšahar ʕala, sabiʕ biyāriǧ ǧō-ne m-as-Sʕūdiyye min ʕArʕar. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a44"
                TIME_SLOT_REF1="ts87" TIME_SLOT_REF2="ts88">
                <ANNOTATION_VALUE>ī waḷḷa, ibin Miǧlād yigūlū-l-u, ʕNnizi.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a45"
                TIME_SLOT_REF1="ts89" TIME_SLOT_REF2="ts90">
                <ANNOTATION_VALUE>min has-sinayyāt ǧī ʕala ǧimāʕa haḏōle yōmin-hum dawwaraw. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a47"
                TIME_SLOT_REF1="ts93" TIME_SLOT_REF2="ts94">
                <ANNOTATION_VALUE>ḥaǧǧi nōbāt agul-l-u waḷḷa… ḥitt ᵊṭʕanaw abū-ye waḷḷa abū-ye nṭaʕan ᵊb-čatf-u, al… al-Fidʕān ᵊṭʕanō-´.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a48"
                TIME_SLOT_REF1="ts95" TIME_SLOT_REF2="ts96">
                <ANNOTATION_VALUE>agūl waḷḷa nōbāt:yā wal waḷḷa agūl l-al-badu intu xāynīn yā walu, w xaḏētu bāʕir-ne w-ṭaʕantu abū-ye. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a49"
                TIME_SLOT_REF1="ts97" TIME_SLOT_REF2="ts98">
                <ANNOTATION_VALUE>w bēn-na w bēn w bēn-hum iḥna zād Ibn ᵊGbēne ᵊb-zimāniyye zād qār ʕalē-ne w-ḏibaḥna ʕabd-u. ibin ᵊGbēne dawle yā xū-ye. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a51"
                TIME_SLOT_REF1="ts101" TIME_SLOT_REF2="ts102">
                <ANNOTATION_VALUE>dawle ibn ᵊ Gbēne qār ʕalē-na zād xaḏa bāʕir-ne. waḷḷa al əḥyō-´ ʕyāl ʕamm-i wēlād ʕamm-i zād.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a52"
                TIME_SLOT_REF1="ts103" TIME_SLOT_REF2="ts104">
                <ANNOTATION_VALUE>huwwa hā gāl haǧǧa-na al-bōdāt w-ḥiḏ̣rū-hin an-nišāme w-al-ʕabid min ḏ̣arb-ha aṭ-ṭāḥib šāyib-u, ᵊḏbaḥō-´ ʕād ʕAdwān</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a53"
                TIME_SLOT_REF1="ts105" TIME_SLOT_REF2="ts106">
                <ANNOTATION_VALUE>čān bēn-na w-bēn-hum, ǧō-ne min ʕArʕar yā xayy-i, hēne xaḏō-ne. sabiʕ biyārig, bass āni ḏīč an-nōbe ziqīr, ahal-ne ysōlfūn. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a55"
                TIME_SLOT_REF1="ts109" TIME_SLOT_REF2="ts110">
                <ANNOTATION_VALUE>čānat tāxuḏ w mā xuḏ gabḷ al-ᵊḥkūma, w waḷḷa min ṣārat al-ᵊḥkūma al-ʕālam. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a57"
                TIME_SLOT_REF1="ts112" TIME_SLOT_REF2="ts114">
                <ANNOTATION_VALUE>istirāḥat alḥamdilla. waḷḷa dawlit-ne zēne yā xū-ye, aḷḷa lā yxarrib-he!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
