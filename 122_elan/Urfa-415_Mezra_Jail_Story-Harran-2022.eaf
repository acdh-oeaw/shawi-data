                TIME_SLOT_REF1="ts321" TIME_SLOT_REF2="ts323">
                <ANNOTATION_VALUE>al-ʕašər wrugāt īdaḥ-ha miṯil al-ḥummuṣ w zitt-ha ʕalay-ye tā_lḥag Bireǧīk. daxīl-ak ḏ̣allēt b-ad-darib āni. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a163"
                TIME_SLOT_REF1="ts325" TIME_SLOT_REF2="ts326">
                <ANNOTATION_VALUE>gabəḷ nahārēn ᵊmdarrib-in-ne imye w xamsīn wruga mā ənṭā-ni, abū-y. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a165"
                TIME_SLOT_REF1="ts329" TIME_SLOT_REF2="ts330">
                <ANNOTATION_VALUE>mā ənṭā-ni ī waḷḷa zaləmləq. yā Ḥasan zatt al-ʕašər wrugāt lakāni maḥkūm, axāf yuḏ̣urbūn-ni.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
