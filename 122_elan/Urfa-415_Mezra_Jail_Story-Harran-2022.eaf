    <TIER LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Corpus:Mezra01">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
                <ANNOTATION_VALUE>āni, ṭəlaʕit min al-ḥabis, al-gaṛāyib, gaṛāyib al-šēnīn intam ᵊtgūlūn iḥna hēne b-al-Məzraʕ ᵊtgūl al-fāynīn.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3"
                TIME_SLOT_REF1="ts4" TIME_SLOT_REF2="ts7">
                <ANNOTATION_VALUE>ē, aš-šēnīn al-fāynīn ʕayne. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>gām ḏ̣ərab ᵊzləmt ač-čälʕāni min ač-Čälʕān ḏ̣ərab wāḥad.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>wla, bint ʕamm-na ʕind-aw, mart al-mayyit binit xāl abū-ye</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts15">
                <ANNOTATION_VALUE>alḥaz al-Məzraʕ āā miṯil al-ǧālūč. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
