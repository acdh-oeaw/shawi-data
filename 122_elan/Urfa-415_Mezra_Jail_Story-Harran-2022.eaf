        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a25"
                TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts50">
                <ANNOTATION_VALUE>Sarqōt b-al-ʕasker, āni b-al-ḥabis Ḥamdi zād čān faqīr, ᵊtʕarif Ḥamdi? al-akbar minn-i, faqīr čān.</ANNOTATION_VALUE>
