                TIME_SLOT_REF1="ts61" TIME_SLOT_REF2="ts62">
                <ANNOTATION_VALUE>wal, gilit, yā ibin ʕamm-i ḥayrān-ak? āni ǧā_šīl ad-damm ʕa-rūḥ-i, ǧaʕad agūl, ben! </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
