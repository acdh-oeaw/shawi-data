                TIME_SLOT_REF1="ts36" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>w-āni grōl-i ṭnāʕaš sine w-āni ʕumr-i siṭṭāʕaš. </ANNOTATION_VALUE>
