        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
                <ANNOTATION_VALUE>b-al-alif w tisʕimye w tisʕa w sabʕīn, b-al-alif w tisʕimye w tisʕa w sabʕīn, yaʕni min gabəḷ xams w ṯalāṯīn sine, abū-ye w ʕamm-i Aḥmad yištaġlūn b-al-petrol.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a2"
                TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>petrol ʕala darib Aqčaqale, petrol ᵊnsammī-he l-Ḥasan Altay, rāʕī-he ṣāḥib-he ism-u Ḥasan Altay, patrol-hum rāʕi, ṣāḥib al-petrol.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3"
                TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>ḏīč as-sāʕa, al-banzīl al-māzōt w-al-qazyāg, ᵊb-Turkiyye čān ʕala dōr ᵊḥkūmit Ecevit. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a4"
                TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>al-fabrīkāt w-az-zanāgīl kull-hum wurč aṣ-ṣāġ parti, iḥna ngūl aṣ-ṣāġ. w Ecevit partit aṣ-ṣōl, yaʕni aṣ-ṣōl. aṣ-ṣāġ parti mā yḥibbūn Ecevit tā yiǧi ʕa-l-iqtidār.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>gāmaw kull-hum yqabbūn māl-hum, as-samin, as-sukkar, al-māzōt, al-qazyāg al yiǧī-´ māl yqabbī-´ ybīʕ-u iḥna nsammī-´ qaraborsa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts13">
                <ANNOTATION_VALUE>ᵊtʕarif maʕnat al-qaraborsa? </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>yaʕni azwad as-siʕir ybīʕūn.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a10"
                TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>hā iḥna, abū-ye w ʕamm-i Aḥmad yištaġlūn b-al-patrol ᵊmdāwara, kull wāḥad yḏ̣all hafte, lēl w nahāṛ, w ytibādalūn aš-šuġul.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>hafte abū-ye yištaġil, hafte ʕamm-i Aḥmad yištaġil, w ʕamm-i Mḥimmad az-ziġīr ʕid-ne ṣār qamyūn,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a12"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>yrūḥ ʕa-l-ᵊKwēt yāxuḏ qanam. yingulūn qanam yǧībūn min qādi māzōt b-as-sayyāra, b-al-qamyūn.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a13"
                TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>arūḥ āni ziġīr ᵊb-gadd Fārūq, abū-ye yōm-in abū-ye tiǧi ṣərāt-u, arūḥ maʕ abū-ye aḏ̣all b-al-petrol.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a14"
                TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>yiǧi at-tankēr, al-māzōt, at-tankēr al-pampa, bī-´ ṯalṯ ᵊʕyūn, ʕēn māzōt w ʕēn banzīl w ʕēn qazyāg.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a15"
                TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>yaʕni ṯnaʕaš ṭōn al-qamyūn, kull arbaʕ ᵊṭwān šakil. ᵊnfaḏ̣ḏ̣ī-hin b-al-patrol.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a16"
                TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>tiǧi al-ʕaskariyye tigaf ʕid-ne. al-ʕaskariyye tigaf w-ᵊngūm ᵊnbīʕ ʕa-l-ʕālam, al-mille txušš b-aṣ-ṣəra.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a17"
                TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>aṭ-ṭaqṣiyyāt al-banzīl kull wāḥad fīš, ninṭī-´ ṯalāṯīn litre b-aš-šahar. min, yāxḏūn m-al-wāli, fīš, aṭ-ṭaqṣi kull šahar luwwa ṯalāṯīn litre banzīl, zōd mā-l-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a18"
                TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts34">
                <ANNOTATION_VALUE>āni agūm abīʕ banzīl, āxḏ al-fīš anṭi ṯalāṯīn litre āxuḏ ḥagg-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a19"
                TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>abū-ye ygūm ybīʕ qazyāg, kull wāḥad yinṭī-´ xaməs litrāt, sitt litrāt, ʕašər litrāt, ʕala fyāšt-u, qarne hā, ᵊnsammī-ha qarne. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a20"
                TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>al-māzōt yiǧūn ač-čiftčiyye zād al-mōtōrāt al-qamyūnāt, kull wāḥad ninṭī-´ xamsīn, sittīn, sabʕīn litre zōd māmiš.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a21"
                TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
                <ANNOTATION_VALUE>sabʕīn litre yāxuḏ al-fīš minn-u ʕamm-i Aḥmad. al-qamyūn, at-tankēr sāʕa zimān, sāʕa w nuṣṣ nfaḏ̣ḏ̣ī-´ xalaṣ. w nuxluṣ šuġul-ne w nugʕud.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a22"
                TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts42">
                <ANNOTATION_VALUE>ā aǧi ʕād āni ʕa-l-midīne, ʕal Kuyubāši gəḏ̣abne dukkān, baqqāliyye fāḏ̣ye lissaʕ mā ḥaṭṭēne bī-´ šī. dukkān miṯil dukkān-i ḏe, bass fāriq.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a23"
                TIME_SLOT_REF1="ts43" TIME_SLOT_REF2="ts44">
                <ANNOTATION_VALUE>zād ḥāyir yaʕni ši-ybīʕ bī-´, ši-ybīʕ bī-´? ʕamm-i Mḥimmad yǧīb m-al-ʕIrāg māzōt, yǧīb ṭōn, xaməs barāmīl.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a24"
                TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts46">
                <ANNOTATION_VALUE>al-māzōt al-ʕIrāg ragīǧ, miṯil al-qazyāg. ᵊnǧīb al-māzōt, ᵊnǧīb-u ʕa-d-dukkān, ᵊnwaǧǧif al-qamyūn b-al-lēl, ǧiddām ad-dukkān, </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a25"
                TIME_SLOT_REF1="ts47" TIME_SLOT_REF2="ts48">
                <ANNOTATION_VALUE>ᵊnḥuṭṭ barāmīl b-ad-dukkān ᵊnfarrq-hun b-ad-dukkān. al-māzōt ta-ngūl al-litre ḏīč as-šāʕa b-wruga, iḥne b-ad-dukkān ᵊnbīʕ-u b-wruga w nuṣṣ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a26"
                TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts50">
                <ANNOTATION_VALUE>ᵊnfukk ad-dukkān aṣ-ṣubuḥ, al-ʕālam tiǧi tǧīb ᵊǧrār hāḏa: ᵊnṭī-ni xamse! hāḏa: ᵊnṭī-ni ʕašər litrāt! ənṭī-ni ʕišrīn litre!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a27"
                TIME_SLOT_REF1="ts51" TIME_SLOT_REF2="ts52">
                <ANNOTATION_VALUE>zād sāʕa zimān sāʕtēn ᵊnbīʕ māzōt ʕamm-i, ṭāgēn ᵊflūs ta-ngūl inčād yiswa milyār ᵊnbīʕ-u b-milyār w nuṣṣ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a28"
                TIME_SLOT_REF1="ts53" TIME_SLOT_REF2="ts54">
                <ANNOTATION_VALUE>awwal məṣāri nilʕab bī-hin liʕib čiṯīr awwali. ʕala dōr Ecevit qəṭṭ, an-nōb ʕugub al-māzōt ᵊngəṭaʕ, al-māzōt ṣār guṭma zōd gām yiǧi ṣār bōl, yaʕni ičṯir al-māzōt.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a29"
                TIME_SLOT_REF1="ts55" TIME_SLOT_REF2="ts56">
                <ANNOTATION_VALUE>kān ᵊnfukk ad-dukkān ᵊnsāwi bī-´, gumne nbīʕ sukkar. ᵊrrūḥ niktib b-al-ᵊhniyye, b-al-qarne, b-al-baladiyye nǧīb ʕišrīn čuwālit sukkar.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a30"
                TIME_SLOT_REF1="ts57" TIME_SLOT_REF2="ts58">
                <ANNOTATION_VALUE>ᵊnǧīb-hin ʕa-d-dukkān, ᵊnzwazzin-hin ʕala xaməs kīlawāt, xaməs kīlawāt.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a31"
                TIME_SLOT_REF1="ts59" TIME_SLOT_REF2="ts60">
                <ANNOTATION_VALUE>tiǧi al-baladiyye tigaf, ᵊnfarrǧ as-sukkar lummun-ma yxalaṣ w trūḥ al-ʕālam txušš ṣəra al-mille. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a32"
                TIME_SLOT_REF1="ts61" TIME_SLOT_REF2="ts62">
                <ANNOTATION_VALUE>kull wāḥad xaməs kīlawāt, ʕašər kīlawāt mā ninṭī-´, ᵊnxallṣ-u. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a33"
                TIME_SLOT_REF1="ts63" TIME_SLOT_REF2="ts64">
                <ANNOTATION_VALUE>ᵊrrūḥ ʕa-t-tekel, nāxuḏ kīlawēn ǧəgār Samsun w Maltepe ism-u. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a34"
                TIME_SLOT_REF1="ts65" TIME_SLOT_REF2="ts66">
                <ANNOTATION_VALUE>yiǧūn zād tiǧi al-baladiyye tigaf kull wāḥad pākiyye pākiyye ziyāde mā ninṭī-´. nxalṣ-u w nugʕud.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a35"
                TIME_SLOT_REF1="ts67" TIME_SLOT_REF2="ts68">
                <ANNOTATION_VALUE>awwali at-Turkiyye čān maʕlūm-ak yaʕni ᵊhniyye šuġul-ha kullši qəṭṭ ʕala… w ṣār inqəlāb ʕād ǧī, ingəlāb Kenan Evren. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a36"
                TIME_SLOT_REF1="ts69" TIME_SLOT_REF2="ts70">
                <ANNOTATION_VALUE>inqəlāb Kenan Evren ʕād yōm-in ǧīʸ. b-ᵊḥsāb ǧī Turgut Özal ʕa-l-iqtidār.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a37"
                TIME_SLOT_REF1="ts71" TIME_SLOT_REF2="ts72">
                <ANNOTATION_VALUE>al-fabrīkāt al mā yḥibbūn aṣ-ṣōl al-Ecevit, kull-hin ᵊftaḥat al-ᵊhniyye w-al-māl kull-u ṣār čiṯīr.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a38"
                TIME_SLOT_REF1="ts73" TIME_SLOT_REF2="ts74">
                <ANNOTATION_VALUE>māzōt čiṯīr, banzīl čiṯīr, as-sukkar ičṯir mā_dri tgūl in raḥme w ǧat ʕala Turkiyye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a39"
                TIME_SLOT_REF1="ts75" TIME_SLOT_REF2="ts76">
                <ANNOTATION_VALUE>ē demek ki mū daʕwut māmiš, daʕwut al-mille az-zanāgīl yōm-in yrīdūn yigṣurūn aš-šakle, tā yxarrbūn al-iqtidār al-partiyye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a40"
                TIME_SLOT_REF1="ts77" TIME_SLOT_REF2="ts78">
                <ANNOTATION_VALUE>miṯil halḥīn alḥaz ǧāʕde al-mille, ta-ngūl partiyyāt aṣ-ṣōl, ysāwūn bahānāt ʕala Ṭayyib ᵊḥkūmit-ne ḏiyye zād ʕala Ṭayyib Erdogan zād.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a41"
                TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts80">
                <ANNOTATION_VALUE>ysāwūn mā šifit ōlāyāt Istanbūl, ōlāyāt al-Güney Doǧu ysāwūn ʕalē-´ qaṣir ᵊhniyyāt tā ywaǧǧʕūn-u. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a42"
                TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts82">
                <ANNOTATION_VALUE>bass aḷḷa yʕāwn-u aḷḷa yaʕni, millit-ne ʕaman gaḷəb-ha naḏ̣īfe, rabb al-ʕālamīn yǧīb-in-ne dawl… iqtidār al yaʕni bašbaqān-in zēn.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a43"
                TIME_SLOT_REF1="ts83" TIME_SLOT_REF2="ts84">
                <ANNOTATION_VALUE>yēlōn aḷḷa yǧīb-in-ne miṯil krālīt al-ʕArab, miṯil Sūriyye w-al-ʕIrāg w-al-Urdun maʕlūm-ak al-Lībya,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a44"
                TIME_SLOT_REF1="ts85" TIME_SLOT_REF2="ts86">
                <ANNOTATION_VALUE>alḥaz čān Turkiyye zād məltāṣa zād xarbāne w-alḥaz zād nuḏ̣rub baʕaḏ̣-na w bass alḥamdilla rabb al-ʕālamīn yḥibb-ne w ʕid-ne wǧūh ᵊṣlāḥ šīʸ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a45"
                TIME_SLOT_REF1="ts87" TIME_SLOT_REF2="ts88">
                <ANNOTATION_VALUE>w millit-ne iḥne, millt at-Turuk Turkiyye al bī-he ʕArab al bī-he w Krād al bī-he w Turk al bī-he.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a46"
                TIME_SLOT_REF1="ts89" TIME_SLOT_REF2="ts90">
                <ANNOTATION_VALUE>aṯ-ṯalāṯe haḏōle kull-he bī-hum wǧūh ᵊṣlāḥ šī w zēnīn šīʸ. w yḥibbūn ad-dīn w yḥibbūn al-xēr w yḥibbūn al-xāṭir.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a47"
                TIME_SLOT_REF1="ts91" TIME_SLOT_REF2="ts92">
                <ANNOTATION_VALUE>w rabb al-ʕālamīn b-ʕizzt-u w ǧalāl-u yḥibb az-zēnīn mā ysāwi bī-hum ᵊhniyye yaʕni bale w muṣībāt w maʕlūm-ak inte w salāmt-ak w-al-ʕāfye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
