    <TIER LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Corpus:Harran23">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
                <ANNOTATION_VALUE>ʕumr-i ṯalāṯīn sine, bin dokuz yüz doksan beş mā-gdar ačāwir-hin b-al-ʕarab, ē ṣirit b-al-midīne</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a2"
                TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>ān… ān d-aḥčī-l-ak ʕala liʕb al-bēš ṭāš, ngūl-l-u xams ᵊḥǧarāt.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3"
                TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>nlaggiṭ m-al-gāʕ xams ᵊḥǧarāt, lāzim yṣīrin al-ᵊḥǧarāt yuwarlaq, yaʕni mīhin ʕūǧ w mūǧ ᵊnlaggiṭ-hin.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a4"
                TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>b-aš-štē nilʕab-hin b-al-bēt wakt-in ʕalatrīk yrūḥ, wakt-in šakle an-nahār, yiṭwal al-lēl, ᵊngūm ᵊhniyye nṭalliʕ, nṭalliʕ ʕalē-hin.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>xams ᵊḥǧarāt nzitt-hin awwal šī marra, ntill kull daqqa wəḥdit-in wəḥde, ᵊnlimm-hin.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>ʕugub b-at-tāli al yiqaznič yzitt an-nōba uxra yzitt al-ᵊḥǧarāt, an-nōba iṯnēn iṯnēn yāxuḏ-hin.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>w b-at-tāli uxṛa yzitt al-ᵊḥǧarāt yāxuḏ awwal ši wəḥde b-at-tāli ṯalāṯe yāxuḏ-hin. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a8"
                TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>ʕugub al-arbaʕ yāxuḏ-hin w b-at-tāli ysāwi miṯil kȫpri, yzitt al-ᵊḥǧarāt kull-hin ygūm yzitt-hin.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>ʕugub-ma yzitt-hin zād ʕala īd wəḥde yzitt al-ᵊḥǧarāt kull-hin ylimm-hin.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a10"
                TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>čādin-hin lamm-hin kull-hin, yāxuḏ ʕašər puanāt. čādin-hin ywaggiʕ wəḥde, yāxuḏ ṯiman puanāt. uxṛa ywaggiʕ wəḥde xaməs puanāt.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>w b-at-tāli hīčiḏ w hīčiḏ, al-liʕbe tgūm ᵊttidāwar, w-al yāxuḏ čiṯīr puanāt yqaznič. hāḏi zād ʕala gəṣṣat al-xams ᵊḥǧarāt. liʕbe. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a13"
                TIME_SLOT_REF1="ts24" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>ē, aḷḷa yinṭī-k.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
