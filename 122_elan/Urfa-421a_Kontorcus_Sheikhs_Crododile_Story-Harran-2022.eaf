    <TIER LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Corpus:Ziyara01">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a8"
                TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>konturǧi tʕarf-u mū? </ANNOTATION_VALUE>
