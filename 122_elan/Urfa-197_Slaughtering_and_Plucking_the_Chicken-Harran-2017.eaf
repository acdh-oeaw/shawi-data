    <TIER LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Corpus:Harran02">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>ē.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a4"
                TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>ē, ad-diǧāǧe xōǧam, yōm-in, ad-diǧāǧe al-barri ta-ngūl ᵊhniyye al b-al-gaṛāye. iḥne ngūl köy tavuğu.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>nāxuḏ ad-diǧāǧe, ᵊnǧīb-he ʕa-l-bēt, lissaḥ-ḥa ṭayybe.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>hā agḏ̣ub āni aḏbaḥ-ha, agṭaʕ kallit-he, ʕugub-ma aḏbaḥ-ḥa nǧabbil-he ǧible, ad-diǧāǧe, ᵊnrīd niḏbaḥ-ḥa nsammi bismilla.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>nigṭaʕ kallit-he, baʕadēn armī-he, umm Fārūg, Amīne, ᵊtḥuṭṭ b-aǧ-ǧidrīt ač-čibīre mayye, ᵊtfawwur-he. ᵊtfawwr al-mayye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a8"
                TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>baʕad-ma tfawwur al-mayye ǧǧīb al-mayye tirmī-he, ᵊǧǧīb ad-diǧāǧe b-timmit-he. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>ᵊtḥuṭṭ-ha b-al-mayyt al-ḥāṛṛa hīčiḏ zēn guṭma daqīqtēn xamis daqāyiq ᵊtxallī-ha ʕašər daqāyiq,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a10"
                TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>lummun-ma d-diǧāǧe tišrab mayyt al-ḥāṛṛa, tuṭlaḥ-ḥa m-aǧ-ǧidriyye, al ᵊhniyye ʕād aš-šaʕ… ᵊhnīt ad-diǧāǧe rīšt ad-diǧāǧe yṣīr il-ḥāl-u ytimaṭṭaḥ. yiṭluʕ yaʕni.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>ᵊtgūm ʕād ᵊtlim… ᵊtmaʕʕiṭ-ha tmaʕʕiṭ ar-rīš. ᵊtmaʕʕiṭ-ha b-nōba ᵊb-ʕašər daqqāt mā yḏ̣all ʕalē-´ rīše wəḥde.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a12"
                TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>ʕugub ʕād tugḏ̣ub tugḏ̣ub ᵊhnīt-he min hēne ḥōṣalit-he, tigšim-he. tigšim al-ḥōṣala, w tuṭlaʕ al-ḥunṭa, al-ḥōṣala.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a14"
                TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>ē, al-finduwwe yaʕni, iḥne ngūl al-ḥōṣala. al-finduwwe yaʕni, al-finduwwe iḥne nsammī-´ l-ḥōṣala.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a15"
                TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>tuṭlaʕ al-ḥunṭit al-ġādi tnaḏ̣ḏ̣if-ha hīčiḏ aǧ-ǧilid tislax-u tirmī-´ b-ač-čōp.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a16"
                TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>w-ᵊtfukk čaršit-he zād, tuṭlaʕ məṣārīn-he. w ǧigār-he w gaḷəb-ha, aš-šīt al-ᵊhniyye tnaḏ̣ḏ̣əf-ha zēn, ᵊtqassil-he.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a17"
                TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts34">
                <ANNOTATION_VALUE>baʕdēn-ma tqassil-he tirmī-he ʕād tugḏ̣ub-ul-he ad-dahre, alle s-siččīne yōma ad-dahre.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a18"
                TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>ᵊtgaṭṭiʕ-ḥa, ᵊfxaḏ̣-he w hnīt-he zēn ᵊtkassir-he zēn, w ᵊtrīd ʕād ᵊǧǧīb ᵊtḥuṭṭ ᵊhniyye,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a19"
                TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>ᵊtḥuṭṭ guṭmut xāšūgtēn samin w-ᵊtḥuṭṭ-ha b-al-ᵊhniyye w mayye. w-ᵊtgūm tiṭbax-ha tḥamiṣ-he linne.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a20"
                TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
                <ANNOTATION_VALUE>nākul-he ʕal ʕēš al-burqul, ʕal ʕēš ar-rizz, yṣīr zēn ṭʕamit-he zēne yaʕni ad-diǧāǧ al-barri.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
