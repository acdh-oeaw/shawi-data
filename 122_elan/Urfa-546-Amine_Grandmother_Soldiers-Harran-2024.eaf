        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a36"
                TIME_SLOT_REF1="ts71" TIME_SLOT_REF2="ts72">
                <ANNOTATION_VALUE>bir daha, b-at-turuk ʕād ᵊtṭabbiš umm-i hā. bu adamı dokuni ben bu kızı öldüri. bu adam şimdi geldi.</ANNOTATION_VALUE>
