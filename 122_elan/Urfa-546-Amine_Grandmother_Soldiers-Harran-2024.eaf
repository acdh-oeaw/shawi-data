    <TIER LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Corpus:Harran03">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
                <ANNOTATION_VALUE>w-ᵊtgūl w gimne zāten-ne ʕugub al-ᵊhniyye ʕād raḥalne ʕal Aqčaqale, m-aǧ-ǧarye yaʕni hā. āni ʕād ṣāyre, en ṣōn Miryam ṣāyre.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a2"
                TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>wakt-in Miryam ṣāyre ygūl, Miryam-ne uxt-i ṣāyre, w ǧāye al-ᵊhniyye ṣāyre, fēle ygūl fēle ṣāyre yaʕni kuraklık. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3"
                TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>ṣāyre, wakt-in Miryam uxt-i ṣāyre, sint al-xarāb ygūlū-l-he. ᵊb-Turkiyye hēne sint al-xarāb. ygūl xarāb yaʕni məṭar māmin.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>məṭar māmin fēle, fēle zariʕ māmin šakle māmin uxt-i ṣayre, Miryam.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>ygūl alḥaz sint al-xarāb wakt-in yisʕalūn-he ygūlūn sint al-xarāb ṣāyre, Miryam. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>w gāyim ʕādēne rḥamt abū-y demek wāḥad rāyiḥ, yrīd yrūḥ ʕa-l-qačaq miṯil xawāl-i awwali yrūḥ ʕa-l-qačaq.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a8"
                TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>w gūm w taʕāl w-al-ʕaskari demek ki mʕayyin ʕalē-hum šāyif-hum gāyil-l-hum lā tihnūn! aḏ̣rub-ak mā aḏ̣rub-ak, aḏ̣rub-ak mā aḏ̣rub-ak.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>w gāyim belči ḏ̣ārib-hum ᵊhniyye mū gadrān-il-hum. w taʕālu uḏ̣rubu l-ʕaskari, ism-u hniyye, aḏ̣-ḏ̣ārbīn ḏābḥīn al-ʕaskari, ī iṯnēn huṃṃa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a10"
                TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>huwwa gāyim xāmš-u, demek rāʕīn ᵊlḥe zā, xāmš-u min waǧh-u. xāmš-u min waǧh-u, al-ʕaskari xāmš az-zlime min waǧh-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>w lābis xātam, gāyil, al-ʕaskari al gāyil hā, mā ʕād alḥaz šwayyt-in āxar šwayye afṭan ʕala hnīt-u afṭan lissaʕ-u b-al-ʕIlle.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a13"
                TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>šahīd ṣār lissaʕ-u b-al-ʕIlle, ahal-u dammō-´ b-al-ʕIlle. maḥḥad yaʕni ahal-u ǧāw hēne w dammō-´, b-al-ʕIlle w ḏ̣all. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a14"
                TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>ḥitte zēn ygūlū-l-u w-āni nahāṛ lē ᵊhnēne ṣārat qəsme rrūḥ ʕa-l-ʕIlle, </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a16"
                TIME_SLOT_REF1="ts30" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>alle ašawwf-ak gabr-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a17"
                TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts34">
                <ANNOTATION_VALUE>arūḥ ʕalē-´ agul-l-ak daḥḥiǧ hāḏa as sōlafit ʕalē-´ aš-šahīd al gilt-ill-ak ʕinn-u. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a18"
                TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>hā, w ygūm ʕādēne ḏ̣all ᵊb-gabr-u kull-ne niftil ʕalē-´ ḥawālē-´ yamm al-ʕaskariyye, wakt-in-ne zqār.  </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a19"
                TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>kull-u ḥāṭṭīn ḥawālē-´ mṣannʕīn gabr-u, msāwīn yaʕni kenārāt-u warid w msāwīn ᵊhniyye, ḥawā… Šākir, Šākir ism-u. ism-u Šākir al-ʕaskari. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a20"
                TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
                <ANNOTATION_VALUE>w gāymīn ʕād Šākir uḏ̣rub gāyil: āni ḥaṭṭēt belči wakt-in ǧāyīn ʕala Šākir demek ḏ̣arb al-ʕaskari. wakt-in ḏ̣ārib al-ʕaskari w mxallī-´. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a21"
                TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts42">
                <ANNOTATION_VALUE>ᵊmxallī-´ w minhizim ʕala Sūriyye wakt-in minhazim ǧāyīn ʕa-l-ʕaskari, wunn al-ʕaskari ḏ̣āll ᵊb-tāli yrūḥ … šāylitt-u.   </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a22"
                TIME_SLOT_REF1="ts43" TIME_SLOT_REF2="ts44">
                <ANNOTATION_VALUE>umm ism-u Šākir gāyil, gāylī-l-u hniyye: Šākir min aḏ̣ ḏ̣rab-ak? gāyil: aḏ̣ ḏ̣ərabt-u rāʕi liḥye, ḥaṭṭēt ᵊb-waǧh-u nīšān, lābis xātam, aḏ̣ ḏ̣ərab-ni.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a23"
                TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts46">
                <ANNOTATION_VALUE>hā w gāymīn ʕādēne w hāḏa ism-u Ḥaydar al-komuṭān ᵊmsāwi bi-l-ʕIlle. ḏāk an-nahāṛ ᵊrḥamt abū-y yiǧi yištaġil ušhur ušhur yḏ̣all, ušhur yḏ̣all b-al… ʕind ʕind al-qawāt.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a24"
                TIME_SLOT_REF1="ts47" TIME_SLOT_REF2="ts48">
                <ANNOTATION_VALUE>yaʕni iki ay üç ay wunn-u ǧāy al-liḥye hīčiḏ ṣāyre w ṣār ᵊšnōn at-trāb w-al-wusax w šī ǧāy, m-aǧ-ǧarye yaʕni ǧāy hā kull-u ǧaʕ ysūg.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a25"
                TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts50">
                <ANNOTATION_VALUE>yaʕni b-al-gərrāṭāt w-b-al-ᵊhniyyāt ysūg yaʕni hā, b-al-filḥ yaʕni mū gərrāṭa zād māmin zād filḥ, yiflaḥ al-ᵊhniyyāt al-guwāʕi b-al-moṭōrāt yiflaḥūn.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a26"
                TIME_SLOT_REF1="ts51" TIME_SLOT_REF2="ts52">
                <ANNOTATION_VALUE>wunn-u ǧāy ḥāl-u mū haḏāk an-nahāṛ ʕād ǧāy ʕala bēt-u ʕala ʕaǧiyyāt-u tā yšūf ʕaǧiyyāt-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a27"
                TIME_SLOT_REF1="ts53" TIME_SLOT_REF2="ts54">
                <ANNOTATION_VALUE>wakt-inn-u ǧāy ygūlūn: inn-u hāḏa al-ᵊhniyye al-komuṭān ygūl l-ahal al-ᵊbyūt: taʕāl az-zilum taʕāl al-ḥarīm al-bēt.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a28"
                TIME_SLOT_REF1="ts55" TIME_SLOT_REF2="ts56">
                <ANNOTATION_VALUE>kull min ᵊhniyye gāḏ̣ib al-ʕaṣa al… al… al-ʕaṣa w hahōha yiktul al-awādim. al-komuṭān hā ač-čibir. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a29"
                TIME_SLOT_REF1="ts57" TIME_SLOT_REF2="ts58">
                <ANNOTATION_VALUE>yuktul-hum ygūl-il-hum uṭluʕū-l-i az-zlime ḏāk al-bāriḥ aḏ̣ ḏ̣ərab al-ʕaskari. uṭluʕū-´!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a30"
                TIME_SLOT_REF1="ts59" TIME_SLOT_REF2="ts60">
                <ANNOTATION_VALUE>ᵊnhibal yaʕni. ygūl wakt-in kull-hum ṭālʕīn ᵊb-nōba ygūl ḥāṭṭīn al-zilum ʕala wuruč w-al-ḥarīm ʕala wuruč. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a31"
                TIME_SLOT_REF1="ts61" TIME_SLOT_REF2="ts62">
                <ANNOTATION_VALUE>ygūl wakt-in šāyfīn rḥamt abū-y. zād o gün ʕaksine rḥamt abū-y ǧāy m-al-ᵊhniyye, m-aš-šuqul, ǧāy m-aš-šuqul.</ANNOTATION_VALUE>
