    <TIER LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Corpus:Harran02">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a2"
                TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>ī, al-ḥiǧǧe xōǧam, yaʕni al-ḥiǧǧe hniyye: ytaḥaǧǧaǧ mū maʕna… yaʕni al-ḥiǧǧe iki, tiǧi ʕala maʕanātēn.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3"
                TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>al-ḥiǧǧe wəḥde ḥaǧǧ, al-ḥiǧǧ yrūḥ yḥiǧǧ yzūr al-ḥiǧǧ, zād ygūl-il-he ḥiǧǧe rāḥ ʕa-l-ḥiǧǧ ǧāy… al-ḥiǧǧe.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a4"
                TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>w ikinǧisi al-ḥiǧǧe maʕanāt-ha al šakilt-in mā yhawa, al-ādami yōm-in aš šakilt-in al mā yhawā-ha, ygūl ytaḥaǧǧaǧ: arīd ataḥaǧǧaǧ-l-i bi-ḥiǧǧe.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>ta-ngūl al-xōǧe l-muġrib ṣāḥ-l-i ʕa-l-bēt ʕəzam-ni. Štēfan xōǧe gāḷ: al-muġrib taʕāl maʕzūm ʕind-i.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>āni mā_rīd arūḥ ʕala ʕazīmt-u, arīd ataḥaǧǧaǧ-l-i bi-ḥiǧǧe yaʕni agul-l-u: xōǧam rās-i yōǧiʕ-ni, wēya ište arīd arūḥ ašūf waǧʕān, wēya ǧō-ni xuṭṭār, wēya yaʕni mā_rīd mā-ni hāwi.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>mā-ni hāwi tā_rīd arūḥ, ataḥaǧǧaǧ-l-i b-šakle agūl-he ḥiǧǧe yaʕni. yaʕni hāḏi maʕanāt al-ḥiǧǧe yaʕni yōm-in šīt-in mā yhawā-ha l-ādami ygūl ytaḥaǧǧaǧ ḥiǧǧe. maʕanāt al-ḥiǧǧe hāḏi hiyye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
