    <TIER LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Corpus:Harran03">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
                <ANNOTATION_VALUE>huwwa ʕrubi taxtūr, hā w axū-´ zādēn demek luwwa šuġul mā_dri yihni gāyil l-axū-´ gāyil: wal xayy-i taʕāl inte ᵊbidāl-i tā tihni hniyye. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a2"
                TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>gāyil: al yiǧi waǧʕān, gāyil: xayy-i inte taxtūr āni ᵊšnōn ᵊhniyye anṭi agdar aktib ʕilāǧ bidāl-ak? šnōn aktib?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3"
                TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>gāyil tigdar tigdar tiktib inte bass al yiǧi lā ssāwi šī bass iktib-ill-u hniyye. iktib-ill-u ḥabb zalambūḥ w xall-u yrūḥ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a4"
                TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>neyse gāyim at-taxtūr rāyiḥ w-axū-´ ǧāy ǧaʕad ᵊbidāl-u w ǧāy al-waǧʕān, ayayayay baṭn-i tōǧiʕ-ni. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>gāyim kātb-ill-u ḥabb ᵊhniyye, ḥabb zalambūḥ, w mdarrb-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>uxṛa ǧāy wāḥad ayayayay yšawwif ta-ngūl fōg min fōg min hēne ᵊktūf-u w-hnīt-u ṣadr-u, ayayayay</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>uxṛa gāyim hāḏa kātb-ill-u hniyye, ḥabb zalambūḥ, tss!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a8"
                TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>neyse uxṛa wāḥad ǧāy, han-nōb haḏa īd-u maksūra, ǧāy ʕalē-´ yšawwif īd-u, gāyim uxṛa kātb-ill-u ḥabb zalambūḥ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>gāyil: hā! hāḏa ḥarām kitabt-ill-i ḥabb zalambūḥ, āni īd-i maksūra, ḥabb az-zalambūḥ ʕalē kitabt-u? gāyil: inte šnōn īd-ak ᵊnkasrat?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a10"
                TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>gāyil: āni waḷḷa rigēt ʕa-š-šǧaṛa, wugaʕit min fōg aš-šǧaṛa, w-ᵊnkasrat īd-i.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>ē, gāyil: lōn mū b-ṭīz-ak dūde, ši-mraggī-k fōg aš-šǧaṛa. hahaha.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LINGUISTIC_TYPE_REF="Subdivision" PARENT_REF="Corpus:Harran03" TIER_ID="Trans03">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a12" ANNOTATION_REF="a1">
                <ANNOTATION_VALUE>There was an Arab who was a doctor; his brother had another job, though I don’t know what it was. He said to his brother, “Come and make (my job) instead of me!”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a13" ANNOTATION_REF="a2">
                <ANNOTATION_VALUE>He said, “(Treat) the one who comes as a patient.” He replied, “My brother, you are a doctor, but how can I prescribe a medicine instead of you? How can I prescribe it?”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a14" ANNOTATION_REF="a3">
                <ANNOTATION_VALUE>He said, “You can. You can prescribe a medicien. When someone comes in, just prescribe him some anthelminthic drug and let him go.”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a15" ANNOTATION_REF="a4">
                <ANNOTATION_VALUE>Anyway, the doctor left, and his brother came in his place. A patient came saying, “Ouch! Ouch! My stomach hurts!”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a16" ANNOTATION_REF="a5">
                <ANNOTATION_VALUE>He prescribed that pill for him, the anthelmintic drug, and let him go on his way.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a17" ANNOTATION_REF="a6">
                <ANNOTATION_VALUE>Another person came saying, “Ouch! Ouch! He showed the upper parts of his shoulders and his chest in pain.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a18" ANNOTATION_REF="a7">
                <ANNOTATION_VALUE>He once again prescribed him the thingy, the anthelmintic drug.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a19" ANNOTATION_REF="a8">
                <ANNOTATION_VALUE>Another person came with a broken hand, showing it to him. Once again, he prescribed the anthelmintic drug.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a20" ANNOTATION_REF="a9">
                <ANNOTATION_VALUE>He said, “I see you have prescribed an anthelmintic pill for me. My hand is broken, why did you prescribe an anthelmintic?”(The doctor) replied, “How did you break your hand?”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a21" ANNOTATION_REF="a10">
                <ANNOTATION_VALUE>He said, “I climbed a tree and then I fell from the top of the tree and broke my hand.”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a22" ANNOTATION_REF="a11">
                <ANNOTATION_VALUE>The doctor said, “If there were no worm in your ass, you wouldn’t have climbed the tree.” Ha ha ha ha!</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
