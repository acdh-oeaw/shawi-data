    <TIER LINGUISTIC_TYPE_REF="Subdi" PARENT_REF="Corpus:Harran02" TIER_ID="Trans02"/>
    <TIER LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Corpus:Ceylanpinar02">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
                <ANNOTATION_VALUE>iḥne ǧāyīn min Naǧid bēn as-Sʕūdiyye w-al… w-al-Yaman. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a4"
                TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>Naǧid, Naǧid, Naǧd al-ʕariyye. ā, w-kuṯrut-ne b-al-Yam… ᵊb-Naǧid w-as-Sʕūdiyye </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts8" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>ʕAdwān, ʕašīrit ʕAdwān. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a8"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>as-Sʕūdiyye w Naǧid, w-al-Urdun zād bī-he. tā-ngūl iḥne ʕād ǧīne min Naǧid, awwal-ma ṭabbaw ahal-ne min Naǧid. iḥne maʕa l-Milliyye maʕa l-Milliyye hēne, iḥne badu ǧīne min, min Naǧid. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a10"
                TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>ahal-na ʕād yom-inn-hum ǧaw yi… gabǝḷ ahal bāʕir w yḥadūn yḥadūn tā-ngūl.ᵊngūl ḥitt awwal mūmin.w-iḥne ǧīne min Naǧid Ṣalība w-min xilfit ʕAli.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a12"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>Ṣalībe min xilfit ʕAli.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a13"
                TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>iḥne wēlād ʕAli Abu ᵊḤsēn. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a16"
                TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>ygūl iḥne ǧīne min Naǧid Ṣalība w-min xilfit ʕAli. iḥne ǧīne min aḏ-ḏwēde yirʕa b-xašm al-mōdali, aḏ-ḏwēde al-bāʕir hā. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a17"
                TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>ī, waḷḷa ʕala hīčiḏ ǧīne ahal-na min haḏīč al-ʕarab.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a18"
                TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts34">
                <ANNOTATION_VALUE>min, min bēn al-Yaman w-bī-´ isim-ha Naǧd al-ʕariyye. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
