        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a13"
                TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>ā, w ṯōb šappāni w-ᵊzbayyin-in ḥamar min hal-ᵊhniyye ylabbsūn-ha.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a14"
                TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>w yrūḥ yǧībūn al-biʕīr  w ǧ... yḥuṭṭūn yǧībūn al-lubbāde. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a16"
                TIME_SLOT_REF1="ts30" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>w yǧībūn al-lubbāde, yōm-in yǧībūn al-lubbāde yšiddūn ʕa-l… yǧībūn al-lubbāde ysāwūn-ha miṯil al-ḥalga, al-lubāde.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a17"
                TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts35">
                <ANNOTATION_VALUE>miṯil al-ḥalga w yḥuṭṭūn-he fōg w ynaxxūn al-biʕīr w yḥuṭṭūn-he fōg al-biʕīr.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a19"
                TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>yšiddūn-ha ʕād w yḥuṭṭūn fōg-ha ǧāǧim yḥuṭṭūn fōg-ha sāḥa ǧāǧim yḥuṭṭūn fōg-ha w-aš-šarāšib, </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a20"
                TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
                <ANNOTATION_VALUE>yḥuṭṭūn aš-šaṛāšib w yqawwūn ʕād al-biʕīr. yǧībū-l-u šarāšib w-ᵊyǧībū-l-u sifīfe yluffūn ʕalē-´ w yḥuṭṭūn-u b-rās-u yḥuṭṭūn il-biʕīr.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a21"
                TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts42">
                <ANNOTATION_VALUE>w yuguʕdin aṯ-ṯnēne, wəḥde min hēne w wəḥde min hēne. </ANNOTATION_VALUE>
