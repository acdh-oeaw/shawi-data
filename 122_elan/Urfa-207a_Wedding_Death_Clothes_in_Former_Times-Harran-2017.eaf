        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a24"
                TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts50">
                <ANNOTATION_VALUE>yuguʕdun fōg al-biʕīr, ḥurumtēn.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a27"
                TIME_SLOT_REF1="ts53" TIME_SLOT_REF2="ts54">
                <ANNOTATION_VALUE>w-al-ʕarūs zād yǧībūn-he yǧiʕdūn-he zād ᵊb-nuṣṣ al-ḥurumtēn.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a28"
                TIME_SLOT_REF1="ts55" TIME_SLOT_REF2="ts56">
                <ANNOTATION_VALUE>ṯalāṯe, al-biʕīr yšīl ṯalāṯe, ṯalaṯ ḥarīm, w yḥuṭṭūn yḥuṭṭūn-he ygūm ygūdūn-he w yqannūn ʕalē-he. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a30"
                TIME_SLOT_REF1="ts59" TIME_SLOT_REF2="ts60">
                <ANNOTATION_VALUE>ᵊsmān walla xō… ᵊxfāf wala hniyye yʕaddlūn-hin ᵊb-baʕaḏ̣-hin w yiǧiʕdūn-hin. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a32"
                TIME_SLOT_REF1="ts63" TIME_SLOT_REF2="ts64">
                <ANNOTATION_VALUE>yḥuṭṭūn-ha wəḥde m-al-ḥarīm, min hēne, wəḥde min hēne m-al-ḥarīm. b-al-ᵊḥṣār ygūlū-l-u ḥṣār. ʕala ʕa-l-ᵊhniyye, ʕa-l-lubbāde.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a34"
                TIME_SLOT_REF1="ts67" TIME_SLOT_REF2="ts68">
                <ANNOTATION_VALUE>yšiddūn zēn yqurbūn al-lubbāde b-al-maras lummun yidʕūn-he miṯil al-ᵊhniyye w yḥuṭṭūn-he fōg ᵊhnīt al-biʕīr.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a35"
                TIME_SLOT_REF1="ts69" TIME_SLOT_REF2="ts70">
                <ANNOTATION_VALUE>fōg ᵊhnīt āāā ᵊhniyye al-biʕīr ṣanā… ṣanām al-biʕīr. aw yǧībūn ʕād yḥuṭṭūn al-ᵊhniyye yǧībūn ᵊšwā… haḏāk al-ʕubēdi yḥuṭṭūn awwali ʕubēdiyyāt.</ANNOTATION_VALUE>
