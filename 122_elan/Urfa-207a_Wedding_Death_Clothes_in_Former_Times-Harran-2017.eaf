                TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>ǧazmat-in ḥamṛa w bī-he širšiba hīčiḏ hāḏi ǧazmit al-ʕarūs. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a12"
                TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>w-ᵊylabbsūn-he ᵊmḥērmit-in … min hal-guṭniyyāt.</ANNOTATION_VALUE>
