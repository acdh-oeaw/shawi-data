                TIME_SLOT_REF1="ts73" TIME_SLOT_REF2="ts74">
                <ANNOTATION_VALUE>w yǧībūn aš-šarāšib yqawwūn al-biʕīr ylabbsūn-u zādēne ylabbsūn-u sifīfe w kull-ha, šarāšib.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
