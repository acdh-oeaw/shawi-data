        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a36"
                TIME_SLOT_REF1="ts71" TIME_SLOT_REF2="ts72">
                <ANNOTATION_VALUE>ᵊmnaggašāt miṯil-he kull-u hniyye, darak w warag w-ᵊhniyye yḥuṭṭūn ʕalē-hin yuršugūn ʕalē-´. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
