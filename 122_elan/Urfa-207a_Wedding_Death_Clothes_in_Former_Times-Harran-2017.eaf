                TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts82">
                <ANNOTATION_VALUE>ʕa-l-biʕīr, ā yḥuṭṭūn ṯalaṯ ḥarīm, al-ʕarūs w ḥurumtēn. ā w ygūmin yqannin, ygūmin yqannin ʕal ʕa-l-ʕarūs fōg al-biʕīr.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
