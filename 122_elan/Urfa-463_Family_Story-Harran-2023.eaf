    <TIER LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Corpus:Harran03">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
                <ANNOTATION_VALUE>taww-ne riḥna ʕala, ʕala zaffit walda xāl-i w-al-ʕaǧiyyāt ʕa-d-darib yisʕalin-ni.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a2"
                TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>yigūl: hāḏa šī yaʕni, šinhi hnīt-u gurbut-u ličče? šī yṣīr-ill-ič? gitt: hāḏa, hāḏa walda xāl-i.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3"
                TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>lōn-mu alḥaz awwali b-zimānāt. hāḏa xāl-u, māxḏ umm-iʸ, xāl-u, xāl az-zlime ḏe māxḏ umm-i.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a4"
                TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>ḏ̣ālla umm-i ʕind-u sabʕ ᵊsnīn w mayyit. umm-i awwali b-zimānāt čiṯīr zēne waqt-in-he bnayye. hā w gāyim hāḏe, wāḥad min ahal aǧ-ǧarye gāyim yirīd-he.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>gāyim yrīd-he huwwa zād ḥasīn, al-ʕaǧi al yrīd-he, hā w gāyme ḥabbābt-i ḏāk al-wakit ʕid-he ʕiǧyān-he, mā ʕala mlaḥḥǧit-hum māmin, safīlliq w ǧūʕ w ʕaṭaš.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>hā w gāyim hāḏa huwwa ač-čibīr, wālid-he  Mḥimmad, w hiyye zād ʕid-hum Farḥa al-ʕaǧiyye, al-ʕaǧiyye uxt, uxt al-ʕaǧi ṣṣīr.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>uxt al-ʕaǧi, isim-ha Farḥa, han-nōba hniyye mīhi zēne zād ta-ngūl, mīhi samra, umm-i axēr min-he b-aš-šaxaṣ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a8"
                TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>hā ygūm ʕād al-ʕaǧi hāḏe al yrīd umm-i, ism-u Xiḏ̣ir. yrīd w yrīd umm-i, w ḥabbābt-i ʕād gāyle: lā xayyo, al-ḥarīm yʕallmin ḥabbābt-i gāylāt axēr mā tinṭīn bint-ič, al haḏōle.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>w mā ʕid-hum šī fāṭsīn. uxḏi zād binit-hum sāwī-he hniyye, tibādalu yaʕni, ənṭi bint-ič uxḏi zād binit-hum.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a10"
                TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>hā w gāymīn w gāylīn: tamām! wakt-in gāymīn yinṭūn ʕād tā yaxḏūn ᵊhniyye, gāymīn ʕād tā yinṭūn binit-hum haḏōlak ᵊhniyye, al-ʕaǧiyye mū gablāne.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>gāyme tkāwin ᵊtqāfix w mā tigbal mā trīd xāl-i, xāl-i šwayye yaʕni zēn amma mū hniyye, mā tigbal-u mā trīd-u balči ʕāšǧe qēr ḥade maḥḥad yindall aḷḷa yindall.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a12"
                TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>hā, w ygūm axū-ha al yrīd umm-i, yuktil-he čatle lummun yiʕǧiz-he, tā tā, tā yinṭī-he il-xāl-i, b-az-zōr yaʕni hā.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a13"
                TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>yuktil-he hiyye bi-čatil yinṭī-he il-xāl-i, hā w tgūm ʕādēne, tgūm ʕād hiyye tāxuḏ qəǧəq min umm-i, tāxuḏ qəǧəq min umm-i. ʕaman mū axū-ha ǧaʕad yrīd umm-i? axū-ha yiǧbur-hum.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a14"
                TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>axū-ha yiǧbur-hum yigūl: yaʕni alli ti-trūḥīn ʕa-z-zlime ḏe ʕala axu al ʕaǧīt al arīd-he tā yinṭūn-ni yā-ha.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a15"
                TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>az-zlime zād iḥne ʕinid-na l-ʕarab mū daha hniyye daha kuvvetli? daha al-ḥukum b-īd-u?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a16"
                TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>hā ygūmūn ʕādēne yinṭūn ʕād haḏīč ᵊtrūḥ ʕala xāl-i, w hāḏe yāxuḏ-he az-zlime ḏe ism-u Xiḏ̣ir yāxḏ umm-i.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a17"
                TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts34">
                <ANNOTATION_VALUE>ygūm ʕād eyle yištahī-he hnīt-hum yaʕni ʕašgit-hum, w hnīt-hum ᵊṣṣīr destān l-ahal aǧ-ǧarye, yaʕni al-kull ytisōlaf ᵊb-ʕašgit-hum b-ᵊhnīt-hum ytisōlaf ahal aǧ-ǧarye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a18"
                TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>w ygūmūn ʕādēne han-nōba yihnūn, ʕugub ʕādēne mā yāxuḏ-he yigūm aṣṣōb-ma yṣīr ʕiris, mā ʕid-hum ʕēb miṯil alḥaz.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a19"
                TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>ygūl yrūḥ yišḥaḏ-il-he hdūm mā ʕid-hum awwali al-ᵊhdūm māmin, al-libs az-zēn al-qawwi māmin</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a20"
                TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
                <ANNOTATION_VALUE>ygūm yrūḥ yišḥaḏ-il-he hdūm min hēn… m-aǧ-ǧārāt, aṣṣōb šī ṭaxm-in zēn yiǧi ylabbs-u l-umm-i, w yugḏ̣ub īd-he w yāxuḏ-he mū māl-he zād mū ṣāyr-il-he ḏanne, sabʕ ᵊsnīn mū ṣāyr-ilhe ḏanne.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a21"
                TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts42">
                <ANNOTATION_VALUE>w gāyim ʕād yāxuḏ-he, ī, yāxuḏ-he kull-ma yṣīr ʕiris yiṣīr b-aǧ-ǧaryit al-ᵊflāniyye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a22"
                TIME_SLOT_REF1="ts43" TIME_SLOT_REF2="ts44">
                <ANNOTATION_VALUE>yirčib-he w yāxuḏ-he w yrūḥ ʕa-l-ʕiris yrūḥūn yidbičūn, yʕaris ahal al-bēt ykayyfūn, yrūḥūn yṣabbḥūn ahal al-bēt yaʕni hā.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a23"
                TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts46">
                <ANNOTATION_VALUE>w yirkabūn w yiǧūn, aṣṣōb balay ʕazīme hā, awwali balay ʕazīme mū miṯil alḥaz.  </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a24"
                TIME_SLOT_REF1="ts47" TIME_SLOT_REF2="ts48">
                <ANNOTATION_VALUE>awwali, alḥaz lōn ʕind aṭ-ṭāga tṣīr in mā yʕazzmūn-ne, maḥḥad yrūḥ. amma awwali balay ʕazīme n-nās tiǧi ʕala baʕaḏ̣-ha ʕa-l-ʕiris, min yismaʕūn ḥiss aṭ-ṭabla,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a25"
                TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts50">
                <ANNOTATION_VALUE>yigūm kull-min ʕind-u ḥurma, kull-min ʕind-u bnayye, kull-min ʕind-u hniyye, yrūḥūn ytifarraǧūn ʕa-d-dabče.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a26"
                TIME_SLOT_REF1="ts51" TIME_SLOT_REF2="ts52">
                <ANNOTATION_VALUE>hāḏe zād ygūm yāxuḏ-he, w ṭāyrīn min dabče il-dabče. ygūmūn ʕād b-al-bēt šī ḥamāt-he, ḥamāt umm-i.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a27"
                TIME_SLOT_REF1="ts53" TIME_SLOT_REF2="ts54">
                <ANNOTATION_VALUE>hā, haḏīč zād mā yṣīr-il-he ḏanne, ṣāyr-il-he bass wlēd w ṣəgaṭ, walad-he. hā, ᵊtgūm ʕādēne, umm-i tgūl mā ʕid-hum šī magdūrīn ḍurum-hum mū zēn.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a28"
                TIME_SLOT_REF1="ts55" TIME_SLOT_REF2="ts56">
                <ANNOTATION_VALUE>ᵊtgūl ᵊrrūḥ hā, awwali māmin gərrāṭāt māmin, awwali yrūḥin ylaggṭin ygūl ylaggṭin al-ḥunṭa, ylaggṭin-ha m-al-gāʕ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a29"
                TIME_SLOT_REF1="ts57" TIME_SLOT_REF2="ts58">
                <ANNOTATION_VALUE>al mū yṣīr ḥaṣād-u hniyye? ylaggṭin al-ḥunṭa yom-in yiǧin ʕal abu ʕamāye, abū ʕamāye, ism-u köstebek b-at-turuk.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a30"
                TIME_SLOT_REF1="ts59" TIME_SLOT_REF2="ts60">
                <ANNOTATION_VALUE>yḥuṭṭ al-ḥunṭa ǧawwa l-gāʕ, yḥuṭṭ al-ḥunṭa. w hāḏanne yiǧin bass yšūfin hīčiḏ yṣīr-l-u miṯil miṯil al-gabər haš-šakil ta-ngūl at-trāb ᵊhniyye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a31"
                TIME_SLOT_REF1="ts61" TIME_SLOT_REF2="ts62">
                <ANNOTATION_VALUE>yiǧin yfukkun yitku… baʕaḏ̣-hin yilgin ḥitt ḥayāye, ᵊbgaḷb al-ᵊhniyye hā, ᵊbgaḷb haḏīč, miṯil bēt yaʕni hā! bēt abu ʕamāye ygūlū-l-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a32"
                TIME_SLOT_REF1="ts63" TIME_SLOT_REF2="ts64">
                <ANNOTATION_VALUE>ta-ngūl, hīčiḏ ᵊtrāb kōm at-trāb,  tiǧi, tiǧi tugḏ̣ub l-abu ʕamāye, tiǧi tigḏ̣ub-u tfukk ᵊhnīt-u trāb-u, mū aǧ-ǧirdi, abu ʕamāye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a33"
                TIME_SLOT_REF1="ts65" TIME_SLOT_REF2="ts66">
                <ANNOTATION_VALUE>ᵊtfukk at-trāb w tgūm tuṭluʕ al-ᵊhniyye, abu ʕamāye, al-ǧaṛādīn ʕugub liḥǧan al-ǧaṛādīn liḥǧan alḥaz al-baladiyye gāmat tā ynaḏ̣ḏ̣fin aṭ-ṭabaqāt.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a34"
                TIME_SLOT_REF1="ts67" TIME_SLOT_REF2="ts68">
                <ANNOTATION_VALUE>aw ygūm ʕādēne tgūm tibḥaš, haḏanne l-ḥīwānāt kull-hin ᵊhniyye Ismāʕīn ysammūn benzeme ʕala baʕaḏ̣-hin, abu ʕamāye, w-aǧ-ǧirdi, w-al-ᵊhniyye. ši-ygūlūn haḏāk al-köstebek. haḏanne kull-hin yinṭin šabih ʕala baʕaḏ̣-hin</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a35"
                TIME_SLOT_REF1="ts69" TIME_SLOT_REF2="ts70">
                <ANNOTATION_VALUE>hā, ᵊtgūm ʕād tibḥaš al-ḥunṭa tgūl: aʕabbi al-malāt, ᵊtgūl: agušš ḥitt tgūl han-nōb b-al-ʕaṣa nōbāt axāf axāf yṣīr ḥayāye zād yiṣīrin ᵊbgaḷb al-qīrān.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a36"
                TIME_SLOT_REF1="ts71" TIME_SLOT_REF2="ts72">
                <ANNOTATION_VALUE>aʕabbi malāt al-ʕalīǧe w aǧīb ʕād ʕa-l-bēt, ᵊtgūl hinne ḥunṭut-hin hinne zād yrūḥin ʕa-l-ʕamme, kaynanası yaʕni hā, mart ta-ngūl ʕammit-he yaʕni umm raǧil-he.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a37"
                TIME_SLOT_REF1="ts73" TIME_SLOT_REF2="ts74">
                <ANNOTATION_VALUE>tgūl hī zād ᵊtrūḥ, w ḥamāt-he zād ᵊtrūḥ, hinne yirūḥin ᵊtgūl al yḥūšinn-u, yrūḥin yǧībinn-u ybīʕinn-u, yḥuṭṭun məṣārī-hin ᵊb-ǧēb-hin,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a38"
                TIME_SLOT_REF1="ts75" TIME_SLOT_REF2="ts76">
                <ANNOTATION_VALUE>al ybīʕinn-u hal-ḥunṭa, w-ᵊtgūl: w āni ḥunṭut-i yduggun-he, w yāklin-he b-al-bēt xubuz, ᵊtʕab-i yaʕni hā. ᵊtgūl mā_sāwi ḥiss-i.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a39"
                TIME_SLOT_REF1="ts77" TIME_SLOT_REF2="ts78">
                <ANNOTATION_VALUE>ᵊtgūl: az-zlime ʕamann-u zēn ʕalay-ye w-aštahī-´, huwwa yištahī-ni mā_sōlif.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a40"
                TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts80">
                <ANNOTATION_VALUE>ᵊtgūl:  arūḥ lugutt-i hinne yǧībin məṣārī-hin ylaggṭin yrūḥin ybīʕinn-u w yāxḏinn-u yḥuṭṭin ᵊb-ǧyūb-hin.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a41"
                TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts82">
                <ANNOTATION_VALUE>w-ᵊtgūl: w āni al-ḥunṭat al aǧīb-he, al asāwī-he hā, yiǧin yḥuṭṭin-he b-al-bēt  ygūmin yihnin-he, ydīrin-he b-ar-raḥā.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a42"
                TIME_SLOT_REF1="ts83" TIME_SLOT_REF2="ts84">
                <ANNOTATION_VALUE>w ysāwin-he ṭaḥīn yxabzin-he, ᵊtgūl: ī. yāklin-he b-al-bēt. ᵊtgūl: āni mā_sāwi ḥiss-i, ᵊtgūl w ḏ̣allēt hīčiḏ sabʕ ᵊsnīn.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a43"
                TIME_SLOT_REF1="ts85" TIME_SLOT_REF2="ts86">
                <ANNOTATION_VALUE>ᵊtgūl: w hāḏi tmūt minn-i, mart axū-y. hiyye ʕād ṣāyrat-il-he awwal fāl awwal šī ṣāyr-il-he wlēd, ᵊhniyye wlēd w bnayye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a44"
                TIME_SLOT_REF1="ts87" TIME_SLOT_REF2="ts88">
                <ANNOTATION_VALUE>wlēdēn w bnayye awwal šī ṣāyrī-l-he yaʕni, wakt-in umm-i ṭāmḥe, umm-i ʕād az-zlime ṣāyb-u šeker hastaləgə, awwali aš-šeker hastaləgə mā-l-u čāra, mū miṯil alḥaz. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a45"
                TIME_SLOT_REF1="ts89" TIME_SLOT_REF2="ts90">
                <ANNOTATION_VALUE>bass yišrab mayye, ᵊtgūl: l-aṣ-ṣubḥiyye malāt at-tnike yišrab mayye. ᵊtgūl: aǧīb-ill-u han-nōba tgūl ybūl.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a46"
                TIME_SLOT_REF1="ts91" TIME_SLOT_REF2="ts92">
                <ANNOTATION_VALUE>ᵊtgūl mū yišrab al-mayye  ᵊtgūl öyle ybūl miṯil al-ʕaṣīd, ᵊtgūl gāylit-il-he umm-i.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a47"
                TIME_SLOT_REF1="ts93" TIME_SLOT_REF2="ts94">
                <ANNOTATION_VALUE>yā wlēd-i iḥfir hīčiḏ ḥafīre! tā yḏ̣all ybūl bī-he w dummī-he, awwali māmiš češmāt, uxṛa raddēt ʕa-č-češme.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a48"
                TIME_SLOT_REF1="ts95" TIME_SLOT_REF2="ts96">
                <ANNOTATION_VALUE>māmin češmāt awwali, tḥafir b-al-gāʕ tḥafir ᵊtḥafir w yiǧi az-zlime yḏ̣all ybūl l-aṣ-ṣubuḥ,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a49"
                TIME_SLOT_REF1="ts97" TIME_SLOT_REF2="ts98">
                <ANNOTATION_VALUE>ᵊtgūl al aǧīb-he at-tnike yxaḷəṣ-ha, yimli aǧ-ǧafər ḏāk al ybūl, m-aš-šakar. w tgūl w-aqaṭṭī-´ ᵊtgūl ḏ̣all hīčiḏ sabʕ ᵊsnīn.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a50"
                TIME_SLOT_REF1="ts99" TIME_SLOT_REF2="ts100">
                <ANNOTATION_VALUE>tgūl w ta-ngūl mū hniyye kull-u sabʕ ᵊsnīn wuǧʕa yaʕni hā, arbaʕa xamsa snīn ṭayyib</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a51"
                TIME_SLOT_REF1="ts101" TIME_SLOT_REF2="ts102">
                <ANNOTATION_VALUE>ʕugub haḏannīč at tālyāt kull-hin waǧʕān, ā ᵊtgūl w ʕugub ʕādēn ᵊtgūl w ntikat ᵊtgūl w nahāṛ rəma rās-u w māt.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a52"
                TIME_SLOT_REF1="ts103" TIME_SLOT_REF2="ts104">
                <ANNOTATION_VALUE>wakt-inn-u māt ᵊtgūl hāḏi ʕādēne nahāṛ tgūl ʕād lissaʕ-u gabəḷ-ma ymūt. ᵊtgūl hāḏi gāyme w zaʕlāne.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a53"
                TIME_SLOT_REF1="ts105" TIME_SLOT_REF2="ts106">
                <ANNOTATION_VALUE>umm al-ʕaǧi hāḏa at taww-ni ǧīt min ʕind-u… min ʕirs-u hā, abu ʕiris hāḏa at taww ǧawwaz wlid-u, hāḏi ište umm-u, awwal fāl ᵊtgūl gāyme w zaʕlāne.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a54"
                TIME_SLOT_REF1="ts107" TIME_SLOT_REF2="ts108">
                <ANNOTATION_VALUE>zaʕlāne min xāḷ-i zaʕlāne min ḥabbābt-i mū ḏa ʕēl-u w qarabāləq. w gāyme umm-i zād… ama hāḏi tizʕal umm-i zād tizʕal.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a55"
                TIME_SLOT_REF1="ts109" TIME_SLOT_REF2="ts110">
                <ANNOTATION_VALUE>tiǧi trudd ʕal ahal-he kull-min ᵊtrūḥ ʕal ahal-he, gāyil: ʕalēš inti trīdīn ᵊtrūḥīn? raǧil-he gāyil hīčiḏ. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a56"
                TIME_SLOT_REF1="ts111" TIME_SLOT_REF2="ts112">
                <ANNOTATION_VALUE>gāyle: hā mā ššūf uxt-ak ziʕlat? alḥaz ā umm-i ddarrib ʕalay-ye āni gabəḷ-ma ddarrib ʕalay-ye arīd arūḥ. w gāyme umm-i zād rāyḥe.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a57"
                TIME_SLOT_REF1="ts113" TIME_SLOT_REF2="ts114">
                <ANNOTATION_VALUE>wakt-in rāyḥe mū maġdūrīn ḥawāli mā ʕid-hum šī? yrīd yrūḥūn awwali guṭun māmin iḥne hēne b-al-məṭāriḥ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a58"
                TIME_SLOT_REF1="ts115" TIME_SLOT_REF2="ts116">
                <ANNOTATION_VALUE>guṭun šī ta-ngūl yrūḥūn ʕal Ādane  tā yḥūšūn al-guṭun. w gāyme w mʕabbīn ummāʕīn-hum mʕabbīn umm-i zād rāčbe.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a59"
                TIME_SLOT_REF1="ts117" TIME_SLOT_REF2="ts118">
                <ANNOTATION_VALUE>b-al-makīne w xawāl-i rāčbīn yrīd yrūḥūn ʕal Ādane ʕ-al-guṭun. w hāḏa samʕān minhabil, rāǧil-he yaʕni hā.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a60"
                TIME_SLOT_REF1="ts119" TIME_SLOT_REF2="ts120">
                <ANNOTATION_VALUE>yrīd yāxḏūn mart-u, ygūl ygūm w yuktil uxt-u čatle, ygūl-il-he alle trīd trūḥīn ᵊbsāgit-hum inti ti-trūḥīn.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a61"
                TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts122">
                <ANNOTATION_VALUE>tā tiǧi mart-i w-inti rūḥi, yuktil-he yiksir ḏirr-he ʕād. yiksir ḏirr-he, ytisaggaṭ ʕād minn-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a62"
                TIME_SLOT_REF1="ts123" TIME_SLOT_REF2="ts124">
                <ANNOTATION_VALUE>min hāḏa ḏ̣allat lummun al-marḥūma  mātat, hīčiḏ timši ʕōǧe, mātat čünki huwwa kāsir ḏirr-he al-marḥūm.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a63"
                TIME_SLOT_REF1="ts125" TIME_SLOT_REF2="ts126">
                <ANNOTATION_VALUE>yaʕni gāyl-il-he ygūl-il-he imši rūḥi mā tṭīʕ-u mā trūḥ, šwayye ar… ᵊhniyye aḷḷa yirḥam-ha ʕarsīze, yaʕni ḥayāsīze mā tṭīʕ yaʕni hā</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a64"
                TIME_SLOT_REF1="ts127" TIME_SLOT_REF2="ts128">
                <ANNOTATION_VALUE>ygūmūn ʕādēne b-az-zōr ʕād yǧīb-he, w yḏ̣all ygūl ydaffiʕ bī-he ḏ̣āḷḷ m-al-ʕIlle l-Aqčaqala mdaffiʕ bī-he yuktil-he lummun mōṣil-he al-makīne. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a65"
                TIME_SLOT_REF1="ts129" TIME_SLOT_REF2="ts130">
                <ANNOTATION_VALUE>mirčib-he ʕād ʕid xawāl-i, gāyil mwaggif ʕād ahal al-makīne gāyil: igafu! ᵊmwaǧǧif ḏ̣āll yurkuḏ̣ūn yaʕni b-aṯar al-makīne. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a66"
                TIME_SLOT_REF1="ts131" TIME_SLOT_REF2="ts132">
                <ANNOTATION_VALUE>ᵊmwaǧǧif ʕād al-makīne ygūl hiyye w-irčib-he hiyye, w hāt umm-i w taʕāl, w rādd māxḏ umm-i w rādd ʕād. o kadar ki yaʕni yištahī-he mā yxallī-he tā trūḥ ᵊbsāgt ahal-he.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a67"
                TIME_SLOT_REF1="ts133" TIME_SLOT_REF2="ts134">
                <ANNOTATION_VALUE>aw ʕugub ʕād ḏ̣all, ḏ̣all, ḏ̣all  agul-l-ak w māt. ʕugub-ma māt ʕādēne gāmat ʕād hiyye hāḏi uxṛa raddat ʕal ahal-he.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a68"
                TIME_SLOT_REF1="ts135" TIME_SLOT_REF2="ts136">
                <ANNOTATION_VALUE>wakt-in raddat ʕal ahal-he ʕid-he ʕiǧyān hīčiḏ ṯalāṯe, gāyim ʕād ḥamā-ha umm-i ḥamā-ha wāḥad-in hīčiḏ,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a69"
                TIME_SLOT_REF1="ts137" TIME_SLOT_REF2="ts138">
                <ANNOTATION_VALUE>zād čirkin w zād axū-´ hāḏa haḏōle ixwa haḏōle, hīčiḏ aswad w rāʕi ʕyūn-in ᵊmṭaggagāt</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a70"
                TIME_SLOT_REF1="ts139" TIME_SLOT_REF2="ts140">
                <ANNOTATION_VALUE>āni ben āni zād ilḥišt-u yaʕni wakt-inn-u al-marḥūm ṭayyib, ism-u Furmān zād wakt-inn-u ṭayyib, ilḥišt-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a71"
                TIME_SLOT_REF1="ts141" TIME_SLOT_REF2="ts142">
                <ANNOTATION_VALUE>ā hā w gāyim ʕād yrīd umm-i huwwa, mū raǧil-he mayyit? gāyim yrīd-he tā yāxuḏ-he ʕala mart-u ḏ̣arra. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a72"
                TIME_SLOT_REF1="ts143" TIME_SLOT_REF2="ts144">
                <ANNOTATION_VALUE>umm-i gāyle: xalla d-rūḥ wal min hēne gəṭṭīʕe! awwali ǧarēt min-kum lummun-ma hlikit, āni mā ʕād, mā ʕād arīd tirčit-kum.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a73"
                TIME_SLOT_REF1="ts145" TIME_SLOT_REF2="ts146">
                <ANNOTATION_VALUE>umm-i ʕād zaʕlāne rāyḥe ʕal ahal-he, yaʕni ḏ̣ālla ʕinid ahal-he, w haḏīč ʕād gāymīn fākkīn-he,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a74"
                TIME_SLOT_REF1="ts147" TIME_SLOT_REF2="ts148">
                <ANNOTATION_VALUE>mənṭīn ʕād ḥabbābt-i rāyḥe bāyʕe ᵊbgarāt ʕid-hum w duwāb bāyʕit-hin w fākka ʕād al-ḥurma,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a75"
                TIME_SLOT_REF1="ts149" TIME_SLOT_REF2="ts150">
                <ANNOTATION_VALUE>yfukkūn-ha hāḏi yinṭūn badal, ʕaman hāḏi raǧīl-he māt yinṭūn badal miššān ᵊhnīt hā, al-bidīle haš-šakle, </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a76"
                TIME_SLOT_REF1="ts151" TIME_SLOT_REF2="ts152">
                <ANNOTATION_VALUE>al-bidīle ta-ngūl, </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a78"
                TIME_SLOT_REF1="ts154" TIME_SLOT_REF2="ts156">
                <ANNOTATION_VALUE>al-bidīle ta-ngūl ᵊhnīt-he alḥaz axušš al-qōniyye trīd ytibaddal amma.  </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
