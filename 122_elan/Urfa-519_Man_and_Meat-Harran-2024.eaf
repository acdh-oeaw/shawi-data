    <TIER LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Corpus:Harran02">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
                <ANNOTATION_VALUE>nahāṛ m-al-iyyāmāt Stefān xōǧa, rḥamit ǧiddo šēx Ḥasan gəṛābit-ne aḷḷa yirḥam-u čānaw ǧāʕdīn b-aǧ-ǧbile b-Fitte.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a2"
                TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>w ʕind-u zāriḥ zārʕēn ḥunṭa w ḥāṣdīn al-ḥunṭa w mkawwin al-bēdar b-aǧ-… ǧiddām al-bēt w di-yǧībūn yǧībūn al-ḥunṭa ʕa-l-midīne tā ybīʕūn-he.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3"
                TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>hā an-nōb awwali mā ʕid-hum wāṣtāt w mətōrāt w šī awwali, ʕamm-i Mḥimmad, Mḥimmad al-Bōzaw ʕind-u makīne qamyūn, </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a4"
                TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>w ḥāǧǧ ʕUmar, ḥāǧǧ ʕUmar al-Ḥasan walda xālt-u čirīf-i zād ʕind-u makīne, w mdarrib ʕalē-hum xabar gāyil: </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>taʕālu b-al-makīne tā tiǧūn ᵊššayylūn al-ḥunṭa w nāxuḏ-ha ʕa-l-midīne w nbīḥ-ḥe.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>rāyḥīn ʕa-l-makīne čirīf-i ḥāǧǧ ʕUmar, aḷḷa yirḥam-u, aw w huwwa māxiḏ ʕamm-i Mḥimmad ᵊbsāgt-u rāyḥīn ʕala Fitte. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>ygūl riḥna qādi ygūl w gimne, ad-dinya ḥāṛṛa ygūl māmiš ḥade.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a8"
                TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>ʕiǧyān ǧiddo šēx Ḥasan Ibrāhīm Edhem w Mḥimmad Ṣāliḥ az-zġār ygūl iḥne tišaččalne.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>l-al-ḥunṭa b-d-dibābi iḥne w Xanse w ḥabāyb-u w gimna nʕabbi b-ad-dibābi nʕabbi b-al-qamyūn, awwali hniyyāt māmiš helezōnāt māmiš.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a10"
                TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>ā ygūl w gəḏ̣abne čān nšayyil al-ḥunṭa aḏ̣-ḏ̣uhur al-ḥamra ad-dinya ḏ̣uhur ḥāṛṛa tiʕliǧ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>ygūl ʕala-ma ʕabbēne al-qamyūn ygūl ᵊnsəmaṭne min al-ḥāṛṛ ygūl lummun-ma ḥammalnā-ha ygūl w šaddēna čādir</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a12"
                TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>ygūl š-isim-ha Xanse ygūl gāmat čānat tiḏbaḥ-in-ne hniyye āāā xārūf, qade ha. ygūl w hiyye ǧaʕad ᵊtḥamṣ-in-ne al-xārūf ygūl w čān ᵊssāwī-´ w ǧǧīb-u </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a13"
                TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>ᵊddīr-in-ne al-ᵊhniyye gaʕadne ygūl qassalne īdē-ne w-ᵊwǧūḥ-ne ygūl gaʕadne b-ad-dār ygūl čān ᵊǧǧīb-in-ne ʕēš burqul w ḥamīṣit laḥam.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a14"
                TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>ygūl yā xayyo yōm-in rəmat-in-ne at-tibāsi at-tabsītēn ygūl ḥaṭṭat-in-ne al-laḥam ʕādēn ygūl ᵊtʕibne tā rrīd nākul.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a15"
                TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>ygūl iḥne gaʕadne lissaʕ as-sufra dārat, w gām ygūl ahal aǧ-ǧarye salāmu ʕalay-kum – ʕalē-kum salām, salāmu ʕalay-kum – ʕalē-kum salām!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a16"
                TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>win ygūl ad-dār milyāne xaməstaʕaš ᵊzlime. tss ī wēlād al-ḥalāl wakt aš-šuġul aṣṣōb čintu wakt al lummun dārat al…al-burqul w-al-laḥam tā ǧītu?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a17"
                TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts34">
                <ANNOTATION_VALUE>han-nōba ʕamm-i Mḥimmad hinne tabsītēn, gāyil il-ḥāǧǧ ʕUmar, ḥāǧǧ ʕUmar ǧāyīn arbaʕ yamm-u b-tabsīt-u gāyil ḥūd-l-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a18"
                TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>yōm-in gāyil ḥūd-l-u! ḥāǧǧ ʕUmar ydīr at-tabsiyye yugḏ̣ub, till at-tabsiyye ǧiddām-ak w gāyim yšīl m-al-laḥam w yḥuṭṭ ǧawwa al-burqul w yqabbi l-laḥam </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a19"
                TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>w ykawwim al-laḥam ǧiddām-u w yākul, yluxx al-laḥam ʕala iṯm-u w yirmī-´ ǧiddām-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a20"
                TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
                <ANNOTATION_VALUE>xayyo al-xamse sitte mā... tabsīt ḥāǧǧ ʕUmar mā wāḥad lā ʕaḏ̣əm wāǧiʕ b-īd-u gəṭʕat laḥam w mū wāǧiʕ b-īd-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a21"
                TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts42">
                <ANNOTATION_VALUE>ygūl ᵊrḥamit šēx Ḥasan ygūl ydaḥḥiǧ hīčiḏ gāyim yiḏ̣ḥak. wal gāyil intu šiyāṭīn wal iš-sāwētu? wal ḥarām az-zlime mā xallētu wāḥad wal yḏūg al-ᵊhniyye. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a22"
                TIME_SLOT_REF1="ts43" TIME_SLOT_REF2="ts44">
                <ANNOTATION_VALUE>gāyil ḥāǧǧ ʕUmar hāḏe wakit al… ᵊtʕibbi l-ḥunṭa māmiš w taww wakt ᵊtʕibbi l-laḥam ǧō-ni? āni waḷḷa falle axalli wāḥad yākul gəṭʕat laḥam.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a23"
                TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts46">
                <ANNOTATION_VALUE>w xayyo gāyim gāyim ḥāǧǧ ʕUmar at-tabsiyye kull-he māčil-he min ǧiddām-hum, mū mxalli wāḥad ymidd īd-u ʕala gəṭʕa w māčil-he kull-he ygūl han-nōba staḥaw.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a24"
                TIME_SLOT_REF1="ts47" TIME_SLOT_REF2="ts48">
                <ANNOTATION_VALUE>w gāmaw ydaḥḥǧūn az-zilumʕala wǧūh baʕaḏ̣-hum, wal gāylīn hāḏa šinu min ādami? āfe wal ʕafrīt wal?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a25"
                TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts50">
                <ANNOTATION_VALUE>mā xallā-ne nḏūg ṭʕama mā xallā-na nḏūg ᵊlḥame wal</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a26"
                TIME_SLOT_REF1="ts51" TIME_SLOT_REF2="ts52">
                <ANNOTATION_VALUE>w ǧiddo šēx Ḥasan aḷḷa yirḥam-u gāyim yiḏ̣ḥak hehehe wal gāyil yā wal iš-sāwēt-u? walu, mā xallēt-u l-xuṭṭār yḏūgūn aṭ-ṭʕama . w salāmt-ak w-al-ʕāfye xōǧam.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
