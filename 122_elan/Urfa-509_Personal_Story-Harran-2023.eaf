                TIME_SLOT_REF1="ts51" TIME_SLOT_REF2="ts52">
                <ANNOTATION_VALUE>čabš ēš ḥāl ēš? gāl: arīd arūḥ adawwir čabiš. tārī-´ huwwa tā yiǧi ʕala… ʕala Qōrān tā yǧīb al-ᵊwlēd, daḥḥiǧ!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
