                TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts33">
                <ANNOTATION_VALUE>arīd amuṛṛ ʕala xālt-i Hāǧir hēne. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a18"
                TIME_SLOT_REF1="ts34" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>ʕala Abu Šrāg balči ḥade inn-i ywaddī-ni.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a19"
                TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>ḏāk az-zimān demek bēnāt-hum warwaṭa ʕād ʕala… ʕala… ʕala bint ʕUbēd al-Mazzāni. ǧāʕde ʕid-hum lissaʕ gaʕadit mā gaʕadit winn-u abū-ye w ʕamm-i Barhaw. zīīīrṭ w ʕid-hum, ǧīb. […]</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a20"
                TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
                <ANNOTATION_VALUE>yōm-inn-u ǧīʸ inn-i ǧāʕde āni… ṭaṛṛad-ič wald al-Bāgiyye anīč xarg umm-u! čān ygūm w-yāxuḏ-ni ᵊb-sāgt-u w riḥit. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a21"
                TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts42">
                <ANNOTATION_VALUE>ḏ̣aḷḷēt ḥirwit as-sitt sabiʕ tiyyām ʕašir tiyyām wlid-i b-al-bēt. hēne ḏ̣aḷḷ ʕind-u, w-Ǧammūl-i w Miččiy-ye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a22"
                TIME_SLOT_REF1="ts43" TIME_SLOT_REF2="ts44">
                <ANNOTATION_VALUE>ᵊrḥamit ǧidd-i Aḥmad yistaḥīṭ, mā yigbal. waḷḷa, čān yiǧīb ač-čaḥaš w yḥuṭṭ al… al-bardaʕa fōg w-yirkab. aṣṣōb? gāl-ill-u, trīd ᵊtrūḥ? </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
