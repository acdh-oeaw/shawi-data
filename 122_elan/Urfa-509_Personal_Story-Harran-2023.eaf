        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a15"
                TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>čān arkab ad-darib w-arūḥ. riḥit ma-bēn Zinnār w waḷḷa w Abu aš-Šrāq. yā wal w činit mā_ǧārib, ad-dinye ḏ̣uhur. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
