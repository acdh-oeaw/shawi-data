    <TIER LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Corpus:Harran26">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
                <ANNOTATION_VALUE>w rāčib b-al-makīne winn-u ǧāy at-taxam. humma ḥayyaraw ʕalē-he. w raddadaw gayyāt-u w ǧaw ʕid-ne bayyāte. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3"
                TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>ʕid-ne bayyāte, ǧiddām-na ʕarabāne ǧišš w čān afarrš-il-hum. ᵊb-ʕarabānt ᵊhnīt aǧ-ǧišš b-al-gāʕ w nāmaw: šēx ʕĪse. ᵊrḥamt Amūne, al-Xalīl, w Aḥmad. w Maḥmūd w Mḥimmad.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a4"
                TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>waḷḷa ǧī aṣ-ṣubḥ hinne… winn ᵊmsaṭṭaḥa al-ʕālam ʕind-u b-al-bēt, ǧāʕde ᵊrḥamit ḥabbābt-i Zalxa zād ʕād ᵊgʕadat ʕid-ne. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>winn-u ygūl: waḷḷa hāḏa mū ōtēl ʕAli Manǧe ī waḷḷa. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>ī uṭulʕu yaḷḷa gūmu! yaḷḷa gūmu. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts16" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>ī, āni ǧītū-ni ʕala Maḥāwi w ṭaṛṛadtū-ni. āni zād ǧāyīn-ni b-bēt-i yaḷḷa rūḥu yaḷḷa!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a10"
                TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>xayye gāmaw w rāḥaw ʕala gōm al-Hlayyil ḏāk az-zimān, rāḥaw ʕa-ǧ-ǧarye. yā wāl ʕalē ṭaṛṛadit-hum? čān nitikāwan āni w huwwa. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a12"
                TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>tikāwanne, ᵊḤmē-ne yirḏ̣aʕ. ᵊzġayyir luwwa sine timām mū timām. čān yugḏ̣ub w yāxuḏ ᵊḤmē minn-i zād w yṭaṛṛid-ni. yaḷḷa! gāl. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a14"
