        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a92"
                TIME_SLOT_REF1="ts183" TIME_SLOT_REF2="ts184">
                <ANNOTATION_VALUE>mḥayyara ʕala nām bini ʕiǧil, gālaw, w-al-gayyāt ḏanne mā yruddin, gāl-l-u ʕād ᵊrḥamit ᵊŠēx Ismāʕīn: xamse bāwalit-hum damm w-inta s-sātt, bass yruddin al-gayyāt, haḏanne mā ʕād yiruddin.</ANNOTATION_VALUE>
