                <ANNOTATION_VALUE>gāyil: maʕnāt-hin b-al-lēl ᵊštaġalit w-al-ʕālam xaḏat-hin. āni ṣāran-l-i banāt, ṣāran-l-i banāt. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a72"
                TIME_SLOT_REF1="ts143" TIME_SLOT_REF2="ts144">
                <ANNOTATION_VALUE>w al-banāt rabbēt-hin w-inṭēt-hin l-al-ʕālam alḥīn ǧaʕad al-ʕālam yinfaʕin al-ʕālam āni mā yinfaʕan-ni uxṛa ḏ̣allēt wḥad-i.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a73"
                TIME_SLOT_REF1="ts145" TIME_SLOT_REF2="ts146">
