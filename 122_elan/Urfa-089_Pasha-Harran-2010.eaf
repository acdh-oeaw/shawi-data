                TIME_SLOT_REF1="ts91" TIME_SLOT_REF2="ts92">
                <ANNOTATION_VALUE>hā, il-bāčir. il-bāčir anṭī-k muhle, w rūḥ inte ilig yaʕni inte tǧīb-l-i ǧ-ǧawāb!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a48"
