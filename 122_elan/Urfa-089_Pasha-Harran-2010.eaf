                <ANNOTATION_VALUE>w sitt tušhur, gāyil: as-sitte yōm-in gāḷ-ak as-sitte gbāl-hin sitte yaʕni maʕnāt-hin sittāt?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a65"
