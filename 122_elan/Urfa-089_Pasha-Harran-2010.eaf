            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a74"
                TIME_SLOT_REF1="ts147" TIME_SLOT_REF2="ts148">
                <ANNOTATION_VALUE>ᵊštaġalit b-al-lēl l-al-banāt w-ənṭēt-hin l-al-ʕālam. ā w gāyil: tamām!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a75"
                TIME_SLOT_REF1="ts149" TIME_SLOT_REF2="ts150">
                <ANNOTATION_VALUE>yōm-in ʕād gāyil tamām, rādd-l-u ʕād aš-šāyib gāyil-l-u: mū ḏ̣allat wəḥdit-in nōba. al-bāše yōm-in rāḥ min hēne, gāḷ: bāše adarrib-l-ak qāze təmʕaṭ-ha!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a76"
                TIME_SLOT_REF1="ts151" TIME_SLOT_REF2="ts152">
                <ANNOTATION_VALUE>gāyil: haḏīč mā_ʕari… haḏīč mā_rīd-he, āni ʕrifit-he. al-qāze āni tā uxṛa mā ʕād arīd. haḏīč ʕrəfit-he.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a77"
                TIME_SLOT_REF1="ts153" TIME_SLOT_REF2="ts154">
                <ANNOTATION_VALUE>al-qāze āni laʕād maʕaṭ yāzi mā ḏ̣all ḏahab mā ḏ̣all. kaz kalmadı para kalmadı, yaʕni flūs mā ḏ̣allan.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
