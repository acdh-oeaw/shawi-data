                <ANNOTATION_VALUE>al-wazīr wāǧif wāǧif gāyil: d-arūḥ waḷḷa, asʕal al-bāše. ǧāy ʕa-l-bāše sāʕl-u gāyl-l-u: yā bāšt-i! </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a41"
                TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts82">
                <ANNOTATION_VALUE>arīd asʕal-ak bass lā yaʕni… lā tʔāxiḏ-ni! lā tuʔāxiḏ-ni! lā tuʔāxiḏ-ni! inte w-aš-šāyib hāḏa, aš-šāyib ḏe tʕarfūn baʕaḏ̣-kum?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a42"
                TIME_SLOT_REF1="ts83" TIME_SLOT_REF2="ts84">
                <ANNOTATION_VALUE>ǟǟǟ, ᵊšnōn yaʕni yʕarif-ak? aš-šāyib ḏe šnōn ʕrif-ak? as-suwālif al bēnāt-kum aṣ ṣāran šinhin? šinhu maʕnit-hin?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a43"
                TIME_SLOT_REF1="ts85" TIME_SLOT_REF2="ts86">
                <ANNOTATION_VALUE>gāyil-l-u: suwālf al… inte minte, māni msāwī-k wazīr-i? minte ʕagəl rāḥ ṣāḥib ʕagəl? ʕind-inn-ak bī-k ʕagəl w sāwēt-ak wazīr-i, rūḥ ʕa-š-šāyib w-inte rūḥ ʕalē-´!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a44"
