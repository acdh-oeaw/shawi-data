        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a49"
                TIME_SLOT_REF1="ts97" TIME_SLOT_REF2="ts98">
                <ANNOTATION_VALUE>al-wazīr ǧāy gāyim ydōšin. wal, gāyil hāḏa: aṣṣōb arūḥ yā rabb-i? aṣṣōb arūḥ? aṣṣōb arūḥ? gāḏ̣ib w rāyiḥ ʕa-š-šāyib.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a50"
