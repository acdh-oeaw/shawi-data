                <ANNOTATION_VALUE>aštaġil zād asāwi čifčiliq zirāʕa, tā ykaffin aṯnēn w ṯalāṯīn.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a67"
                TIME_SLOT_REF1="ts133" TIME_SLOT_REF2="ts134">
                <ANNOTATION_VALUE>gāyil: aṯnēn w ṯalāṯīn šinhin? gāyil: ǧīb uxṛa ḏahab! uxṛa minṭī-´ ta-ngūl čīs aḏ-ḏahab.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a68"
                TIME_SLOT_REF1="ts135" TIME_SLOT_REF2="ts136">
                <ANNOTATION_VALUE>gāyil: aṯnēn w ṯalāṯīn zād as-sitte gbāl-hin sitte, ništaġil ṣaġlam aṯnēn w ṯalāṯīn as-snūn haḏanne yišbaʕin, yduggun, yāklin.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a69"
                TIME_SLOT_REF1="ts137" TIME_SLOT_REF2="ts138">
                <ANNOTATION_VALUE>aṯnēn w ṯalāṯīn yṣīrin zēnāt, yaʕni yišbaʕin ṣaġlam yištaġlin nšaġġil aṯnēn w ṯalāṯīn. in mā ṣāran sitte ᵊgbāḷ-hin sitte tā yṣīrin aṯnēn w ṯalāṯīn, yišbaʕin. aṯnēn w ṯalāṯīn, tā ykaffin.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a70"
                TIME_SLOT_REF1="ts139" TIME_SLOT_REF2="ts140">
                <ANNOTATION_VALUE>gāyil: peki! w gāḷ-l-ak b-al-lēl, w gāḷ-l-ak al-bāše gāḷ-l-ak b-al-lēl gilt āni b-al-lēl ᵊštaġalit, w-al-ʕālam xaḏat-he, ta-ngūl ᵊštaġalit l-al-ʕālam.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a71"
