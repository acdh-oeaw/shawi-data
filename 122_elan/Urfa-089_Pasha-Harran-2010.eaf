    <TIER LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Corpus:Harran02">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
                <ANNOTATION_VALUE>nahāṛ m-al-ayyām, hāḏi xərāfa ʕala-l… ʕala wāḥad awwali al-bāše. al-bāše, yōm-in yiṭluʕ ʕa-s-sūg ydawwir ahālīy-u millt-u, </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a2"
                TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>ǟǟǟ, at-Turuk ysammūn-ha tabdīl al-qiyāfāt ygūlūn, yaʕni ǟǟǟ ybadddil ᵊhdūm-u, ybadddil ᵊhdūm-u, al-bāše.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3"
                TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>w yōm-in ybadddil ᵊhdūm-u yiṭluʕ ʕal… ʕa-s-sūg, ydawwir as-sūg, ydawwir sūg-u millt-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a4"
                TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>minṭi xabar il-wazīr-u gāyl-l-u: bāčir arīd aṭluʕ ʕa-s-sūg adawwir. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>yōm-inn-u minṭi xabar wazīr-u, wazīr-u ṭāliʕ gabḷ-u ʕa-s-sūg yrūḥ yʕallim as-sūg, al-mille.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>yaʕni millt-u gabəḷ-ma yuṭluʕ al-bāše, yʕallim-hum ygūl-il-hum: bāčir arīd arūḥ ʕa-s-sūg, al… bāčir al-bāše yrīd yiǧi ydawwir-kum yzūr-kum, yaʕni ydawwir as-sūg.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>neyse, al-bāše yiṭluʕ ṭāliʕ ʕa-s-sūg ᵊmdawwir as-sūg kullši min gōlāt at-turuk yōm-in ygūlūn asayiş ber Kemal yaʕni. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a8"
                TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>māmiš šī, al-wazīr mū mʕallim-hum yā! al-bāše yiǧi kull-he yʕarfūn-u: ahlēn b-al-bāše! ahlēn b-al-bāše! mūhu yaʕni māmiš ṣōrun, rādd. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>yōm-inn-u rādd al-bāše ṯāni nahāṛ uxṛa ṭāliʕ ʕa-tabdīl al-qiyāfāt ṯāni nahāṛ, ʕayne ḏāk an-nahāṛ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a10"
                TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>b-ar-radde, ē, yōm-inn-u ǧāy yrudd ʕa-d-darib, āāā, šāyif ʕa-d-darib wāḥad šāyib. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>ʕa-d-darib šāyfīn wāḥad šāyib mārr ʕalē-´ al-pādišāh minṭī-´ salām, salāmu ʕalē-kum, ʕalē-kum as-salām! ǧāʕdīn.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a12"
                TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>al… al-bāše: ḥāl kēf ᵊšnōn-ak? ᵊšnōn? ṭayyib? ʕadil? yisʕal aš-šāyib ygūl-l-u: zēn, alḥamdilla!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a13"
                TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>w aš-šāyib ysāwi hniyye, āāā huwwa ysāwi sxam der… ǧlūd, ᵊb-aǧ-ǧlūd, ysāwi hniyye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a14"
                TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>yqassil ᵊǧlūd, yqassil ᵊǧlūd.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a16"
                TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>yōm-inn-u yqassil ᵊǧlūd, al-pādišāh saʕal-u, āāā gāyil-l-u: ᵊšnōn as-sitte, as-sitte tištaġil ysāwi ǧlūd b-as-sitte. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a17"
                TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts34">
                <ANNOTATION_VALUE>as-sitte al-uxriyyāt ši-ssāwi bī-hin? ᵊšnōn as-sitte? </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a18"
                TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>ᵊšnōn as-sitte? yaʕni ysōlf-u maʕnawiyyāt, ᵊšnōn as-sitt, as-sitte?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a20"
                TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
                <ANNOTATION_VALUE>waḷḷa, gāyil: as-sitte al mā ṣāran as-sittit al-uxriyyāt, mā aṯnēne w ṯalāṯīn mā yṣīrin mā yištaġlin mā yāzin aṯnēn w ṯalāṯīn.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a21"
                TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts42">
                <ANNOTATION_VALUE>as-sittit al-uxriyyāt in mā ṣāran mā yāzin aṯnēne w ṯalāṯīn, aṯnēne w ṯalāṯīn.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a22"
                TIME_SLOT_REF1="ts43" TIME_SLOT_REF2="ts44">
                <ANNOTATION_VALUE>yōm-inn-u sāʕl-u uxṛa wəḥdit-in nōba, gāyil-l-u: ʕaǧal b-al-lēl ši-ssāwi? b-al-lēl ši-ssāwi? ī gāyil: b-al-lēl āni mā_sāwi šīʸ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a23"
                TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts46">
                <ANNOTATION_VALUE>mā_sāwi šī, mā_sāwi šī. as sāwēt-he b-al-lēl āāā āni ᵊštaġalit w-al-ʕālam xaḏat-he yaʕni ta-ngūl. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a24"
                TIME_SLOT_REF1="ts47" TIME_SLOT_REF2="ts48">
                <ANNOTATION_VALUE>al āni štaġalit w-al-ʕālam xaḏat-he b-al-lēl aštaġil ᵊštaġalit awwali. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a25"
                TIME_SLOT_REF1="ts51" TIME_SLOT_REF2="ts52">
                <ANNOTATION_VALUE>b-al-lēl aštaġil w-ᵊnfaʕat al-ʕālam. ᵊštaġalit b-al-lēl w-ᵊnfaʕat al-ʕālam.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a27"
