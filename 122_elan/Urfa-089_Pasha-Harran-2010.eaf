        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a52"
                TIME_SLOT_REF1="ts103" TIME_SLOT_REF2="ts104">
                <ANNOTATION_VALUE>āni wazīr al-bāše, albāriḥ gāyil yōm-in ǧīnā-k āni w-al-bāše. ᵊšgadd ᵊtrīd? āni, yrīd ysitt-ni m-al-wuzara. daxīl ʕalē-k yrīd ysitt-ni.</ANNOTATION_VALUE>
