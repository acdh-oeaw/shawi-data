        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a30"
                TIME_SLOT_REF1="ts58" TIME_SLOT_REF2="ts60">
                <ANNOTATION_VALUE>an-nās yrūḥūn ʕa-č-čwāl, yrūḥūn ysāwūn iḥtiyāǧ-hum.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a31"
                TIME_SLOT_REF1="ts61" TIME_SLOT_REF2="ts62">
                <ANNOTATION_VALUE>amma šinu min iḥtiyāǧ yaʕni? yaʕni mū rāḥa mū b-rāḥa mesela.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a32"
                TIME_SLOT_REF1="ts63" TIME_SLOT_REF2="ts64">
                <ANNOTATION_VALUE>ahal al-gaṛāye li-lbāriḥ lissa ahal al-gaṛāya ʕa-č-čōl, mā ʕid-hum ᵊhniyyāt. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a34"
                TIME_SLOT_REF1="ts67" TIME_SLOT_REF2="ts69">
                <ANNOTATION_VALUE>mā ʕid-hum tuwālētāt tā ti-yrūḥūn b-ač-čōl.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a36"
                TIME_SLOT_REF1="ts70" TIME_SLOT_REF2="ts72">
                <ANNOTATION_VALUE>miṯil čān ygūl awwaliyye čān ṭəlaʕ filim Šener Šen, ygūl ᵊhniyye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a37"
                TIME_SLOT_REF1="ts73" TIME_SLOT_REF2="ts74">
                <ANNOTATION_VALUE>gām Šener Šaʕbān rāḥ ʕa… ʕa-l-bilid yaʕni awwali, rāḥ ʕa-l-bilid tā yištaqil w šāf hināk ač-češmāt, rāḥ miššān daḥḥag in-he l-bāšləq gāyim. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a38"
                TIME_SLOT_REF1="ts75" TIME_SLOT_REF2="ts76">
                <ANNOTATION_VALUE>māxḏīn yāxḏūn al-ḥarīm balāy ᵊhniyye istediği gibi yani severek alırlar yištihūn-hin yāxḏūn-hin.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a39"
                TIME_SLOT_REF1="ts77" TIME_SLOT_REF2="ts78">
                <ANNOTATION_VALUE>huwwa rāḥ tā ylimm ḥagg al-ᵊhniyye ḥagg as-siyāg. wakt-inn-u radd min qādi ǧī gāḷ ad-arūḥ ʕala ahal ǧaryit-i.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a40"
                TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts80">
                <ANNOTATION_VALUE>hināk šī češmāt, ᵊmsāwīn daḥḥiǧ ᵊšnōn iš-mi zēne! češmāt iš-mi zēne!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a41"
                TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts82">
                <ANNOTATION_VALUE>al-ḥurma yāxḏūn-he al yištihi-he yāxuḏ-he, iḥne ʕalēš al-ᵊhniyye hāḏi mā ʕid-ne? </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a42"
                TIME_SLOT_REF1="ts83" TIME_SLOT_REF2="ts84">
                <ANNOTATION_VALUE>hā tā yʕallim ahal al-ǧarye ʕa-l-aqa ʕād b-aǧ-ǧarye haḏāk al-āqa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a43"
                TIME_SLOT_REF1="ts85" TIME_SLOT_REF2="ts86">
                <ANNOTATION_VALUE>haḏāk ʕād radd w ygūl ᵊhniyye, gāl čān ygūm yḥafr-ill-u češme b-al-məṣāri tā ylimm məṣāri s-syāg.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a44"
                TIME_SLOT_REF1="ts87" TIME_SLOT_REF2="ts88">
                <ANNOTATION_VALUE>w yḥafir ač-češme w yḥuṭṭ ʕalē-he bala ǧāfye qār ᵊtnike šakli, w sakkar ʕalē-´ al-bāb w yǧūn ʕād yxuššūn,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a45"
                TIME_SLOT_REF1="ts89" TIME_SLOT_REF2="ts90">
                <ANNOTATION_VALUE>al ysāwi marak ʕād ahal aǧ-ǧarye, šinhi hāḏi? ygūl: hāḏi yüz nimre.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a46"
                TIME_SLOT_REF1="ts91" TIME_SLOT_REF2="ts92">
                <ANNOTATION_VALUE>yǧūn ʕād tā yxuššūn ᵊbgaḷəb-ha, en ṣōn ǧīy al-aqa. ǧīy čān yiktib ağaya beleş, kitab.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a47"
                TIME_SLOT_REF1="ts93" TIME_SLOT_REF2="ts94">
                <ANNOTATION_VALUE>maxṣūs tā al-aqa mā yizʕal ʕalē-´ mū aǧ-ǧarye tinḥasib l-al-aqa yā?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a48"
                TIME_SLOT_REF1="ts95" TIME_SLOT_REF2="ts96">
                <ANNOTATION_VALUE>čān yḥawwil al-aqa gāḷ: šinhu wal hāḏi? gāḷ: ǧibit waḷḷa hniyye sāwēt tuwālet.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a49"
                TIME_SLOT_REF1="ts97" TIME_SLOT_REF2="ts98">
                <ANNOTATION_VALUE>aġam, āni riḥit ʕ-ač-čōl riḥit ʕa-l-bilid, w šinhi daḥḥiǧ iš-mi zēne msāwīn ᵊhniyye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a50"
                TIME_SLOT_REF1="ts99" TIME_SLOT_REF2="ts100">
                <ANNOTATION_VALUE>tuwālēt hāḏi w yüz nimre w čān ygūm gāḷ: šinu bgaḷəb-ha? wāḥad hāḏe, wāḥad ydarrib wāḥad.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a51"
                TIME_SLOT_REF1="ts101" TIME_SLOT_REF2="ts102">
                <ANNOTATION_VALUE>gāḷ: waḷḷa hīčiḏ šī qār hahahaha, içinde ne var? gāḷ, gāḷ: ne var ulan? mā ʕallam mā ʕallam.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a52"
                TIME_SLOT_REF1="ts103" TIME_SLOT_REF2="ts104">
                <ANNOTATION_VALUE>w čān yuḏ̣rub al-ʕaǧi ʕād ʕala rās-u, ḏ̣urab al-ʕaǧi ʕala rās-u,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a53"
                TIME_SLOT_REF1="ts105" TIME_SLOT_REF2="ts106">
                <ANNOTATION_VALUE>ʕugub ʕād gāḷ: wald al-kalib! gāḷ, gāḷ Šaʕbān hāḏa wald al-kalib. gāḷ: ᵊhniyye fōg xaṛa al-aqa yṣīr xaṛa? </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a54"
                TIME_SLOT_REF1="ts107" TIME_SLOT_REF2="ts108">
                <ANNOTATION_VALUE>yaʕni inte ʕazab ti-trūḥ āni inte txara w-āni zād aqa aǧi fōg-ak agʕud? āni mā_gʕud, gāḷ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a55"
                TIME_SLOT_REF1="ts109" TIME_SLOT_REF2="ts110">
                <ANNOTATION_VALUE>ā iḥne ʕādēn hēne onun temsili, iḥne hēne b-Urfa gāmaw ʕādēne n-nās ta-ngūl ᵊrḥamt abū-ye gām yḥafir yüz nimre.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a56"
                TIME_SLOT_REF1="ts111" TIME_SLOT_REF2="ts112">
                <ANNOTATION_VALUE>arbaʕ mitrawāt ᵊṭlaʕat al-mayye, daḥḥiǧ al-ḥōš min hēne al-mayye arbaʕṭaʕaš ṣəfā ṭləʕat mā ṭləʕat?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a57"
                TIME_SLOT_REF1="ts113" TIME_SLOT_REF2="ts114">
                <ANNOTATION_VALUE>al-kōše ḏīč čān ysāwi bī-he češme ṭləʕat al-mayye hināk.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a58"
                TIME_SLOT_REF1="ts115" TIME_SLOT_REF2="ts116">
                <ANNOTATION_VALUE>mā xallā-ha mū ḏīč sāwa češme ḏ̣allat ʕād, w ḏ̣all al-ḥōš yābis w ʕugub səḥab m-aš-šabaka mayye, w ḏ̣all ḏ̣all ḏ̣all haš-šakle.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a59"
                TIME_SLOT_REF1="ts117" TIME_SLOT_REF2="ts118">
                <ANNOTATION_VALUE>w-al-bīr ʕādēne tigaʕ ʕa-l-ḥaywāne at tiǧi at tiǧi, axāf al-ḥōliyye lā tigaʕ ᵊbgaḷəb-ha. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a60"
                TIME_SLOT_REF1="ts119" TIME_SLOT_REF2="ts120">
                <ANNOTATION_VALUE>sāwa bass ᵊhnīt-u ʕurḏ̣-u hāḏa b-gadd ᵊgʕadit-na iḥne ḏiyye, yaʕni ᵊswāṛ-u hā, ᵊb-gadd ᵊgʕadit-ne alḥaz al-bīr.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a61"
                TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts122">
                <ANNOTATION_VALUE>yṣīr hīčiḏ ysāwūn baʕaḏ̣-hum ysāwūn-u b-gadd at-tapsiyye, aẓġar m-at-tapsiyye hāḏa min-gadd az-zlime mū ʕamann-u miššān aṣ-ṣəfā miššān al-ᵊhniyye,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a62"
                TIME_SLOT_REF1="ts123" TIME_SLOT_REF2="ts124">
                <ANNOTATION_VALUE>ṣār haš-šakle miṯil as-sahrīǧ, čibīr ta-ngūl iṯum, iṯum al-bāb al-ᵊhniyye hā. han-nōb mū arbaʕṭaʕaš mitraw?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a63"
                TIME_SLOT_REF1="ts125" TIME_SLOT_REF2="ts126">
                <ANNOTATION_VALUE>ad-diǧāǧe tigaʕ ᵊbgaḷb-u w nxāf al-ḥōliyye tigaʕ ᵊbgaḷb-u, axāf kull-u mitqayytīn al-ʕaǧi aẓ-ẓġīr al yrūḥ waṛa d-dūr.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a64"
                TIME_SLOT_REF1="ts127" TIME_SLOT_REF2="ts129">
                <ANNOTATION_VALUE>wāli urkuḏ̣i waṛa ʕid-ne bīr hā! lā yrūḥ yigaʕ b-al-bīr kull-u lā yigaḥ b-al-bīr. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a66"
                TIME_SLOT_REF1="ts130" TIME_SLOT_REF2="ts132">
                <ANNOTATION_VALUE>ā minhu yrūḥ yǧīb ṣāč w-ᵊhniyye yrīd yǧīb ṣāč, ḥitta ṣ-ṣāč čöker.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a67"
                TIME_SLOT_REF1="ts133" TIME_SLOT_REF2="ts134">
                <ANNOTATION_VALUE>aṣ-ṣāč mā yugḏ̣ub hāḏa yrīd-ill-u šīt-in öyle bir kuvvetli bir hniyye lazım b-gadd ad-dār ḏiyye ḥadīde w tḥuṭṭīn-he b-gadd al-xāliyye ḏiyye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a68"
                TIME_SLOT_REF1="ts135" TIME_SLOT_REF2="ts136">
                <ANNOTATION_VALUE>tḥuṭṭīn-he ʕalē-´ tā yugḏ̣ub-ha lōn tḥuṭṭīn aṣ-ṣāč zād min qādi yxafiṣ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a69"
                TIME_SLOT_REF1="ts137" TIME_SLOT_REF2="ts138">
                <ANNOTATION_VALUE>yiǧi al yšūf-u ʕād ygūm tā yšūf-u tā mā yigaʕ tā yxāf tā mā ytigallaṭ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a70"
                TIME_SLOT_REF1="ts139" TIME_SLOT_REF2="ts140">
                <ANNOTATION_VALUE>ʕugub ḥaṭṭēne ḥaṭab l-alḥaz-u l-alḥaz-u mawǧūd al-ᵊhniyye, l-alḥaz-u mawǧūd al-bīr yaʕni lē riḥti hināk ašawwf-ič yā-´, čünkü ḏ̣all ǧawwa hniyye alḥaz ǧawwa l-ḥaṭab.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a71"
                TIME_SLOT_REF1="ts141" TIME_SLOT_REF2="ts142">
                <ANNOTATION_VALUE>nhār ʕād āni ẓġayyre hīčiḏ miṯil ta-ngūl miṯil Sumayye amma ḏ̣aʕīfa āni, wgaʕat ad-diǧāǧe bgaḷb al-bīr. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a72"
                TIME_SLOT_REF1="ts143" TIME_SLOT_REF2="ts144">
                <ANNOTATION_VALUE>hā wun ygūlūn xawāti taʕāli tā tuṭluʕīn-he min gaḷb al-bīr, gitt: laʔ! al-ʕaǧi ta-ngūl bī-´ al-ʕaǧi aẓ-ẓġīr hā yḥasib abū-´ yaʕni abū-´. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a73"
                TIME_SLOT_REF1="ts145" TIME_SLOT_REF2="ts146">
                <ANNOTATION_VALUE>abū-´ yaʕni al-abb hā, āni aḥasib abū-ye yʕarif kull an-nās, aḥasib abū-ye çok kuvvetli, aḥasib abū-ye hniyye yigdar ʕa-kull ad-dinye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a74"
                TIME_SLOT_REF1="ts147" TIME_SLOT_REF2="ts148">
                <ANNOTATION_VALUE>böyle bir hissiyat āni hā öyle bir babamın böyle gözümde yani b-ʕēn-i öyle mčabbritt-u ki alḥaz ǧaʕad aftakir haš-šakli demek āni şu anki çocuk aklımla hniyye yaʕni hā.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a75"
                TIME_SLOT_REF1="ts149" TIME_SLOT_REF2="ts150">
                <ANNOTATION_VALUE>mčabbre abū-ye aḥasib ad-dinye abū-ye yigdar-il-he, agūl āni lā tḥuṭṭun-ni āni b-al-bīr! xall abūy yiǧi, abū-ye yugḏ̣ub-ni intin ᵊtdaššrin-ni bgaḷb al-bīr.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a76"
                TIME_SLOT_REF1="ts151" TIME_SLOT_REF2="ts152">
                <ANNOTATION_VALUE>axāf in ydaššrin al-ḥabil yaʕni hā, miṯil wakt-in tara hniyye hā, Yūsif tara ḥaṭṭō-´ b-al-bīr axūt-u səttō-´ b-al-bīr.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a77"
                TIME_SLOT_REF1="ts153" TIME_SLOT_REF2="ts154">
                <ANNOTATION_VALUE>āni zād agūl trūhin ssittin-ni b-al-bīr, atni abū-y tā yiǧi tā abū-y yḥuṭṭ-ni čān ʕād ʕugub wāḥad ǧīy min ʕiǧyān ǧīrān-ne, gāḷ: xušši b-az-zōr čān yitill-ni. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a78"
                TIME_SLOT_REF1="ts155" TIME_SLOT_REF2="ts156">
                <ANNOTATION_VALUE>ysitt-ni bgaḷb al-bir yugḏ̣ub al-maras axušš ᵊbgaḷb al-bīr aṭluʕ ad-diǧāǧe,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
