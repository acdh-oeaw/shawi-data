    <TIER LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Corpus:Harran03">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
                <ANNOTATION_VALUE>awwali b-zimānāt čān ᵊrḥamt abū-ye gāḷ d-ahniyye arīd aḥafir-l-i bīr, miššān tā_zraʕ baqče.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a2"
                TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>gāl, daḥḥag aš-šī qāli ta-ngūl al-baqdanūs w-al-niʕnāʕ han-nōb kull-u ṣār xormōn, gāl dā_xallī-´ ta-yṣīr organīk yaʕni.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3"
                TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>čān ygūm w gəḏ̣ab-ill-u zlime, ᵊzlime awwali maḥallit-ne yṣīrūn min nisābit-ne, ama durum-hum maġdūr, mā ʕid-hum šī.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a4"
                TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>hā w čān ygūm yṣīḥ l-az-zlime, ygūm az-zlime w gām yḥafir.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>waṛa d-dūr waṛa dūr ahal-i ta-ngūl bēt ahal-i ḥōš-hum,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>dönümēn, dönem humma ǧāʕdīn bī-´, w-ad-dönem al-ḥōš al-waṛāni hāḏa, gāḷ arīd asāwi bīr aḥuṭṭ ʕalē-´ dīnamaw aḥuṭṭ ʕalē-´ santrafīš šakli w-axalli aḏ̣all awarrid asāwi yaʕni azraʕ-ill-i baqče.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>w gām az-zlime yḥafir, w yḥafir w yḥafir w yḥafir w yḥafiiiiir,  ʕugb aṯ-ṯalaṯ arbaʕ mitrawāt təṭlaʕ aṣ-ṣəfā.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts16" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>ṣəfāt-in čibīre, ā w gām an-nōb yiksir aṣ-ṣəfā gəḏ̣ab-il-he l-ḥadīde, </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a10"
                TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>w gāḷ ḥāǧǧey! ṭəlaʕ-in-ne ṭləʕat aṣ-ṣəfā yaʕni šnōn Məṣṭafa, šnōn asāwi?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>gāl: axū-ye, ᵊb-kēf-ak iksir-he aṣ-ṣəfā ᵊṭləʕat yaʕni hā.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a12"
                TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>w ygūm aṣ-ṣəfā haḏīče, ygūm miṯil at-tunguše an-nagiš, nagiš nagiš, mū ilme ilme hā, ilme ilme yiksir aṣ-ṣəfā.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a13"
                TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>yiksir-ha bēš? hīčiḏ ḥadīde ʕind-u, ᵊhniyye w-… sičče sičče, as-siččt al yšiddūn-ha li-l-bəgar tā mā yinhazmin min ᵊhnīte ta-ngūl.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a14"
                TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>al-xēṭ yšiddūn-u yṭuggūn-u b-al-gāʕa, w lilhe ḥalga hīčiḏ, as-sičče w tā… bala ǧāfye yḥuṭṭūn ʕād al-ᵊmrəse, ᵊnḥuṭṭ al-ᵊmrəse bī-he w-ᵊnšidd al-ᵊbgaṛa mesela ʕid-ne hīčiḏ ᵊsčačč.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a15"
                TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>as-sčačč hīčiḏ ḥadīdāt w lilhin ta-ngūl rūs-hin ᵊhniyye rfāʕ, w lilhin hīčiḏ xātmāt haš-šakle mihniyyāt haš-šakle bala ǧāfye haš-šakle.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a16"
                TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>w-ᵊnšidd ʕād iḥne al-ᵊmrəse hēne ʕa-l-ᵊbgaṛa… nṭugg-ha b-al-gāʕ ʕugub ʕād nšidd li-l-ᵊbgaṛa tā mā tinhazim.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a17"
                TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts34">
                <ANNOTATION_VALUE>az-zlime b-haḏīče kisar al-ᵊhniyye, kisar haḏīče aṣ-ṣəfā, w ḏ̣all balči ʕalē-he šahrēn ṯalāṯ tā bəgar aṣ-ṣəfā.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a18"
                TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>aṣ-ṣəfā mitraw, </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a20"
                TIME_SLOT_REF1="ts38" TIME_SLOT_REF2="ts40">
                <ANNOTATION_VALUE>mitraw ᵊhnīt-he yaʕni ʕuruḏ̣-ha, w hnīt-he čibīre yaʕni hā alān-ha.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a21"
                TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts42">
                <ANNOTATION_VALUE>w ḏ̣all bi-hdāy bi-hdāy bi-hdāy bi-hdāāāāāy lummun-ma kisar-ha w xašš mitraw ǧawwa l-gāʕa, ṭəlaʕ at-trāb ʕād.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a22"
                TIME_SLOT_REF1="ts43" TIME_SLOT_REF2="ts44">
                <ANNOTATION_VALUE>gām an-nōb yḥafir at-trāb, w yḥafir arbaʕṭaʕaš mitraw, win-hin ṭālʕāt ʕēnēn!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a23"
                TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts46">
                <ANNOTATION_VALUE>hin ᵊzqār ʕyūn ygūlūn l-al-mayye ʕyūn, al-ʕēn yā ᵊtbalbil hīčiḏ tā tiṭlaʕ mayyt al-bīr hā.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a24"
                TIME_SLOT_REF1="ts47" TIME_SLOT_REF2="ts48">
                <ANNOTATION_VALUE>w mā ṭləʕat, ṭləʕat hīčiḏ ʕēn-in yābse, w ḏ̣all ʕād haḏāk al-ᵊhniyye al-bīr.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a25"
                TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts50">
                <ANNOTATION_VALUE>čān ygūmūn ᵊhnā, sāwa vazgeč minn-u, w gām ʕādēne han-nōba ḥifar ᵊhnā ygūlū-l-he č-češme, yüz nimre awwali ygūlūn l-ač-češmāt.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a26"
                TIME_SLOT_REF1="ts51" TIME_SLOT_REF2="ts52">
                <ANNOTATION_VALUE>lawābo hāḏi māmin? ač-češme mā ygūlū-l-he hniyye. awwali yiktibūn ʕalē-he yüz numara, at-turuk w-al-ʕarab ʕād ᵊmsammīn-he yüz nimre.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a27"
                TIME_SLOT_REF1="ts53" TIME_SLOT_REF2="ts54">
                <ANNOTATION_VALUE>yüz nimre, nəmāṛa imye yaʕni hā, msammīn-he yüz nimre yiktibūn ʕalē-he hīčiḏ yüz ʕaman gāylīn hāḏi yüz nimre w rāyḥīn al-ʕarab kull-hum ygūlūn yüz nimre amma ač-čwā…</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a28"
                TIME_SLOT_REF1="ts55" TIME_SLOT_REF2="ts57">
                <ANNOTATION_VALUE>awwali tuvālētāt māmin. </ANNOTATION_VALUE>
