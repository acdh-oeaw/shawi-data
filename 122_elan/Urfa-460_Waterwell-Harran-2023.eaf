                <ANNOTATION_VALUE>w ytillūn-ni ʕād, ī al-bīr lissaʕ-u mawǧūd l-alḥaz hināk. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a81"
