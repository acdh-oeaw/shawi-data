    <TIER LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Corpus:Harran02">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts3">
                <ANNOTATION_VALUE>ᵊrtaḥam ǧidd-i Ǧōšaw, māt, w riḥna ʕa-š-šēx Ḥayā, ᵊndumm-u, ʕala Ḥarrān, yōm-in …</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3"
                TIME_SLOT_REF1="ts4" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>Maḥāwi, ī, māt ᵊrtaḥam, </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>w yirḥam ᵊmmāt-ak!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>w riḥna ndumm-u, ʕala Ḥarrān, ᵊndumm-u b-gabər axū-´, Ibrāhīm, Barha Dugmān ngul-l-u iḥne, yaʕni laqab, ysammūn-u Barha Dugmān yaʕni.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>Brāhīm māt gabəḷ ǧidd-i Ǧōšaw ᵊb-xaməsṭaʕaš sine, ʕišrīn sine, ᵊrtaḥam.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a8"
                TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>ā ǧidd-i Ǧōšaw ᵊmwaṣṣi gāyil: dummū-ni b-gabər Barhaw, yaʕni waṣiyyet,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>ḥufarna gabər, gabər ǧidd-i Barhaw, ᵊḥfərō-´. ǧidd-i Barhaw ᵊʕḏ̣ām-u, mū mayyit awwali yā?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a10"
                TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>al-ᵊʕḏ̣ām ylummūn-hin ʕugub-ma yḥuṭṭūn al ymūt ǧidīd, yḥuṭṭūn-hin ʕind rās-u, yōm ʕid riǧlēn-u, ʕid riǧlēn-u yirmūn-hin, hīčiḏ yirmūn-hin.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>hā, lammaw ᵊʕḏ̣ām-u ǧaʕad ynaḏ̣ḏ̣fūn-u bgaḷb al-gabər ymiššūn-u ynaḏ̣ḏ̣fūn-u yaʕni ysāwūn-u düzeltme.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a12"
                TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>al-ᵊʕḏ̣ām ṭlaʕō-hin ḥaṭṭō-hin, ḥaṭṭō-hin ᵊb-pōšēte, pōšēte, ᵊb-ʕəllāga. w gāḏ̣əb-hin al-ʕaǧīy, walid ʕĪse, yaʕni ṭōrun Barha Dugmān, Xalīl.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a13"
                TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>ənṭō-´ b-al-pōšēte gālō-l-u: hāk haḏanne tiqayyat ʕalē-hin ʕugub tinṭī-nā yā-hin lummun-ma hniyye ugḏ̣ub-hun tiqayyat ʕalē-hin!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a14"
                TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>Xalīl yḥuṭṭ al-pōšēte al-ᵊʕḏ̣ām, ʕa-t-taksiyyāt wāǧfāt imyitēn mitir ʕin al-miǧanne, biʕīd.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a15"
                TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>yāxḏ al-pōšēte ʕḏ̣ām ǧidd-u yrūḥ yḥuṭṭ-u b-at-taksi hahaha. yrūḥ yḥuṭṭ-u b-at-taksi, rāmī-hin b-at-taksi mčallit al-baġāǧ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a16"
                TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>w ǧāy wāǧif ᵊbsāgt al-mille, al-ʕālam dammaw ᵊhni… gəḏ̣aw al-gabər ḥaṭṭaw ǧidd-i Ǧōšaw yrīd ydummūn-u yqabbtūn yḥuṭṭūn aṭ-ṭbəgāt yaʕni aṭ-ṭbəgāt,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a17"
                TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts34">
                <ANNOTATION_VALUE>han-nōba wāḥad gāḷ: walu al-ᵊʕḏ̣ām wēn-hin? ʕḏ̣ām Barha ḥāǧǧ Barhaw wēn-hin?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a18"
                TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>gāḷaw: Xalīl wēn al-ᵊʕḏ̣ām? gāḷ: mū giltu tiqayyat ʕalē-hin! xaḏēt-hin ḥaṭṭēt-hin b-at-taksiʸ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a19"
                TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>wal imiš rūḥ hāt-hin maqṣūft al-ʕumur, wal! w čān yizgaḥūn ʕalē-´ w rāḥ rakəḏ̣. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a20"
                TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
                <ANNOTATION_VALUE>rāḥ ǧāb-hin m-at-taksiʸ. w fakkō-hin ḥaṭṭō-hin ʕid riǧil ǧidd-i Ǧōšaw, čān yiṣbuṭūn al-gabər ʕād w ydummūn-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a21"
                TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts42">
                <ANNOTATION_VALUE>aw gāmaw han-nōba fōg al-gabər yrīd ytiḏ̣āḥakūn yaʕni, ᵊšnōn hāḏa nsāwi? w salāmt-ak w-al-ʕāfye!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
