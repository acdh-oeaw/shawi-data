                TIME_SLOT_REF1="ts145" TIME_SLOT_REF2="ts146">
                <ANNOTATION_VALUE>māmiš awwali, sirwāl māmin, šēy māmin yilbas gaṣṣīrt-he lummun-ma tā tibas gaṣṣīrt-u tā yihni tā yi… tā yilbas-he.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
