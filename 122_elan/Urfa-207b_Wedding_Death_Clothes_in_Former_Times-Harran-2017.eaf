        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a72"
                TIME_SLOT_REF1="ts143" TIME_SLOT_REF2="ts144">
                <ANNOTATION_VALUE>awwal nōba kull-he gabəḷ awwali, kull-he. awwali māmin zād az-zlime yilbas ṯōb al-ḥurma tlabbs-u ṯōb-ha yilbas ṣāyt al-ḥurma tā yqassil gaṣṣīrt-u. </ANNOTATION_VALUE>
