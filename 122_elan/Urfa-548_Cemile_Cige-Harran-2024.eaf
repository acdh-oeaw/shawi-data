    <TIER LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Corpus:Harran23">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts3">
                <ANNOTATION_VALUE>xōǧam ač-čīgt al-farik ᵊšnōn ᵊṣṣīr? </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3"
                TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>čīgt al-farik iḥne ahal al-Urfaliyye, kull šīt-ne ʕaman-he xaṣṣ ᵊṣṣīr zēne.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a4"
                TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>ṣōṭ-na nsāwi ʕa-l-īd, ad-dibis ᵊnsāwi ʕa-l-īd, w-al-burqul zād ᵊnsāwi ʕa-l-īd.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>aṣ-ṣōṭ awwal šī ykaššminn-u ummahāt-ne, wakt-in ʕugb ar-rabīʕ. ykaššmin aṣ-ṣōṭ b-īdēn-hin, yšurrun-hin b-aš-šams.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>ʕugub-ma yšurrun-hin b-š-šamis, aṣ-ṣōt yības yḥuṭṭunn-u b-al-laylōnāt, yiʕarrǧinn-u ysāwinn-u aswad.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>ʕugub-ma yṣīr aswad uxṛa yṭuššinn-u m-al-laylōnāt tā yības ᵊb-nōba b-š-šamis.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a8"
                TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>b-at-tāli yrūḥūn ywaddūn-u ʕa-ǧ-ǧarrāšīn.  aǧ-ǧarrāšīn yiǧrušūn aṣ-ṣōṭ. ʕugub-ma yiǧrušūn aṣ-ṣōṭ yz… yḥuṭṭūn ʕalē-´ zēt.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>yḥuṭṭūn ʕalē-´ miliḥ w yšīl aṣ-ṣōṭ hāḏa mūnit-ne as-sine kull-he nākul min-he, ṣōṭ-ne. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>as-sine kull-he nākul min-he ʕala kull ačin-ne.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a12"
                TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>ʕa-č-čīge, ʕa-l-qīyma ʕala kull al… iḥne ništihi nḥibb ʕaman ᵊnḥibb al-ḥārr, kull-u nḥiṭṭ ʕal ačil-ne aṣ-ṣōṭ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a13"
                TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>w-ad-dibis ᵊšnōn nsāwī-´? ad-dibis zā al-ᵊfrənǧi nǧīb-u. ᵊnqassl-u zēn w numrud-u b-īdēn-ne.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a14"
                TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>yḏ̣all b-al-lgāne čam nahāṛ, b-at-tāli uxṛa nimlaḥ-u nʕaṣṣir mayyt-u. ʕugub-ma nʕaṣṣir mayyt-u nšurr-u b-aṣ-ṣiyāni ʕa-š-šamis.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a15"
                TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>yḏ̣all zā hafte ʕašir tiyyām yṣīr dibis. zā nimlaḥ-u w-ᵊnḥuṭṭ-u b-aš-šwašš. hāḏa zād kull as-sine nḏ̣all nākul minn-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a16"
                TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>ač-čīge šnōn ᵊnsāwī-he? al-burqul zād awwali az-zēn ysawwūn-u ʕa-l-īd bass arṭəq az-zimān ʕamann-u tibaddal, mā nsāwī-´. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a17"
                TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts34">
                <ANNOTATION_VALUE>ᵊnǧīb-u ḥāḏ̣ir min marketāt ᵊnǧīb-u bass al… al-burqul al-aswad xēr m-al-burqul al-aṣfar. al-aswad bsaʕ yisāwi. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a18"
                TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>ᵊnḥuṭṭ-un-na ḥafnit burqul, w ṣōṭ w dibis w ʕala ṯūm w bəṣal, zēn hāḏe yínfarič b-al-īd, balāy mayye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a19"
                TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>balāy mayye aḥsan yiṣīr xēr min al ᵊtḥuṭṭ ʕalē-´ mayye, az-zēn aṣlīt-u balāy mayye. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a20"
                TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
                <ANNOTATION_VALUE>ʕugub-ma yinfarič zēn zēyūne, ᵊnḥuṭṭ ʕalē-´ baqdanūs w bəṣal zā nugruḏ̣ ʕalē-´.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a21"
                TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts42">
                <ANNOTATION_VALUE>w b-at-tāli nḥuṭṭ ʕalē-´, al yrīd ysāwi ʕala laḥam, laḥam habir ᵊngul-l-u, aswad, balāy šaḥam. yduggunn-u b-al-īd ʕa-l-ᵊḥǧaṛa b-at-toqmāqa yḏ̣allin yduggunn-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a22"
                TIME_SLOT_REF1="ts43" TIME_SLOT_REF2="ts44">
                <ANNOTATION_VALUE>al-wāḥad zād yrīd zā ysāwi ʕala bēḏ̣, al-bēḏ̣ zād tiksir, tiksir-ill-ak bēḏ̣tēn ṯalāṯ ᵊb-gaḷb as-samin w tḥuṭṭ-u b-ač-čīge txalṭ-u. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a23"
                TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts46">
                <ANNOTATION_VALUE>yamm-u zā ssāwi yā ṭurši yā zōlaṭa w hāḏi bir övünümüz. ʕawāfi! </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a25"
                TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts50">
                <ANNOTATION_VALUE>aḷḷa yinṭī-k.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
