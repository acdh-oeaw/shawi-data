                TIME_SLOT_REF1="ts371" TIME_SLOT_REF2="ts372">
                <ANNOTATION_VALUE>gāḷ: aṣṣōb araddid-he?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a187"
                TIME_SLOT_REF1="ts373" TIME_SLOT_REF2="ts374">
                <ANNOTATION_VALUE>gitt: waḷḷa al-ḥurma hāḏi āni mhabūle ǧaʕad-agul-l-ak. bass rūḥ haman rūḥ raddid-he! lā tahniye raddid-he!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
