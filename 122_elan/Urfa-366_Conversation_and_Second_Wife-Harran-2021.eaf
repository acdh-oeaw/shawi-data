        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a183"
                TIME_SLOT_REF1="ts365" TIME_SLOT_REF2="ts366">
                <ANNOTATION_VALUE>gāḷat: mā gāḷ kūt b-al-gāʕ? gitt: lā sāwēti ʕala gayyit ē. aš-Šaʕbān wakt-inn-u mšawwfīn-u l-ḥayye. w gām gəmaz, āni mā-bī kullši āni ṭayyib.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
