            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a234"
                TIME_SLOT_REF1="ts467" TIME_SLOT_REF2="ts469">
                <ANNOTATION_VALUE>gāḷ: laʔ alle arīd ambuš gaḷəb-ha iḥne ǧaʕad ništaġil w huwwa ǧāyib-il-ne uxra kunn nahāṛ ḥurma?</ANNOTATION_VALUE>
