    <TIER LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Corpus:Ceylanpinar02">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a2"
                TIME_SLOT_REF1="ts2" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>waḷḷa yā xayy-i bagūl belči mītēn ṯalṯimye. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a4"
                TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts9">
                <ANNOTATION_VALUE>gaṛāye. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts12" TIME_SLOT_REF2="ts13">
                <ANNOTATION_VALUE>gaṛāye. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a8"
                TIME_SLOT_REF1="ts14" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>kull-he ʕAdwān.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a10"
                TIME_SLOT_REF1="ts18" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>waḷḷa, ᵊb-ʕagl-i gālaw yōm-in ṣār al-ᵊhniyye, ṣār millet wekīli, aš-šēx.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>gālaw yā xayy-i mā ʕād aʕarif, sittīn alif, </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a13"
                TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts27">
                <ANNOTATION_VALUE>yaʕni in-hum minṭīn w huwwa, </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a15"
                TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts31">
                <ANNOTATION_VALUE>qaznač yaʕni. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a17"
                TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts35">
                <ANNOTATION_VALUE>demek b-as-sittīn al yi… </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a19"
                TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts39">
                <ANNOTATION_VALUE>ī, ar-rayy. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a21"
                TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts42">
                <ANNOTATION_VALUE>hīčiḏ hīčiḏ, yā xū-ya ʕAdwān huṃṃa čānaw ad-dīre hāḏi kull-he ʕAdwān. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a23"
                TIME_SLOT_REF1="ts44" TIME_SLOT_REF2="ts46">
                <ANNOTATION_VALUE>al-Milliyye zimān gabǝḷ hā, yōm-in ᵊḥkūma māmiš, </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a25"
                TIME_SLOT_REF1="ts48" TIME_SLOT_REF2="ts50">
                <ANNOTATION_VALUE>ī, al… ʕAdwān ḏīč an-nōba huṃṃa qārši ta-ngūl Ǧēs, qārši al-Bāgāt Qarakēš, qārši Šammar, ʕNize. ʕAdwān čānat. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a27"
                TIME_SLOT_REF1="ts53" TIME_SLOT_REF2="ts55">
                <ANNOTATION_VALUE>huṃṃa al-mikān hāḏa čānaw huṃṃa ʕaskar al-mikān ḏa. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a29"
                TIME_SLOT_REF1="ts57" TIME_SLOT_REF2="ts58">
                <ANNOTATION_VALUE>maʕ ᵊBrāhīm bāše. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a31"
                TIME_SLOT_REF1="ts61" TIME_SLOT_REF2="ts62">
                <ANNOTATION_VALUE>w-yōm-in ʕādēne ṣārat dawle, ᵊstaḥallaw Qōrunšahar maʕ al-bāšāt fāynīn al-ḥaḏ̣ḏ̣, w ǧā-hum ʕādēne ᵊḥkūme xayyo, aṭ-ṭiyyāra gāyme tḥūf ʕalē-hum b-al-lēl.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a32"
                TIME_SLOT_REF1="ts63" TIME_SLOT_REF2="ts64">
                <ANNOTATION_VALUE>w-b-al-lēl šīlu huṃṃa w Brāhīm bāše, ʕAdwān, ḏ̣aḷḷat qalīle hēne, bī-he šī ʕašar xamiṣṭaʕaš ǧarye belči hīčiḏ, ta-ngūl al-ᵊBhēme aš-Šrufa haḏōle. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a33"
                TIME_SLOT_REF1="ts65" TIME_SLOT_REF2="ts66">
                <ANNOTATION_VALUE>ā, w šāl ʕād al-bāše w nizal b-al-ᵊḤsičče, bēn al-ᵊḤsičče w-al-Qāmašliyye ygūlū-l-he, xarbe, ygūlū-l-he ᵊṢfayya.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a34"
                TIME_SLOT_REF1="ts67" TIME_SLOT_REF2="ts68">
                <ANNOTATION_VALUE>waḷḷa, b-al-lēl ṣār, aṭ-ṭiyyāra gāmat ʕād tiḏ̣rib-hum sahhalaw Qōrunšahar. gām yḥārib Qōrunšahar huwwa w-ʕAdwān yaʕni, al-ʕaskar w ʕAdwān </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a36"
                TIME_SLOT_REF1="ts71" TIME_SLOT_REF2="ts72">
                <ANNOTATION_VALUE>w-gām ʕād yōm aṭ-ṭiyyāra gālaw waḷḷa bāčir aṭ-ṭiyyāra al-lēle šayyalaw bāʕir-hum w-haǧǧaw b-al-lēl, huwwa w ʕAdwān.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a37"
                TIME_SLOT_REF1="ts73" TIME_SLOT_REF2="ts74">
                <ANNOTATION_VALUE>w hēnāk ʕād ᵊnḥimas w māt. maʕā-ye Muṣtafa hāḏa nōba riḥna ndawwir siyāḥa, gilt-ill-u hāḏa gabir bāšit-ne. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a38"
                TIME_SLOT_REF1="ts75" TIME_SLOT_REF2="ts76">
                <ANNOTATION_VALUE>ā, hāḏi isim-he ᵊṢfayye, al-ᵊXrēbe gutt hāḏa gabir bāšit-ne xayyo. fitna ʕād min ʕind ᵊṢfayye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a39"
                TIME_SLOT_REF1="ts77" TIME_SLOT_REF2="ts78">
                <ANNOTATION_VALUE>w gabǝḷ hīčiḏ xayyo, ḥarb w hniyye, han-nōbe gabǝḷ ʕAdwān bi-hal-minṭaqa hāḏi. al-minṭaqa hāḏi, ā hāḏi kuṯrut … yindallūn al-ʕašīre min Ǧēs al-awādim al-ᵊkbāṛ māmiš? yʕarfūn alḥaz.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a40"
                TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts80">
                <ANNOTATION_VALUE>ʕAdwān čānat qārši Siyāle qārši ta-ngūl Ǧēs ᵊb-nōba mā… ʕAdwān huṃṃa b-at-tāli ʕād rāḥat. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a42"
                TIME_SLOT_REF1="ts83" TIME_SLOT_REF2="ts84">
                <ANNOTATION_VALUE>al-bāše hū rayyis ṣār, ṣār miṯl ad-dawle mi… miṯil hāḏa lō ʕAbdaḷḷa Öcalan.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a43"
                TIME_SLOT_REF1="ts85" TIME_SLOT_REF2="ts86">
                <ANNOTATION_VALUE>waḷḷa, an-nōbe ḏāk az-zimān aḷḷa yisʕid-u al-mille kull-he b-amr-u. yāxuḏ xōg min al-ʕālam. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a45"
                TIME_SLOT_REF1="ts89" TIME_SLOT_REF2="ts90">
                <ANNOTATION_VALUE>yāxuḏ vergi. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a47"
                TIME_SLOT_REF1="ts93" TIME_SLOT_REF2="ts94">
                <ANNOTATION_VALUE>bass min ʕAdwān mā yāxuḏ. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a49"
                TIME_SLOT_REF1="ts97" TIME_SLOT_REF2="ts99">
                <ANNOTATION_VALUE>ī. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a51"
                TIME_SLOT_REF1="ts101" TIME_SLOT_REF2="ts102">
                <ANNOTATION_VALUE>yāxuḏ ᵊb-nōba min al-ᵊKrād min ta-ngūl Baggāṛa, ᵊNʕēm, ᵊŠarrābiyyīn, kull-he tinṭi mīt dābbe ʕind-u yinṭi ʕašra </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a53"
                TIME_SLOT_REF1="ts104" TIME_SLOT_REF2="ts106">
                <ANNOTATION_VALUE>čann-u bāʕir wala čann-u qanam. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a54"
                TIME_SLOT_REF1="ts107" TIME_SLOT_REF2="ts108">
                <ANNOTATION_VALUE>bass min ʕAdwān mā ᵊnṭō-´ xōg. gāḷaw iḥne mā… ᵊb-xēr-u, čünkü ʕAdwān ygūlū-l-u ngūl iḥne ᵊrwāg bēt-ak iḥna ǧanab ʕalyān.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
