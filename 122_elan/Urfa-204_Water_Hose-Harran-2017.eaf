                <ANNOTATION_VALUE>ṣūs-ne ṣūst al al ʕa-d-darb aṣ-ṣūs. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a46"
                TIME_SLOT_REF1="ts93" TIME_SLOT_REF2="ts94">
                <ANNOTATION_VALUE>ᵊtḥūš, ē yambaġı, ṣūs, ᵊtḥūš-u, w-aṣ-ṣūs ᵊtfarrš-u ᵊtfarriš gaḷb al-wāwi.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a48"
                TIME_SLOT_REF1="ts95" TIME_SLOT_REF2="ts96">
                <ANNOTATION_VALUE>ᵊssāwi wāwi ǧǧīb waḥal w-ᵊssāwi hīčiḏ ᵊssāwi wāwi. al-wāwi šinhu? al-wāwi waḥal ᵊssāwī-´ arḏ̣ tā tḥuṭṭ bī-´ as-samin.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a49"
                TIME_SLOT_REF1="ts97" TIME_SLOT_REF2="ts98">
                <ANNOTATION_VALUE>ā w-ᵊǧǧīb-il-he gṭēmit ṣūs ᵊtfarrš-u, w ʕugub-ma tfarrš-u ṣūs ᵊtfarrš-u xbabb w tistil aḏ̣-ḏ̣arf ᵊbgaḷb-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a50"
                TIME_SLOT_REF1="ts99" TIME_SLOT_REF2="ts100">
                <ANNOTATION_VALUE>b-al-gēḏ̣ mā yšūf al-ḥarr ᵊb-nōba mā aṣ-ṣūs mā ysāwi ʕalē-´ ḥarr. aṣ-ṣūs dāyim yinṭi serin bārid yinṭi brūde yḏ̣all dāyim bārid.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a51"
                TIME_SLOT_REF1="ts101" TIME_SLOT_REF2="ts102">
                <ANNOTATION_VALUE>ā, w-ᵊtqaṭṭī-´ b-ṣūs w ǧǧallil min ǧawwa gāʕt-u ṣūs ᵊbgaḷb aš… š-ism-u haḏāk? al… ᵊbgaḷb al-wāwi.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a52"
                TIME_SLOT_REF1="ts103" TIME_SLOT_REF2="ts104">
                <ANNOTATION_VALUE>ā w-ᵊssāwī-l-u zād ᵊqṭāwa hīčiḏ, hā timli aḏ̣-ḏ̣arf, w tḥuṭṭ-u bgaḷb al-wāwi. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a53"
