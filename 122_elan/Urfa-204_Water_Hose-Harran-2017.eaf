        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a56"
                TIME_SLOT_REF1="ts115" TIME_SLOT_REF2="ts116">
                <ANNOTATION_VALUE>al-wāwi miṯil, axēr min ad-dūlāb mā yxušš ʕalē-´ ʕiṯṯ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a59"
                TIME_SLOT_REF1="ts117" TIME_SLOT_REF2="ts118">
                <ANNOTATION_VALUE>awwali yxāfūn min al-ʕiṯṯ. al-ʕiṯṯ yḏ̣all yibḥaš al-ᵊhniyye yḏ̣all yibḥaš aǧ-ǧilid lummun yibgur-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a60"
                TIME_SLOT_REF1="ts119" TIME_SLOT_REF2="ts120">
                <ANNOTATION_VALUE>al-ʕiṯṯ al-ḥamar ʕiṯṯ šī ḥamar hīčiḏ ʕiṯṯ-in nāʕim hīčiḏ yiṭlaʕ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a61"
                TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts122">
                <ANNOTATION_VALUE>hāḏa yxāfūn mn-a… yxāfūn min al… ad-dūd, min kullši yxāfūn, min nimmāl min kullši. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a62"
                TIME_SLOT_REF1="ts123" TIME_SLOT_REF2="ts124">
                <ANNOTATION_VALUE>hā ā ygūmūn ʕādēne, ā, ᵊǧǧīb-l-he ᵊqṭāwa ssāwī-l-he qṭāwa zād ʕala gadd-u. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a63"
                TIME_SLOT_REF1="ts125" TIME_SLOT_REF2="ts126">
                <ANNOTATION_VALUE>ᵊǧǧaddir ʕala gadd-u haš-šakle w tḥuṭṭ al-ᵊqṭāwa. w ᵊtlayyiṣ hīīīīčiḏ mā ḥawālē-´ tlayyiṣ. ā w-ᵊssaččr-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a64"
                TIME_SLOT_REF1="ts127" TIME_SLOT_REF2="ts128">
                <ANNOTATION_VALUE>ᵊtxallī-´ hāḏa xallatt-u l-aš-štē. hāḏa xallatt-u as-samin hāḏa l-aš-štē.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a65"
                TIME_SLOT_REF1="ts129" TIME_SLOT_REF2="ts130">
                <ANNOTATION_VALUE>ᵊtnike, ᵊtniktēn txallī-hin ḏi l-aš-štē. ᵊtgūm ᵊssāwi miššān aṣ-ṣfəri. miššān b-aṣ-ṣfəri tā ssāwi ʕād samin yḏ̣all.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a66"
                TIME_SLOT_REF1="ts131" TIME_SLOT_REF2="ts132">
                <ANNOTATION_VALUE>az-zubde, at-tāli al-xāṯir yḏ̣all ᵊssāwi l-aṣ-ṣfəri, ᵊssāwī-l-he zād uxṛa ʕukka hīčiḏ hal-ᵊgdēd. ᵊssāwī-he ᵊssāwī-he miššān tā yḏ̣allūn yāklūn bī-he b-aṣ-ṣfəri.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a67"
                TIME_SLOT_REF1="ts133" TIME_SLOT_REF2="ts134">
                <ANNOTATION_VALUE>yā īdām aṣ-ṣfəri, awwali māmin īdām. awwali zēt hal-gadd māmin, awwali qēr aš-šaḥam, w-aš-šaḥam w-as-samin, awwali. māmin.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a68"
                TIME_SLOT_REF1="ts135" TIME_SLOT_REF2="ts136">
                <ANNOTATION_VALUE>hāḏi ysāwūn w ytḥuṭṭ ᵊḏ̣ḏ̣all ʕād ᵊtḥuṭṭ-u zād tʕallǧ-u. ᵊmʕallaga haḏāk ʕād az-zihīd. bī-´ gədar arbaʕ xaməs kīlawāt hīčiḏ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a69"
                TIME_SLOT_REF1="ts137" TIME_SLOT_REF2="ts138">
                <ANNOTATION_VALUE>ᵊtʕallǧ-u w-ᵊyḏ̣allūn yavaš yavaš yāklūn minn-u. lummun yxalṣūn-u w lummun b-aš-štē yfukkūn aḏ̣-ḏ̣arf.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a70"
                TIME_SLOT_REF1="ts139" TIME_SLOT_REF2="ts140">
                <ANNOTATION_VALUE>ā ᵊḏ̣ḏ̣all ᵊtmidd īd-he b-aḏ̣-ḏ̣arf tibḥaš, yṣīr ʕād b-aš-štē ǧāmid, as-samin. ᵊtfūkk aḏ̣-ḏ̣arf aḏ̣-ḏ̣arf miṯl al-biskawīt, miṯl al-bastīq. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a71"
                TIME_SLOT_REF1="ts141" TIME_SLOT_REF2="ts142">
                <ANNOTATION_VALUE>ᵊtmidd īd-he b-aḏ̣-ḏ̣arf. ᵊttill-il-he b-gadd lahmūde lahmūdtēn, w-uxṛa ssaččir ʕalē-´ w-uxṛa w-ᵊtḥuṭṭ al-ᵊqṭāwa w-ᵊssaččir.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a72"
                TIME_SLOT_REF1="ts143" TIME_SLOT_REF2="ts144">
                <ANNOTATION_VALUE>ᵊssāwi bāb hīčiḏ l-al-wāwi, bāb tā ḏ̣ḏ̣all ᵊtmidd īd-he tāxuḏ w tihni. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a73"
                TIME_SLOT_REF1="ts145" TIME_SLOT_REF2="ts146">
                <ANNOTATION_VALUE>ᵊtxallī-´ msakkar w bass ᵊḏ̣ḏ̣all ᵊtmidd īd-he min al-bagər. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
