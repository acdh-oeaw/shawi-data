    <TIER LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Corpus:Harran04">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
                <ANNOTATION_VALUE>aḏ̣-ḏ̣arif yislaxūn ᵊnʕaǧe, ʕugub-ma yislaxūn ᵊnʕaǧe uxṛa ʕād ᵊtḥuṭṭ bī-´ qṭēmit miliḥ,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a2"
                TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>timlaḥ-u w yimʕaṭūn aš-šaʕar al bī-´ kull-u. ʕugub-ma yimʕaṭūn aš-šaʕar al bī-´ kull-u ᵊtgūm ʕād ᵊtḥuṭṭ bī-´ ḥbēbāt, ᵊḥbēbāt ṭaḥīn xafīf.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3"
                TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>w-ᵊtxarrṭ-u mn-aṭ-ṭaḥīn mn-al-ʕaǧīn miṯil al-ʕaǧīn, tʕaǧin bī-´ w txarrṭ-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a4"
                TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>ʕugub-ma txarrṭ-u trūḥ ᵊǧǧīb. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>lā lā! aš-šaʕar timʕaṭ-u hāḏa minn-u aš… aš… timʕaṭ aš-šaʕar ᵊb-nōb. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>aš-šaʕar yṣīr min ǧawwa.  </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a8"
                TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>w-al-laḥam yṣīr min fōg.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>māʕəṭt-u, lā, māʕəṭt-u b-at-tāli ʕād ᵊzzayyn-u. ᵊzzayyn-u miṯil at-trāš, ᵊzzayyn-u b-nōb ᵊzzayyin aǧ-ǧilid w ǧǧīb-ill-u šafra w-ᵊzzayyn-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a12"
                TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>ʕugub-ma zzayyn-u ā w ǧǧīb-ill-u ʕādēne hniyye, al-ʕēš al-liban māmin? yōm-in ᵊtgūm ᵊddīr ʕēš al-liban, al-liban al-fōgāni.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a13"
                TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>ᵊtguff-u wakt-inn-u ygūm yfūr ʕa-l-ʕēš, ᵊtguff-u haḏāk ak… kull-u tguff-ull-ič mālāt hāḏi. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a14"
                TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>w ʕugub-ma tguff-u w-ᵊtḥuṭṭ-u ʕād ᵊbgaḷb-u, ᵊtbaṛṛd-u w-ᵊtḥuṭṭ-u bgaḷb-u, ī!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a15"
                TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>ᵊtḥuṭṭ ʕalē-´ ᵊqṭēmit miliḥ w-ᵊtḥuṭṭ-u bgaḷb-u, w-ᵊtxallī-´.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a16"
                TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>w təbəšṭ-u min fōg [fōk]. min ᵊšḥa… al… aš-šaḥam al bī-´ min fōg. āh… al-ᵊhniyye al bī-´ al-laḥam al bī-´, aš-šaḥam al bī-´ kull-u tuṭ… tuṭluʕ-u min fōg, hā, ī!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a17"
                TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts34">
                <ANNOTATION_VALUE>ā, w tugḏ̣ub ʕādēne ǧǧīb an-nōba hniyye l-ʕēš, ᵊtḥuṭṭ bī-´ mn-… l-ʕēš yḏ̣all bī-´ nahāṛēn ṯalāṯ,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a18"
                TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>w-ᵊtgūm zād uxṛa txarrṭ-u w-ᵊtḥuṭṭ-u ǧawwa ḥǧart-in čibīre lummunn-u-ma trūḥ mayyt-u, maṣl-u balā yrūḥ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a19"
                TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>aw ʕugub-ma yrūḥ maṣl-u malā trūḥ ᵊǧǧīb guṭmut hal-ᵊgdēd ᵊgṭēmit dibis,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a20"
                TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
                <ANNOTATION_VALUE>w-ad-dibis haḏāk ysāwi ysāwi, ad-dibis dibs-in ḥilu, ad-dibis āāā. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a21"
                TIME_SLOT_REF1="ts43" TIME_SLOT_REF2="ts44">
                <ANNOTATION_VALUE>dibis falōṭi dibs al-ʕinab.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a22"
                TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts46">
                <ANNOTATION_VALUE>ᵊǧǧīb dibis al-ʕinab awwal fāl ᵊssāwi šarbāt, ᵊssāwi šarbāt w tḥuṭṭ-u tḥuṭṭ-u bgaḷb-u. yḏ̣all ᵊbgaḷb-u ʕašər tiyyām xaməsṭaʕaš yōm, haš-šarbāt.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a24"
                TIME_SLOT_REF1="ts47" TIME_SLOT_REF2="ts49">
                <ANNOTATION_VALUE>aš-šaʕar yḏ̣all min fōg, haḏāk min ǧawwa </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a25"
                TIME_SLOT_REF1="ts50" TIME_SLOT_REF2="ts52">
                <ANNOTATION_VALUE>lā, yḏ̣all ʕašər tiyyām xaməsṭaʕaš yōm yḏ̣all ad-dibis ᵊbgaḷb-u, aš-šarbāt.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a26"
                TIME_SLOT_REF1="ts53" TIME_SLOT_REF2="ts54">
                <ANNOTATION_VALUE>w-ᵊtqassl-u mā… b-aš-šarbāt ᵊtqassl-u tnaḏ̣ḏ̣f-u. w-ᵊǧǧīb-u ʕala ʕala ḥarf ᵊhniyye ḥadīde, ʕala ḥarf al-ᵊxšibe</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a27"
                TIME_SLOT_REF1="ts55" TIME_SLOT_REF2="ts56">
                <ANNOTATION_VALUE>ʕāmūd ǧǧīb-il-he wudd w hīčiḏ tuqurb-u tilwī-´.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a28"
                TIME_SLOT_REF1="ts57" TIME_SLOT_REF2="ts58">
                <ANNOTATION_VALUE>tilwī-´ lummun tā trūḥ minn-u al-mayye, ᵊtrūḥ minn-u al-mayye w-an-nōba tgūm tuṭbax-ill-u dibis, </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a29"
                TIME_SLOT_REF1="ts59" TIME_SLOT_REF2="ts60">
                <ANNOTATION_VALUE>tuṭbax-ill-u dibis w-ᵊtḥuṭṭ ᵊḥbēbāt miliḥ ᵊtḥuṭṭ tuṭbax-ill-u dibis ᵊtḥuṭṭ-u bgaḷb-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a31"
                TIME_SLOT_REF1="ts61" TIME_SLOT_REF2="ts62">
                <ANNOTATION_VALUE>ā, ad-dibis tuṭbax-u fōr fōrēn ᵊtguff al-qaḏ̣ab al bī-´ kull-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a32"
                TIME_SLOT_REF1="ts63" TIME_SLOT_REF2="ts64">
                <ANNOTATION_VALUE>w-al-bāǧi tbarrd ad-dibis w-ᵊtḥuṭṭ-u bgaḷb-u. yḏ̣all ᵊbgaḷb-u ʕašər tiyyām, xaməsṭaʕaš yōm lummun yqadi ḥamar.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a33"
                TIME_SLOT_REF1="ts65" TIME_SLOT_REF2="ts66">
                <ANNOTATION_VALUE>w-ᵊtḥuṭṭ bī-´ ʕasal, ᵊǧǧīb guṭmut ʕasal hīčiḏ tuṭbax ʕasal w-ᵊtḥuṭṭ ᵊbgaḷb-u, b-aǧ-ǧilid.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a34"
                TIME_SLOT_REF1="ts67" TIME_SLOT_REF2="ts68">
                <ANNOTATION_VALUE>al-ǧilid yṣīr aḥamar aḥamar miṯil miṯil al-bōyaq. ā ʕugub yutrus yqadi iš-midrī-ni. ššidd īdē-´ min hēn ššidd-u min hēn tugḏ̣ub-u min ṭīz-u zādēne zādēne b-al-ibre txayyṭ-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a35"
                TIME_SLOT_REF1="ts69" TIME_SLOT_REF2="ts70">
                <ANNOTATION_VALUE>ʕugub-ma txayyṭ-u zād ᵊtlimm-u ʕala bʕaḏ̣-u w-ᵊtḥuṭṭ-u ʕala hniyye w-ᵊššidd-u qarəb mitīn, w šiddi īdē-´ zād al-arbaʕ ᵊtšidd-hin.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a36"
                TIME_SLOT_REF1="ts71" TIME_SLOT_REF2="ts72">
                <ANNOTATION_VALUE>ʕugub al-arbaʕ īdēn zād ᵊššidd-hin yḏ̣all bass iṯum-ha, iṯum an-nʕaǧa, rgubit-he.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a37"
                TIME_SLOT_REF1="ts73" TIME_SLOT_REF2="ts74">
                <ANNOTATION_VALUE>ā, w-ᵊtḥuṭṭ as-samin tuṭbax ʕādēne tdaḥḥǧ-ill-u inn-u tām yaʕni gāḏ̣ib zād ᵊtḥuṭṭ-il-he ḥbēbāt samin nahāṛēn ṯalāṯe bgaḷb-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a38"
                TIME_SLOT_REF1="ts75" TIME_SLOT_REF2="ts76">
                <ANNOTATION_VALUE>ᵊtxarrṭ as-samin ḏāk txarrṭ-u lummun lummun miššān tā yrūḥ al-miliḥ, tā yrūḥ ad-dibis, tā trūḥ al-ᵊhniyye al-ᵊḥmūḏ̣t al bī-´ aš-šī kull-he.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a39"
                TIME_SLOT_REF1="ts77" TIME_SLOT_REF2="ts78">
                <ANNOTATION_VALUE>ᵊtrudd ʕād uxṛa tuṭbax dibis w-ᵊtḥuṭṭ-u bgaḷb-u tḥuṭṭ-u bgaḷb-u samin. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a40"
                TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts80">
                <ANNOTATION_VALUE>ā w-ᵊtxallī-´ hāḏa aḏ̣-ḏ̣arif, hāḏa al yḥuṭṭūn bī-´ as-samin. yḏ̣all hāḏa xulūdi: xaməs sitt ᵊsnīn ʕašər ᵊsnīn mā yxarab.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a41"
                TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts82">
                <ANNOTATION_VALUE>han-nōb kull sine ḏ̣ḏ̣all ᵊǧǧīb bī-´ dibis tuṭbax w tḥuṭṭ ᵊbgaḷb-u, w ḏ̣ḏ̣all ᵊtḥuṭṭ bī-´ as-samin. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a42"
                TIME_SLOT_REF1="ts85" TIME_SLOT_REF2="ts86">
                <ANNOTATION_VALUE>qādi tā yṣīr yumušaq alle, alle ad-dibis zād ad-dibis tā ysāwi yumušaq, yḏ̣all yumušaq bī-´.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a43"
                TIME_SLOT_REF1="ts87" TIME_SLOT_REF2="ts88">
                <ANNOTATION_VALUE>wakt-in yiǧi al-gēḏ̣, mā ǧī al-gēḏ̣ ǧī (al-bard) al-gēḏ̣, al-ḥarr. ᵊtrūḥ ᵊǧǧīb hal-kuṯur ṣūs.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a45"
