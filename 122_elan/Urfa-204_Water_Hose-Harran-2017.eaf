                <ANNOTATION_VALUE>ʕugub-ma tḥuṭṭ-u b-al-wāwi ššidd-u ṣaġlam ᵊšididān-in zēn.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a54"
                TIME_SLOT_REF1="ts107" TIME_SLOT_REF2="ts109">
                <ANNOTATION_VALUE>tuqurb-u, ᵊtḥuṭṭ bī-´ tinikāt tiniktēn samin, yāq, tnike tiniktēn ᵊtḥuṭṭ </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a55"
                TIME_SLOT_REF1="ts111" TIME_SLOT_REF2="ts112">
                <ANNOTATION_VALUE>ē, samin awwali kull ačil-hum samin.</ANNOTATION_VALUE>
