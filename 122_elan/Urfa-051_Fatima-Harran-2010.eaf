    <TIER LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Corpus:Harran02">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
                <ANNOTATION_VALUE>ḥaḏ̣rati Fāṭma nahāṛ sāʕle abū-ha, gāyle: yā yāba, āni b-aǧ-ǧanne minhi ǧārt-i? yaʕni ǧārt-i b-aǧ-ǧanne minhi?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3"
                TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>gāyl-il-he: bint ᵊflān mart ᵊflān rāʕi, yaʕni flān ādami msammī-´ zād gāyil ᵊflān rāʕi, rāʕit bēt-u, haḏīč ǧārt-ič b-aǧ-ǧanne.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5"
                TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>neyse, ᵊmsāwiyye marak gāyle: arīd ašūf hāḏi, yaʕni bēš ᵊmqazniǧe, āni Fāṭmit an-nibiyye, marit ḥaḏ̣reti ʕAli... [xuḏī-he baččōl, xuḏī-he baččōl, abūy!]</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7"
                TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>ᵊšnōn ᵊmqazniǧe? gāyle yaʕni bsāgt-i b-aǧ-ǧanne ǧārt-i yaʕni bēš ᵊmqazniǧe?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>ᵊmsāwye marak gāyle: d-arūḥ ašūf-ha. d-arūḥ ašūf-ha. ǧāye ʕalē-he, ᵊddugg al-bāb sāʕle flān rāʕi, minhu bēt-u?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>dugg al-bāb! dugg al-bāb yā dāgge bāb-he ta-ngūl, hāḏi ǧāyit-he ʕa-l-bāb, gāyle: xayye! minhi inti? gāyle: waḷḷa, āni Fāṭmit an-nibiyye w ǧīt ašūf-ič hīčiḏ azūr-ič.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a12"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>gāyle: waḷḷa āni ǧawwa mā_gdar āxḏ-ič. – ʕalēš, gāyle: mā tāxḏīn-ni? gāyle: rāʕi bēt-i, ta-ngūl ʕAli wēya Maḥmūd wēya al ism-u mā_ʕarf-u, </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a15"
                TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>sāriḥ b-al-qanam b-aǧ-ǧōl, b-al-qanam. w in māx… tā yiǧi m-aǧ-ǧōl w āxuḏ minn-u izin w ʕugub baʕdēn āxḏ-ič ǧawwa. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a17"
                TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>in mā xaḏēt min ᵊzlimt-i izin, mā_ḥuṭṭ-ič mā_fukk-l-ič al-bāb, m_āxḏ-ič ǧawwa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a19"
                TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>gāyle: tamām! ēmat aǧi? gāyle: bāčir taʕāli! tss, gāyle: tamām! </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a21"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>bass ᵊmdaḥḥǧe al-ḥurma mart ar-rāʕi mīhi ǧāʕde ba… ǧawwa, ḥāṭṭa al-mayye w-al-xubuz b-aš-šamis, b-al-ḥārra b-ač-čōl, al-mayye ḥāṭṭit-he b-aǧ-ǧidriye b-al-ḥārra. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a23"
                TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>w ḥāṭṭa l-ᵊhniyye al-xubuz b-ač-čōl rāmīt-u, al-xubuz. mī sāʕlit-he ṭabi mī xāšše ǧawwa rāyḥe ʕala bēt-he, Fāṭmit an-nibiyye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a25"
                TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>rāyḥe ṯāni nahāṛ, ḥāṭṭa al-Ḥasan ᵊb-ḥuḏ̣un-he, mū al-Ḥasan w-al-ᵊḤsēn ᵊzġār tōm-ha.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a26"
                TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>šāyle al-Ḥa… gāyle: āni arīd alyōm al-Ḥasan ad-āxḏ al-Ḥasan ᵊbsāgt-i, w-al-ᵊḤsēn ᵊmxallīt-u b-al-bēt.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a29"
                TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>šāyle l-Ḥasan ᵊb-xuḏ̣un-he, w ǧāye ʕalē-he, duggi l-bāb uxṛa, ṯāni nahāṛ. fūti xayye! gāyle: waḷḷa ǧīt-ič al mū gilti bāčir taʕāli? xaḏēti izin min ᵊzlimt-ič tā tāxḏīn-ni ǧawwa?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a31"
                TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>hāḏa minhu? gāyle, al ᵊb-ḥuḏ̣n-ič haḏa? – gāyle: waḷḷa wlēd-i al-Ḥasan. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a33"
                TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts34">
                <ANNOTATION_VALUE>ē gāyle: yā uxt-i! āni xaḏēt izin ličče li-šaxṣ-ič. mā xaḏēt izin l-al ᵊb-ḥuḏ̣n-ič, hāḏa mā xaḏēt-l-u izin. albāriḥ mā ǧibtī-´, alyōm mā_gdar āxḏ-ič ᵊb-ḥuḏ̣n-ič [al-ʕaǧi].</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a35"
                TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>gāyle: šnōn asāwi? gāyle: rūḥi alyōm zād! bāčir, ī, alyōm gāyle: inti, albāriḥ ǧīti, inti mā ǧibtī-´ b-ḥuḏ̣n-ič. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a37"
                TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>uxḏī-´ rūḥi ʕala bēt-ič bāčir taʕāli! āni tā d-āxuḏ izin miššān wlēd-ič al ᵊb-ḥuḏ̣n-ič, al-Ḥasan ḏe. bāčir taʕāli ʕalay-ye!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a39"
                TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
                <ANNOTATION_VALUE>gāyle: tamām! rāyḥe uxṛa Fāṭmit an-nibiyye ṣābūṛa yaʕni, rāyḥe ṯāni nahāṛ uxṛa, ṯāliṯ nahāṛ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a41"
                TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts42">
                <ANNOTATION_VALUE>an-nōba Fāṭme, ḥuṭṭi al-Ḥasan w-al-ᵊḤsēn ᵊb-ḥuḏ̣n-ič ᵊṯnēne w ǧāybit-hum. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a43"
                TIME_SLOT_REF1="ts43" TIME_SLOT_REF2="ts44">
                <ANNOTATION_VALUE>uxṛa duggi l-bāb, mdaḥḥǧe gāyle: yā uxt-i!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a45"
                TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts46">
                <ANNOTATION_VALUE>šinhu? gāyle: waḷḷa ǧīt-ič. ište ʕala hniyye, ī gāyle albāriḥ ǧibti hāḏa wāḥad ᵊb-ǧēb-ič ᵊb-ḥuḏ̣n-ič w-alyōm ṣāraw ᵊṯnēne. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a47"
                TIME_SLOT_REF1="ts47" TIME_SLOT_REF2="ts48">
                <ANNOTATION_VALUE>āni xaḏēt il-wāḥad izin min ᵊzlimt-i w-inti lyōm ǧibti aṯ-ṯnēne. uxṛa mā_gdar āxḏ-ič ǧawwa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a49"
                TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts50">
                <ANNOTATION_VALUE>rūḥi tā al-muġrib ᵊzlimt-i yiǧi w-agul-l-u: Fāṭmit an-nibiyye b-ḥuḏ̣un-he l-Ḥasan w-al-ᵊḤsēn āxḏ-il-hum izin tā bāčir aḥuṭṭ-ič.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a51"
                TIME_SLOT_REF1="ts51" TIME_SLOT_REF2="ts52">
                <ANNOTATION_VALUE>“Go until my husband returns in the evening and I will tell him: ‘Fatimah, the daughter of the prophet, she has Hasan and Husayn in her lap.’ So, I can get permission for them to let you in tomorrow.”</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a53"
                TIME_SLOT_REF1="ts53" TIME_SLOT_REF2="ts54">
                <ANNOTATION_VALUE>yaw inti gaʕad tiǧī-č Fāṭmit an-nibiyye l-al-bāb w nahāṛ ᵊtgūlīn ᵊb-ḥuḏ̣n-ič wāḥad yaw xallī-he. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a55"
                TIME_SLOT_REF1="ts55" TIME_SLOT_REF2="ts56">
                <ANNOTATION_VALUE>yēlōn ᵊbsāgit-he kull al-midīne ḥuṭṭī-he ǧawwa! lā ʕād ᵊtruddīn Fāṭmit an-nibi!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a57"
                TIME_SLOT_REF1="ts57" TIME_SLOT_REF2="ts58">
                <ANNOTATION_VALUE>gāyle: tamām yā ax-i! ǧāye ṯāni nahāṛ an-nōba ᵊb-ḥuḏ̣un-he wāḥad w gāyle: xayye, daxīl-ič xušši xušši! </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a59"
                TIME_SLOT_REF1="ts59" TIME_SLOT_REF2="ts60">
                <ANNOTATION_VALUE>xaḏēt il-kull ba… bidīt-ič izin. ᵊzlimt-i ʕzil ʕzil ʕalay-ye. ḥāṭṭit-he ǧawwa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a61"
                TIME_SLOT_REF1="ts61" TIME_SLOT_REF2="ts62">
                <ANNOTATION_VALUE>Fāṭmit an-nibiyye mdaḥḥǧe, al-ḥurma ǧawwa ti-tugʕud ǧawwa w hāḏi b-al-ḥōš.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a63"
                TIME_SLOT_REF1="ts63" TIME_SLOT_REF2="ts64">
                <ANNOTATION_VALUE>timši, ḥawš! kūš! ḥawš! čiš! hō! brrr! tisraḥ sārḥe b-al-ḥōš māmiš qanam, qanam māmiš. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a65"
                TIME_SLOT_REF1="ts65" TIME_SLOT_REF2="ts66">
                <ANNOTATION_VALUE>w gāyle: xayye, inti ḥarām iš-ǧaʕad ᵊssāwīn? qanam māmiš! ǧōl māmiš, iš-ǧaʕad ᵊssāwīn ḥawš w kūš w qōf w… </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a66"
                TIME_SLOT_REF1="ts67" TIME_SLOT_REF2="ts68">
                <ANNOTATION_VALUE>gāyle: yā uxt-i, āni zlimt-i sāriḥ b-al-qanam alḥaz b-aǧ-ǧbile w b-aš-šamis.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a67"
                TIME_SLOT_REF1="ts69" TIME_SLOT_REF2="ts70">
                <ANNOTATION_VALUE>w yišrab mayyt-in ḥārra w yākul xubz-in yābis w kull-u ḥēš w kūš. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a71"
                TIME_SLOT_REF1="ts71" TIME_SLOT_REF2="ts72">
                <ANNOTATION_VALUE>w-āni hēne yǧūz ʕalay-ye āni agʕud b-aḏ̣-ḏ̣lāl w-ačassiʕ hīčiḏ ati-atig ᵊhniyye atidallal. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a73"
                TIME_SLOT_REF1="ts73" TIME_SLOT_REF2="ts74">
                <ANNOTATION_VALUE>āni zād huwwa sāriḥ qādi w-āni sārḥe b-al-ḥōš asāwi miṯl-u tā yṣīr ʕalay-ye zēn. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a74"
                TIME_SLOT_REF1="ts75" TIME_SLOT_REF2="ts76">
                <ANNOTATION_VALUE>šūfi mayyt-i al-mayye hāḏi gāyle w huwwa yišrab mayyt-in ḥārra āni zād ašrab mayyt-in ḥārra.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a75"
                TIME_SLOT_REF1="ts77" TIME_SLOT_REF2="ts78">
                <ANNOTATION_VALUE>w huwwa yišrab mayyt-in ba… xubz-in yābis yākul, āni zād ākul xubz-in yābis, āni m_ākul xubz-in layyin.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a76"
                TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts80">
                <ANNOTATION_VALUE>ᵊzlimt-i b-ač-čōl iš-ma ysāwi āni miṯl-u asāwi. āni mā yǧūz ʕalay-ye tā ačassiʕ b-aḏ̣-ḏ̣lāl. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a81"
                TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts82">
                <ANNOTATION_VALUE>hā! Fāṭmit an-nibiyye gāyle: demek abū-ye ḥaqqli, min hāḏa abū-ye gāl-l-ak gāl-l-i hāḏi ǧārt-ič b-aǧ-ǧanne demek ki ᵊb-ʕamal-he. salāmt-ak w tʕīš! </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LINGUISTIC_TYPE_REF="subdevision" PARENT_REF="Corpus:Harran02" TIER_ID="Translation02">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2" ANNOTATION_REF="a1">
                <ANNOTATION_VALUE>One day, her holiness Fatimah asked her father saying, “O my father, who will be my neighbour in paradise? Who will be my neighbour in paradise?”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4" ANNOTATION_REF="a3">
                <ANNOTATION_VALUE>He said to her, “The daughter of so-and-so, the wife of so-and-so,” He named that certain person, that certain man. His wife will be your neighbour in Paradise.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a6" ANNOTATION_REF="a5">
                <ANNOTATION_VALUE>Anyways, she became curious and said, “I want to meet her. What did she do to deserve this? I am the Fatimah of the prophet, the wife of his holiness Ali.” [to his elder daughter: Take her outside, my daughter!]</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a8" ANNOTATION_REF="a7">
                <ANNOTATION_VALUE>How has she deserved this? I mean, she will be my neighbour in paradise. How did she attain this?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a10" ANNOTATION_REF="a9">
                <ANNOTATION_VALUE>She had become curious and said, “I want to go and see her.” So, she went to her and knocked on the door. She had asked about the so-and-so and where his house was.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a13" ANNOTATION_REF="a11">
                <ANNOTATION_VALUE>She knocked on the door, let’s say she knocked on the door of her house. The woman came to the door and asked, “Who are you, sister?” She replied, “In fact, I am Fatimah, the (daughter) of the prophet, and I came to see you, to visit you.”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a14" ANNOTATION_REF="a12">
                <ANNOTATION_VALUE>She said, “By God, I cannot let you in.” “Why?” she said, “You won’t accept me?” She replied, “My husband…” let’s say (he was called) Ali or Mahmud; whatever his name was, I don’t know.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a16" ANNOTATION_REF="a15">
                <ANNOTATION_VALUE>“He went out to graze the sheep on the pasture; he is with the sheep. So, only when he returns from the pasture and I get permission from him, only then will I be able to welcome you inside. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a18" ANNOTATION_REF="a17">
                <ANNOTATION_VALUE>If I do not get permission from my husband, I will not let you inside, and I cannot welcome you.”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a20" ANNOTATION_REF="a19">
                <ANNOTATION_VALUE>She said, “Alright. When should I come again?” She replied, “Come tomorrow!” She said, “Alright."</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a22" ANNOTATION_REF="a21">
                <ANNOTATION_VALUE>But she noticed that the woman, the shepherd’s wife, was not sitting inside the house. Instead, she had placed water and bread under the sun, outside in the heat. She had placed the water in the pot in the heat.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a24" ANNOTATION_REF="a23">
                <ANNOTATION_VALUE>She had placed the bread outside; she had had put the bread outside. Of course, she didn’t ask her and didn’t go inside. Fatimah, the daughter of the prophet, went back to her house.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a27" ANNOTATION_REF="a25">
                <ANNOTATION_VALUE>The next day she went there again having placed Hasan in her lap. Hasan and Husayn were young; they were still toddlers, her twins.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a28" ANNOTATION_REF="a26">
                <ANNOTATION_VALUE>She had taken Hasan and said, “Today, I want to take Hasan with me.” She left Husayn at home.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a30" ANNOTATION_REF="a29">
                <ANNOTATION_VALUE>She carried Hasan in her lap and approached her again, knocked on the door the other day and (was expected to) enter. She said, “By God, I came to you again. Didn’t you say, ‘Come tomorrow!’ Have you got permission from your husband to let me in?”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a32" ANNOTATION_REF="a31">
                <ANNOTATION_VALUE>“Who is this?” she asked. “The one in your lap?” – “He is my son Hasan,” she replied.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a34" ANNOTATION_REF="a33">
                <ANNOTATION_VALUE>She said, “Sister, I have permission only for you alone. I have no permission for the one in your lap. I haven’t got permission for him. You didn’t bring him yesterday, so I cannot take the one in your lap, the child.”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a36" ANNOTATION_REF="a35">
                <ANNOTATION_VALUE>She said, “What should I do?” The woman replied, “Go away today as well and come back tomorrow!” She said, “When you came yesterday you didn’t bring the one in your lap.”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a38" ANNOTATION_REF="a37">
                <ANNOTATION_VALUE>“Take him and go home, then come agaub tomorrow! I will get permission for your son, the one in your lap, Hasan. Come to me tomorrow!”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a40" ANNOTATION_REF="a39">
                <ANNOTATION_VALUE>She said, “Alright!” Fatimah, the daughter of the prophet, went there again; she was patient. She went the next day again there; it was the third day.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a42" ANNOTATION_REF="a41">
                <ANNOTATION_VALUE>his time, Fatimah placed both Hasan and Husayn in her lap and brought them with her.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a44" ANNOTATION_REF="a43">
                <ANNOTATION_VALUE>She knocked on the door again. The woman looked and said, “O sister!”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a46" ANNOTATION_REF="a45">
                <ANNOTATION_VALUE>“What?” she said. “I came to you again as we agreed.” The woman replied, “Yes, but yesterday you brought one in your lap and today they have become two.”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a48" ANNOTATION_REF="a47">
                <ANNOTATION_VALUE>“I have permission from my husband for one only. But today you have brought two. So, once again, I cannot take you inside.”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a50" ANNOTATION_REF="a49">
                <ANNOTATION_VALUE>“Go until my husband returns in the evening and I will tell him: ‘Fatimah, the daughter of the prophet, she has Hasan and Husayn in her lap.’ So, I can get permission for them to let you in tomorrow.”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a52" ANNOTATION_REF="a51">
                <ANNOTATION_VALUE>Fatimah, the daughter of the prophet, went away. Her husband returned at sunset, and she said to him, “Today, she came with two (children) in her lap as well.” He said, “Oh, you crazy one!”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a54" ANNOTATION_REF="a53">
                <ANNOTATION_VALUE>“Fatimah, the daughter of the prophet, comes to your door, and one day you say there is one in her lap and such! Let her in!”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a56" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE>“Even if the whole city is with her, let her in!” Do not turn away Fatimah, the daughter of the prophet, anymore!”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a58" ANNOTATION_REF="a57">
                <ANNOTATION_VALUE>She said, “Alright!” The next day she came again and that time she only had one in her lap. She said to her, “My sister, please come in, come in, come in!”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a60" ANNOTATION_REF="a59">
                <ANNOTATION_VALUE>I have permission for everyone from my husband, and he even got angry with me.” She took her inside.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a62" ANNOTATION_REF="a61">
                <ANNOTATION_VALUE>Fatimah, the daughter of the prophet, looked and (expected) the woman sitting inside. (But) she was in the courtyard of the house.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a64" ANNOTATION_REF="a63">
                <ANNOTATION_VALUE>She was walking around saying, “Housh, koosh, housh, chish, ho, brr!” She was pretending to graze the sheep in the courtyard of the house, although there were no sheep there.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a68" ANNOTATION_REF="a65">
                <ANNOTATION_VALUE>She said, “My sister, what are you doing? There are no sheep! There is no pasture here. What are you doing, saying ‘Housh and koosh and qof and...?”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a69" ANNOTATION_REF="a66">
                <ANNOTATION_VALUE>She said, “My sister, my husband is grazing the sheep; he is now in the mountains, under the sun.”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a70" ANNOTATION_REF="a67">
                <ANNOTATION_VALUE>“And he must drink hot water and eat dry bread and always has to say, ‘Hesh and koosh!’”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a72" ANNOTATION_REF="a71">
                <ANNOTATION_VALUE>“I am here. Would it be fair for me to sit in the shade, rest in my seat like this, and pamper myself?”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a77" ANNOTATION_REF="a73">
                <ANNOTATION_VALUE>“He is grazing the sheep over there, and I am grazing them here in the courtyard of the house. I do the same so that it will get good (reward) for me.”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a78" ANNOTATION_REF="a74">
                <ANNOTATION_VALUE>She said, “Look at my water! This water. He drinks hot water, and I too drink hot water.”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a79" ANNOTATION_REF="a75">
                <ANNOTATION_VALUE>“He drinks water with... he has only dry bread to eat. And so, I eat dry bread too. I do not eat soft bread.”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a80" ANNOTATION_REF="a76">
                <ANNOTATION_VALUE>“My husband is outside on the pasture, and everything he does, I do it here as well. I should not be sitting comfortably in the shade.”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a82" ANNOTATION_REF="a81">
                <ANNOTATION_VALUE>“Ha!” Fatimah, the daughter of the prophet, said, “This means that my father was right. For this reason, my father said to me, “She will be your neighbour in paradise.” As a reward for her actions. God bless you!</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <LINGUISTIC_TYPE GRAPHIC_REFERENCES="false"
        LINGUISTIC_TYPE_ID="default-lt" TIME_ALIGNABLE="true"/>
    <LINGUISTIC_TYPE CONSTRAINTS="Symbolic_Subdivision"
        GRAPHIC_REFERENCES="false" LINGUISTIC_TYPE_ID="subdevision" TIME_ALIGNABLE="false"/>
