    <TIER LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Corpus:Harran06">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
                <ANNOTATION_VALUE>huṃṃa rabəʕ w šīxān iṯnēne, mitrābʕīn wāḥad rāyiḥ ʕa-l-mišarrǧi wāḥad ʕa-l-miqarrbi, </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a2"
                TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>w fāyit-he ᵊmrūr zimān, yōm-in fāyit-he ᵊmrūr zimān, fāyit-he ᵊmrūr zimān hāḏa wāḥad min-hum yaʕni ǧāy ʕala wāḥad, xāṭir.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5"
                TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>yōm-inn-u ǧāy ʕalē-´ xāṭir, w gāyim aṣ-ṣubuḥ ydugg al-ᵊghawa w-al-ma… tiǧi w-al-mille w tihni w yʕazzim</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7"
                TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>w aǧ ǧāy-u al-xāṭir ugbāḷ bēt ahál-u, bēt hāḏa rāʕi l-bēt, ugbāḷ-u bēt ʕamām-u w ʕid-hum ᵊbnayyt-in zēne.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>ygūm rabīʕ-u al-xāṭir w yrīd al-ᵊbnayye yʕašig-he, yōm-in ʕāšiǧ al-ᵊbnayye, w huwwa w wiyyā-ha yḏ̣all awwali al-xāṭir šahar šharēn yḏ̣all b-al-bēt.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>gāyme al-ᵊbnayye w ǧāyitt-u ʕa-l-ᵊhniyye, ʕa-č-čāsir ʕind al-ᵊhniyye, maḏ̣īfat walda ʕamm-he.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a13"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>yōm-in ytaʕāšarūn w ytahāraǧūn lummun miṣibḥe ad-dinye w nāymīn, huwwa rabīʕ-u w binta ʕamm-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a14"
                TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>yōm-inn-u ḥāss ʕala ghawa tā yšubb al-ᵊghawa yōm-in ydaḥḥiǧ binta ʕamm-u w rabīʕ-u nāymīn ǧimīʕ,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a17"
                TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>gāyim hāḏa ugḏ̣ub as-sēf w gāyim yuwarrič al-bēt, ygaṭṭiʕ b-al-ᵊhniyye yā walu yā walu, al-ᵊhniyye gāmat anzāl tiǧi ʕa-l-ᵊghawa tā ttigahwa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a19"
                TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>w huwwa gāyim ygaṭṭiʕ b-al-bēt, tā šlōn yrīd yiǧʕid-he tinhazim.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a21"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>w gā… aš-šēx ᵊnhibal, aš-šēx ᵊnhibal dākkīn ʕalē-´, hāḏi hāǧse al-ḥiss umurgi w-ᵊinhazmi.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a23"
                TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>yōm-in-he minhazme gāḏ̣bīn-u ʕaglān ǧaʕad w uxṛa miʕliǧ al-ᵊghawa mḥaḏ̣ḏ̣ir-he,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a25"
                TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>šārbīn al-ᵊghawa, huwwa w uxṛa rabīʕ-u, w haḏīč binta ʕamm-u hāḏi ar rāyid-he.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a27"
                TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>ḏ̣āll ᵊmrūr zimān ʕind-u gāyil: yā xayyo āni arīd arūḥ. hū mzaḥḥm-ill-u yaʕni mənṭi zād al yrīd-he w rāyiḥ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a29"
                TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>rāyiḥ ʕal ahál-u, yōm-in rāyiḥ ʕal ahal-u, ḏ̣āll ᵊmrūr zimān, hāḏa abu binta ʕamm, māyle bī-´ ad-dinye mā ḏ̣āll ʕind-u lā ḥalāl wala māḷ wala mihni.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a31"
                TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>ḏ̣āll faǧri ṣāyir ᵊb-nōbt-in nōba mā ʕind-u. gāylitt-ill-u mart-u: yā zlime, mā-l-ak b-ad-dinya ṣadīǧ mā-l-ak rabīʕ mā-l-ak ḥade?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a33"
                TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts34">
                <ANNOTATION_VALUE>tā_rīd arūḥ, arūḥ ʕalē-´ tā nrūḥ ᵊnʕīš, bass ᵊnʕīš, mā-rīd šī. gāyil: ī waḷḷa liyye b-al-warča aš-šarǧi liyya rabīʕ, w-ᵊrrīd ᵊrrūḥ niṭulb-u tā nšūf ᵊšnōn.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a35"
                TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>ᵊmšayyil ʕala ʕind-u nāga wəḥde ᵊmšayyil al-bēt w rāyiḥ, rāyḥe aš-šūxiyye zād minn-u. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a37"
                TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>yōm-in ǧāy ʕala rabīʕ-u: ahlēn w sahlē, inn-u gāyil: waḷḷa yā xayyo, hīčiḏ al-ḥāṣile ǧarat.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a39"
                TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
                <ANNOTATION_VALUE>w ǧāy ʕind-u b-al-bēt w gūm mn-aṣ-ṣubḥiyye w āmir al-ʕurbān ᵊb-nōba, </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a41"
                TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts42">
                <ANNOTATION_VALUE>kull bēt šugga, yilummū-l-u šgāg w yxayyṭūn-hin w yibnūn bēt miṯil bēt-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a43"
                TIME_SLOT_REF1="ts43" TIME_SLOT_REF2="ts44">
                <ANNOTATION_VALUE>w-bi... kull bēt nāga w nʕaǧe w abu ašʕal ʕurbān al ḥawālē-´, hū šēx al-ʕašīre. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a45"
                TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts46">
                <ANNOTATION_VALUE>lāmmī-l-u ḥalāl ᵊb-gadd ḥalāl-u w rəʕyān-u w ʕizbān-u, w-ᵊmsāwī-l-u bēt, hāḏa aṣ-ṣubuḥ ysāwi l-ᵊghawa w haḏāk al-muqrib ysāwī-he. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a47"
                TIME_SLOT_REF1="ts47" TIME_SLOT_REF2="ts50">
                <ANNOTATION_VALUE>ᵊmǧāblīn ᵊbyūt-hum, </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a48"
                TIME_SLOT_REF1="ts51" TIME_SLOT_REF2="ts52">
                <ANNOTATION_VALUE>ugbāḷ baʕaḏ̣-hum, w fāyit az-zimān al-ʕiǧyān w yilʕabūn ᵊbsāgit ʕiǧyān aš-šēx.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a53"
                TIME_SLOT_REF1="ts53" TIME_SLOT_REF2="ts54">
                <ANNOTATION_VALUE>al-awwal aš-šēx al b-ad-dīre, l-al-lēl yilʕabūn w b-ač-čōl w gūmu w-al-ʕiǧyān ḏōlak yiǧūn ynāmūn ʕind umm-hum, ʕind aǧ-ǧāy.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a55"
                TIME_SLOT_REF1="ts55" TIME_SLOT_REF2="ts56">
                <ANNOTATION_VALUE>yōm-in b-al-lēl nāyim b-al-frāš rabʕ-u, yōm-in ǧāy m-al-ᵊghawa huwwa, hāḏa aš-šēx yōm-inn-u ǧāy win ᵊzlime nāyim b-ᵊfrāš-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a57"
                TIME_SLOT_REF1="ts57" TIME_SLOT_REF2="ts58">
                <ANNOTATION_VALUE>gāyil: hā, mart-i mṣāḥbe. gūm uṭluʕ sēf-ak  w lukk kallt-u. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a59"
                TIME_SLOT_REF1="ts59" TIME_SLOT_REF2="ts60">
                <ANNOTATION_VALUE>lā lā! yōm-in ḥāsse gāyilt-ill-u: lā yā wal yā qādi al-baxat hāḏa flān wald ᵊflān wald aš-šēx. gāyil: iš-mi drī-ni.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a61"
                TIME_SLOT_REF1="ts61" TIME_SLOT_REF2="ts62">
                <ANNOTATION_VALUE>ši-nsāwi ši-nsāwi, gāl: ši-nsāwi? rūḥ nʕallm aš-šēx, ʕallim aš-šēx. | IB: ī, rūḥ ʕallm-u! | HA: gāyim w rāyiḥ ᵊmʕallm-u. gāyil: xayyo hīčiḏ w hīčiḏ al-misʕale.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a65"
                TIME_SLOT_REF1="ts65" TIME_SLOT_REF2="ts66">
                <ANNOTATION_VALUE>gāyim w rāyiḥ ᵊmʕallm-u. gāyil: xayyo hīčiḏ w hīčiḏ al-misʕale.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a67"
                TIME_SLOT_REF1="ts67" TIME_SLOT_REF2="ts68">
                <ANNOTATION_VALUE>ligēt-u nāyim b-ᵊfrāš, ʕiǧyān-i ʕinid mart-i w ḏibaḥt-u. gāyil: rūḥ luff-u b-šālt-u, w-uxḏ-u b-arḏ̣-in yilʕabūn al-ʕiǧyān w irm-u, </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a69"
                TIME_SLOT_REF1="ts71" TIME_SLOT_REF2="ts72">
                <ANNOTATION_VALUE>abū-´ hāḏa. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a70"
                TIME_SLOT_REF1="ts75" TIME_SLOT_REF2="ts76">
                <ANNOTATION_VALUE>b-arḏ̣-in yilʕabūn al-ʕiǧyān irm-u w xall-u! hāḏa, lāffīn-u w rāmīn-u b-arḏ̣-in yilʕabūn al-ʕiǧyān.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a77"
                TIME_SLOT_REF1="ts77" TIME_SLOT_REF2="ts78">
                <ANNOTATION_VALUE>hāḏa ǧāʕid aṣ-ṣubuḥ šābb al-ᵊghawa, mā ʕala… </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a78"
                TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts82">
                <ANNOTATION_VALUE>mā ysōlif w ǧat an-nazil, ǧat ʕa-l-ᵊghawa ytigahwa.  </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a83"
                TIME_SLOT_REF1="ts83" TIME_SLOT_REF2="ts84">
                <ANNOTATION_VALUE>yōm-in ymurrūn milʕab al-ʕiǧyān win az-zlime hāḏa malfūf b-aš-šāle w maḏbūḥ ydaḥḥǧūn inn-u wald aš-šēx.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a85"
                TIME_SLOT_REF1="ts85" TIME_SLOT_REF2="ts86">
                <ANNOTATION_VALUE>yiǧūn ʕa-š-šēx ygūlū-l-u, ytišā… bēnāt-hum ytišāwarūn ᵊšnōn ᵊngūl l-aš-šēx?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a87"
                TIME_SLOT_REF1="ts87" TIME_SLOT_REF2="ts88">
                <ANNOTATION_VALUE>gāyil: ḥarām ʕid-kum wišāwīš w hariǧ w šakle ʕallmū-ni b-al-misʕale šinhi?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a89"
                TIME_SLOT_REF1="ts89" TIME_SLOT_REF2="ts90">
                <ANNOTATION_VALUE>gāylīn: ši-nʕallm-ak mū ʕilim xēr. marrēne b-arḏ̣-in yilʕabūn al-ʕiǧyān w ligēne ᵊflān maḏbūḥ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a91"
                TIME_SLOT_REF1="ts91" TIME_SLOT_REF2="ts92">
                <ANNOTATION_VALUE>ē gāyil: maḏbūḥ rūḥu hātū-´! ǧāybīn-u mqasslīn-u mčaffnīn-u dāmmīn-u w gāyil: ʕalē-kum yā ʕurbān kull wāḥad nāga,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a93"
                TIME_SLOT_REF1="ts93" TIME_SLOT_REF2="ts94">
                <ANNOTATION_VALUE>mā_dri čam ᵊnʕaǧe w trūḥūn tinṭūn-hin l-axū-ye, ʕa-rabīʕ-i. lāmmīn al-ʕurbān ᵊb-nōba w ǧāybīn manṭīn-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a95"
                TIME_SLOT_REF1="ts95" TIME_SLOT_REF2="ts96">
                <ANNOTATION_VALUE>fāyit hāḏa čam sine w rāḥil, gāymīn ʕād bēnāt-hum yihnūn ytisōlafūn, tā yrīd yrūḥūn ytiṭālabūn, ar-rabəʕ. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a99"
                TIME_SLOT_REF1="ts98" TIME_SLOT_REF2="ts100">
                <ANNOTATION_VALUE>huwwa w rabīʕ-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a101"
                TIME_SLOT_REF1="ts101" TIME_SLOT_REF2="ts102">
                <ANNOTATION_VALUE>yōm-in rāyḥīn ʕa-l-ʕārfe ytiṭālabūn, gāyil: āni b-az-zimān āni sāwēt-ill-ak hal-gadd zēniyyāt. hāḏa, abū d-dīre.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a103"
                TIME_SLOT_REF1="ts103" TIME_SLOT_REF2="ts104">
                <ANNOTATION_VALUE>gāyl-ill-u: āni zēniyyāt-i akṯar min zēniyyāt-ak. gāyl-ill-u: ᵊšnōn? gāyil: tā nsōlif!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a105"
                TIME_SLOT_REF1="ts105" TIME_SLOT_REF2="ts106">
                <ANNOTATION_VALUE>gāyil: āni ǧīt winn-u nāyim ʕinid binit ʕamm-i, aš-šēx, w gimit sāwēt ḥāl-i mhabūl w gimit agṭaʕ al-ᵊmrāse w-asāwi hīčiḏ, lummun binta ʕamm-i ṭlaʕat min ᵊfrāš-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a107"
                TIME_SLOT_REF1="ts107" TIME_SLOT_REF2="ts108">
                <ANNOTATION_VALUE>tā mā l-ʕurbān w </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a108"
                TIME_SLOT_REF1="ts111" TIME_SLOT_REF2="ts112">
                <ANNOTATION_VALUE>yuḏ̣urbūn-u tā mā yšūfūn-he. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a109"
                TIME_SLOT_REF1="ts115" TIME_SLOT_REF2="ts116">
                <ANNOTATION_VALUE>mā xallēt-u yinḏabiḥ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a117"
                TIME_SLOT_REF1="ts117" TIME_SLOT_REF2="ts118">
                <ANNOTATION_VALUE>w āni ǧīt ʕind-u, mā ʕind-i šī w ǧīt ʕind-u w-ənṭā-ni māl, w-al-ʕiǧyān ǧa-yilʕabūn w ǧīt inn-u nāyim b-ᵊfrāš mart-i w-aḥasb-u mart-i mṣāḥbe.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a119"
                TIME_SLOT_REF1="ts119" TIME_SLOT_REF2="ts120">
                <ANNOTATION_VALUE>w ḏibaḥt-u b-al-ᵊhniyye, </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a123"
                TIME_SLOT_REF1="ts123" TIME_SLOT_REF2="ts124">
                <ANNOTATION_VALUE>ē b-al-xaṭla, w hāḏa ṣār w mā ǧira, hāy-he luwwa ḥaqq? gāylīn: inte likke l-ḥaqq!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a125"
                TIME_SLOT_REF1="ts125" TIME_SLOT_REF2="ts126">
                <ANNOTATION_VALUE>abu binta ʕamm, inte nāmūs-ak šift-u b-ḥuḏ̣n-u, w mā, mā ḏibaḥt-u, mā ḏibaḥt-u wala zʕilit minn-u. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a129"
                TIME_SLOT_REF1="ts129" TIME_SLOT_REF2="ts130">
                <ANNOTATION_VALUE>uxṛa hnēt-l-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a131"
                TIME_SLOT_REF1="ts133" TIME_SLOT_REF2="ts134">
                <ANNOTATION_VALUE>w-ənṭēt-u, aṣ ṣār ʕād ḥaqqli abu binta ʕamm. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a135"
                TIME_SLOT_REF1="ts136" TIME_SLOT_REF2="ts138">
                <ANNOTATION_VALUE>akṯar min </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a141"
                TIME_SLOT_REF1="ts141" TIME_SLOT_REF2="ts142">
                <ANNOTATION_VALUE>awwal abu l-wlēd al inḏibaḥ, akṯar min al-wlēd. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a145"
                TIME_SLOT_REF1="ts145" TIME_SLOT_REF2="ts146">
                <ANNOTATION_VALUE>akṯar min al-wlēd. w tʕīš w tislam! </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LINGUISTIC_TYPE_REF="Subdivision" PARENT_REF="Corpus:Harran06" TIER_ID="Translation">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a3" ANNOTATION_REF="a1">
                <ANNOTATION_VALUE>There were two friends who were both sheikhs. They had become friends. One of them had gone to the east and the other to the west.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4" ANNOTATION_REF="a2">
                <ANNOTATION_VALUE>And time passed. After some time had passed, one of them came to the other, I mean, as a guest.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a6" ANNOTATION_REF="a5">
                <ANNOTATION_VALUE>When he came to him as a guest, in the morning he started preparing coffee and people started coming and and he was the host.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a8" ANNOTATION_REF="a7">
                <ANNOTATION_VALUE>The one to whom the guest came, his familie’s tent was opposite to his. The tent of this one, the host, it was opposite of his paternal uncle’s family. They had a beautiful daughter.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a10" ANNOTATION_REF="a9">
                <ANNOTATION_VALUE>His friend, the guest, wanted the girl, that is, he fell in love with her. After he had fallen in love with the girl, he and she... In the past, a guest would stay for a month or two in the tent (of the host).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a12" ANNOTATION_REF="a11">
                <ANNOTATION_VALUE>So the girl got up and came to him; to the corner of the tent, near the tent for guests belonging to her cousins.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a15" ANNOTATION_REF="a13">
                <ANNOTATION_VALUE>They were spending time together and having fun until the morning and they slept together – his friend and the daughter of his uncle.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a16" ANNOTATION_REF="a14">
                <ANNOTATION_VALUE>When he woke up and wanted to make coffee, he saw the daughter of his uncle and his friend sleeping together.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a18" ANNOTATION_REF="a17">
                <ANNOTATION_VALUE>So he took his sword and started bashing the tent and cutting (the ropes). “Hey you! Hey you!” (he shouted). People from around started coming (as usual) to drink coffee.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a20" ANNOTATION_REF="a19">
                <ANNOTATION_VALUE>He was cutting (the ropes) on all sides of the tent. He wanted to wake her up so she could escape.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a22" ANNOTATION_REF="a21">
                <ANNOTATION_VALUE>And people started saying, “The sheikh has gone mad!” They grabbed him. That girl recognized the noise and so she ran away and escaped.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a24" ANNOTATION_REF="a23">
                <ANNOTATION_VALUE>After she had escaped and they had caught him, he came down and went back making fire and preparing coffee.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a26" ANNOTATION_REF="a25">
                <ANNOTATION_VALUE>So they drank coffee, he and his friend and that girl, his cousin, the one whom (his friend) desired.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a28" ANNOTATION_REF="a27">
                <ANNOTATION_VALUE>He stayed at his place for a while and then he said, “Brother, I want to go.” So, he prepared provisions for him meaning he also gave him what he needed of food (for the road) and left.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a30" ANNOTATION_REF="a29">
                <ANNOTATION_VALUE>He went to back his family. After he had left for his family time passed. As for (his friend), the one who had a cousin, the fate turned against him and no cattle, no property, no thingy remained to him.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a32" ANNOTATION_REF="a31">
                <ANNOTATION_VALUE>He became poor as he had nothing left at all. His wife said to him, “O man, don’t you have a friend or companion in this world? Don’t you have anyone?”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a34" ANNOTATION_REF="a33">
                <ANNOTATION_VALUE>“Let’s go, let’s go to him, let’s go and ask for livelihood, just to live, we don’t want anything else!” He said, “Yes, in fact, I have a friend in the eastern part and I want to go to him and ask him to see what his response will be.”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a36" ANNOTATION_REF="a35">
                <ANNOTATION_VALUE>He loaded… he had only one she-camel. He packed his tent and set off as he had also lost the status of being a sheikh.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a38" ANNOTATION_REF="a37">
                <ANNOTATION_VALUE>When he arrived to his friend that said, “Welcome.” And he said, “In fact, brother, this is what has happened to me.”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a40" ANNOTATION_REF="a39">
                <ANNOTATION_VALUE>He came to his tent where he got up early in the morning and gave orders to all his tribesmen.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a42" ANNOTATION_REF="a41">
                <ANNOTATION_VALUE>Every tent should provide one tent square and then they will collect for him these tent squares, sew them together and put up a tent for him like his own tent.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a44" ANNOTATION_REF="a43">
                <ANNOTATION_VALUE>In each house, there was a camel and a ewe. The one who ordered the tribesmen around him was the sheikh of the tribe.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a46" ANNOTATION_REF="a45">
                <ANNOTATION_VALUE>They had collected cattle for him to match his (the sheikh’s) own; along with his shepherds and servants. They had pitched up a tent for him. So, this one (the host) used to make the coffee in the morning, but in the evening that one (the guest) prepared the coffee.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a49" ANNOTATION_REF="a47">
                <ANNOTATION_VALUE>Their tents were facing each other. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a50" ANNOTATION_REF="a48">
                <ANNOTATION_VALUE>Facing each other. And time passed and (his) children played with the children of the sheikh.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a54" ANNOTATION_REF="a53">
                <ANNOTATION_VALUE>The first sheikh was the one who originally belonged to the tribal area. The children played until nightfall in the open field. At night, those children would come and sleep at their mother’s; at (the place of) the one who had come. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a56" ANNOTATION_REF="a55">
                <ANNOTATION_VALUE>One night, the friends were sleeping in the bed and when the sheikh came back from his coffee gathering, lo and behold he found a man sleeping in his bed.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a58" ANNOTATION_REF="a57">
                <ANNOTATION_VALUE>He said, “Aha! My wife is betraying me!” He got up, drew his sword, and cut off his head.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a60" ANNOTATION_REF="a59">
                <ANNOTATION_VALUE>No, no! When she woke up, she said to him “No, you! Oh, you unlucky one, this boy is the so-and-so. He is the son of the sheikh.” He replied “And how was I to know?”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a62" ANNOTATION_REF="a61">
                <ANNOTATION_VALUE>“What should we do? What should we do?” He said, “What should we do? Let’s go and inform the sheikh!” </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a66" ANNOTATION_REF="a65">
                <ANNOTATION_VALUE>He got up, went to him and informed him. He said, “O brother, this is the situation, this is what happened!”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a68" ANNOTATION_REF="a67">
                <ANNOTATION_VALUE>“I found him sleeping in my bed while my children were also with my wife, so I killed him.” He said, “Go, wrap him in his blanket, take him to the place where the children are playing and throw him there.” </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a71" ANNOTATION_REF="a69">
                <ANNOTATION_VALUE>This was said by his father </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a72" ANNOTATION_REF="a70">
                <ANNOTATION_VALUE>“Throw him in the place where the children are playing and leave him!” So they wrapped him up and threw him in the place where the children were playing.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a79" ANNOTATION_REF="a77">
                <ANNOTATION_VALUE>He was sitting in the morning preparing the coffee</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a80" ANNOTATION_REF="a78">
                <ANNOTATION_VALUE>Without telling anyone. People came to have coffee.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a84" ANNOTATION_REF="a83">
                <ANNOTATION_VALUE>As they passed by the place where the children were playing, they saw that the young man was wrapped in a blanket and that he was murdered. They looked at him and discovered that he was the sheikh’s son.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a86" ANNOTATION_REF="a85">
                <ANNOTATION_VALUE>They went to the sheikh to inform him... and they were deliberating among themselves about how to tell it to the sheikh.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a88" ANNOTATION_REF="a87">
                <ANNOTATION_VALUE>This one said, “I see you whispering and muttering, tell me, what’s going on?”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a90" ANNOTATION_REF="a89">
                <ANNOTATION_VALUE>They said, “What we will tell you is bad news. We passed by the place where the children are playing and found the so-and-so killed.”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a92" ANNOTATION_REF="a91">
                <ANNOTATION_VALUE>He said, “Go and bring the one who was killed to me!” They brought him, washed him, wrapped him in a shroud and buried him. Then he said “O tribesmen, each one of you has to bring me a she-camel.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a94" ANNOTATION_REF="a93">
                <ANNOTATION_VALUE>And (I don’t know how many) ewes. Go and give them to my brother, to my friend.” The tribesmen gathered everything he asked for and gave it to him.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a96" ANNOTATION_REF="a95">
                <ANNOTATION_VALUE>After some years had passed and after that one had departed they began talking among themselves to determine which of the friends  is more in the right. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a100" ANNOTATION_REF="a99">
                <ANNOTATION_VALUE>He and his friend.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a102" ANNOTATION_REF="a101">
                <ANNOTATION_VALUE>When they went to the tribal judge to seek his judgment and one of them said, “One day, I did you many favours.” This was said by the owner of the tribal area.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a104" ANNOTATION_REF="a103">
                <ANNOTATION_VALUE>The other said to him, “But my favours were greater than yours.” He asked him, “How is that?” He replied, “Let’s talk about this matter.”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a106" ANNOTATION_REF="a105">
                <ANNOTATION_VALUE>He said “Once I came and found my friend, the sheikh, sleeping with my uncles daughter. So I acted as if I were mad and started cutting the ropes of the tent like this, so that my cousin would leave his bed.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a110" ANNOTATION_REF="a107">
                <ANNOTATION_VALUE>So that the tribesmen wouldn’t ... </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a111" ANNOTATION_REF="a108">
                <ANNOTATION_VALUE>Hit him, so that they wouldn’t see her.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a112" ANNOTATION_REF="a109">
                <ANNOTATION_VALUE>I didn’t allow him to be killed.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a118" ANNOTATION_REF="a117">
                <ANNOTATION_VALUE>Later I came to him possessing nothing. I came to him and he gave me money. The children were playing and one night I saw someone sleeping in my wife’s bed and thought that my wife was betraying me.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a120" ANNOTATION_REF="a119">
                <ANNOTATION_VALUE>And I killed him then. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a124" ANNOTATION_REF="a123">
                <ANNOTATION_VALUE>Yes, by mistake. This is what happened. Which one is right?” They said, “You are the one who is right.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a126" ANNOTATION_REF="a125">
                <ANNOTATION_VALUE>You, the one who has a female cousin, you saw your honour in his embrace but you didn’t kill him nor were you upset with him. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a130" ANNOTATION_REF="a129">
                <ANNOTATION_VALUE>And you still stayed with him (found for him an excuse).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a132" ANNOTATION_REF="a131">
                <ANNOTATION_VALUE>And you gave it to him.” So, the one who had the female cousin became the one who was (more) right. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a136" ANNOTATION_REF="a135">
                <ANNOTATION_VALUE>More than... </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a142" ANNOTATION_REF="a141">
                <ANNOTATION_VALUE>Before the man, the father of the boy who was killed, more than the one with the boy.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a146" ANNOTATION_REF="a145">
                <ANNOTATION_VALUE>More than the one with the boy. May you live long!</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Corpus:Harran02">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a51"
                TIME_SLOT_REF1="ts48" TIME_SLOT_REF2="ts49">
                <ANNOTATION_VALUE>ugbāḷ baʕaḏ̣-hum.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a63"
                TIME_SLOT_REF1="ts63" TIME_SLOT_REF2="ts64">
                <ANNOTATION_VALUE>ī, rūḥ ʕallm-u! </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a73"
                TIME_SLOT_REF1="ts69" TIME_SLOT_REF2="ts70">
                <ANNOTATION_VALUE>abū-´ hāḏa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a74"
                TIME_SLOT_REF1="ts73" TIME_SLOT_REF2="ts74">
                <ANNOTATION_VALUE>ē.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a81"
                TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts80">
                <ANNOTATION_VALUE>mā ysōlif.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a97"
                TIME_SLOT_REF1="ts97" TIME_SLOT_REF2="ts99">
                <ANNOTATION_VALUE>ē, huwwa w rabīʕ-u. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a113"
                TIME_SLOT_REF1="ts109" TIME_SLOT_REF2="ts110">
                <ANNOTATION_VALUE>yuḏ̣urbūn-u. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a114"
                TIME_SLOT_REF1="ts113" TIME_SLOT_REF2="ts114">
                <ANNOTATION_VALUE>mā xallēt-u yinḏabiḥ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a121"
                TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts122">
                <ANNOTATION_VALUE>b-al-xaṭla. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a127"
                TIME_SLOT_REF1="ts127" TIME_SLOT_REF2="ts128">
                <ANNOTATION_VALUE>ē mā zʕilit minn-u</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a133"
                TIME_SLOT_REF1="ts131" TIME_SLOT_REF2="ts132">
                <ANNOTATION_VALUE>uxra lammēt-l-u hniyye ḥaqq w-ənṭēt-u. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a137"
                TIME_SLOT_REF1="ts135" TIME_SLOT_REF2="ts137">
                <ANNOTATION_VALUE>abu binta ʕamm.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a138"
                TIME_SLOT_REF1="ts139" TIME_SLOT_REF2="ts140">
                <ANNOTATION_VALUE>abu l-wlēd al inḏibaḥ. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a143"
                TIME_SLOT_REF1="ts143" TIME_SLOT_REF2="ts144">
                <ANNOTATION_VALUE>akṯar min al-wlēd.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a147"
                TIME_SLOT_REF1="ts147" TIME_SLOT_REF2="ts148">
                <ANNOTATION_VALUE>ē, aḷḷa ysallm-ič!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LINGUISTIC_TYPE_REF="Subdivision" PARENT_REF="Corpus:Harran02" TIER_ID="Translation02">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a52" ANNOTATION_REF="a51">
                <ANNOTATION_VALUE>Facing each other. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a64" ANNOTATION_REF="a63">
                <ANNOTATION_VALUE>“Yes, go and tell him!”</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a75" ANNOTATION_REF="a73">
                <ANNOTATION_VALUE>This was said by his father</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a76" ANNOTATION_REF="a74">
                <ANNOTATION_VALUE>Yes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a82" ANNOTATION_REF="a81">
                <ANNOTATION_VALUE>Without telling anyone.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a98" ANNOTATION_REF="a97">
                <ANNOTATION_VALUE>Yes, he and his friend. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a115" ANNOTATION_REF="a113">
                <ANNOTATION_VALUE>hit him. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a116" ANNOTATION_REF="a114">
                <ANNOTATION_VALUE>I didn’t allow him to be killed.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a122" ANNOTATION_REF="a121">
                <ANNOTATION_VALUE>By mistake.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a128" ANNOTATION_REF="a127">
                <ANNOTATION_VALUE>Yes, you weren’t upset with him. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a134" ANNOTATION_REF="a133">
                <ANNOTATION_VALUE>You found an excuse for him and you gave it to him. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a139" ANNOTATION_REF="a137">
                <ANNOTATION_VALUE>The one who had the female cousin.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a140" ANNOTATION_REF="a138">
                <ANNOTATION_VALUE>the father of the boy who was killed.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a144" ANNOTATION_REF="a143">
                <ANNOTATION_VALUE>More than the one with the boy.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a148" ANNOTATION_REF="a147">
                <ANNOTATION_VALUE>May God keep you safe!</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
