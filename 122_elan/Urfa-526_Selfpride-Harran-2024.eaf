        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a54"
                TIME_SLOT_REF1="ts107" TIME_SLOT_REF2="ts108">
                <ANNOTATION_VALUE>ē gitt: xaḷḷ-u! yiǧi ta-… aḷḷa yindall w ʕabdalla yindall, āni maskūma mā-l-i wakit.</ANNOTATION_VALUE>
