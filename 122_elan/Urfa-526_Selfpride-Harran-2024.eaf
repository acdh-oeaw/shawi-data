            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a41"
                TIME_SLOT_REF1="ts80" TIME_SLOT_REF2="ts83">
                <ANNOTATION_VALUE>ī, tuktul al-ʕaǧi, w hal-ʕaǧi abū-´ yiǧi w yiktul-ha, huwwa w… </ANNOTATION_VALUE>
