        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a53"
                TIME_SLOT_REF1="ts105" TIME_SLOT_REF2="ts106">
                <ANNOTATION_VALUE>ašūf winn-u ygūl: āni w Zaynaw činna nilʕab w-āni aqallib-he tuktil-ni w abū-y yiǧi b-al-ʕaṣa yrīd yuktil-he, alle axaḷḷī-´ yuktil-ič.</ANNOTATION_VALUE>
