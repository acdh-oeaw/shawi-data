        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a68"
                TIME_SLOT_REF1="ts134" TIME_SLOT_REF2="ts136">
                <ANNOTATION_VALUE>ǧīt ᵊb-ʕagil-hum w ǧīt ᵊb… min gōḷāt al-ʕarab ᵊb-ʕagl-i w ᵊb- durustlaġēt-i, </ANNOTATION_VALUE>
