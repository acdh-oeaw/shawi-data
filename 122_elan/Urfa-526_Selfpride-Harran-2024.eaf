        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a55"
                TIME_SLOT_REF1="ts109" TIME_SLOT_REF2="ts110">
                <ANNOTATION_VALUE>āni mā ǧīt-ak rabīʕe. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a57"
                TIME_SLOT_REF1="ts112" TIME_SLOT_REF2="ts114">
                <ANNOTATION_VALUE>āni ǧīt-ak umm! </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a59"
                TIME_SLOT_REF1="ts117" TIME_SLOT_REF2="ts119">
                <ANNOTATION_VALUE>gilt: abū-k in ǧī aḷḷa w ʕabdaḷḷa yindall inn-i āni waǧʕāne. w wala āni čātlitt-ak wala inte čātil-ni. w mā ǧīt-ak rabīʕe zād tā_lʕab ᵊbsāgt-ak guḷḷa. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a61"
                TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts122">
                <ANNOTATION_VALUE>xayyo w-abū-´ ǧī winn-u ygūl yāba umm-i ᵊčtilat-ni b-al-ʕaṣa ḏiyye. ašūf-u gəḏ̣ab īd-u w biča. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a62"
                TIME_SLOT_REF1="ts123" TIME_SLOT_REF2="ts124">
                <ANNOTATION_VALUE>winn-u ygūl yā wlēd-i hāḏi mū Zayno, hāḏi mū Īso, hāḏi Šammē  yray… yraǧǧūn Urfa ʕalē-ne. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a64"
                TIME_SLOT_REF1="ts126" TIME_SLOT_REF2="ts128">
                <ANNOTATION_VALUE>yṭaffšū-na min Urfa, uskut! ḏ̣arb al… lā tfayyin ḥaḏ̣ḏ̣-ak!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a65"
                TIME_SLOT_REF1="ts129" TIME_SLOT_REF2="ts130">
                <ANNOTATION_VALUE>lummun-ma gāl hīčiḏ gitt: yā rabb-i alḥamdilla, inn-ak zādēnāki inn-u zād miṯil ᵊwlid-u mā zatt wiǧdān-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
