                TIME_SLOT_REF1="ts97" TIME_SLOT_REF2="ts99">
                <ANNOTATION_VALUE>hū yuktil-he w hī tiktil-u. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a51"
                TIME_SLOT_REF1="ts100" TIME_SLOT_REF2="ts102">
                <ANNOTATION_VALUE>ē aḷḷa yʕāwin, qafadan kontak. </ANNOTATION_VALUE>
