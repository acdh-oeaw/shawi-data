    <TIER LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Corpus:Harran03">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>ᵊtʕarif al-burġul ᵊšnōn yṣīr? lā, mā tʕarif </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a2"
                TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>al-burqul, al-burqul yǧībūn al-ḥunṭa, al-ḥunṭa ttəṣawwal, ᵊttaqassal.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a4"
                TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>ʕugub-ma ttaqassal yǧībin al-barāmīl al-ᵊkbāṛ, al-baṛāmīl. al-barāmīl, ᵊtʕarfūn al-barāmīl? </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>al-barāmīl.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>hā, yinḥaṭṭ ᵊbgaḷb al-ᵊgdūṛa, al-burġul. kull ta-ngūl ǧidir tniktēn ḥunṭa, w yṣaffin balči hemen ta-ngūl al-bēt ašgadd ᵊʕyāl-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a8"
                TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>al-bēt ašgadd ᵊkyāl-u ta-ngūl ʕašər tunfus. ysāwū-l-hum sitt sabʕ ᵊgdūṛa, burqul.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>yḥuṭṭūn haš-šakle yṣuffūn-hin ʕa-l-ḥaǧar, ʕugub-ma yṣuffūn ʕa-l-ḥaǧar, w yḥuṭṭūn bī-hin kull ǧidir ᵊtniktēn tniktēn burqul.  </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a10"
                TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>w yḥuṭṭūn ʕalē-hin mayye w ygūmūn ywuzzūn yiṭbaxūn-hin, yiṭbaxūn-hin b-an-nār.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>yiṭbaxūn-hin lummun bulbulbul ygūm yiǧlib, lummun tistawi as-silīǧe hāḏi ygūlū-l-he silīǧe, hā.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a12"
                TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>tistawi, ʕugub-ma tistawi ygūm ʕād ytaštiš ḥitt aǧ-ǧārāt w-al-ʕaǧāwīn al yismaʕūn rīḥt al-burqul alyōm ta-ngūl b-ᵊflān ʕid məṭraḥ ǧār-ne.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a13"
                TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>iḥna hināk b-Aqčaqale, haš-šakle mū miṯil alḥaz hēne b-al-midīne. Aqčaqale čān mū miṯil aǧ-ǧarye?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a14"
                TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>yištammūn ʕala flān da-ybarqəl, uxḏi tāxuḏ-il-he ʕa-ṭ-ṭabši, ənṭī-ni m-al-burqul hāti! </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a15"
                TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>yāxḏūn ʕād ənṭī-ni ḥabbtēn burqul yinṭūn-ha ʕād. ᵊǧǧīb min ʕid ǧīrān w timlaḥ ʕād w yāklūn al-ʕaǧāwīn min-he.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a16"
                TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>alle aǧ-ǧidir yaʕni hemen hemen nuṣṣ-u yfarrǧūn-u. yfarrǧūn nuṣṣ aǧ-ǧidir. hāḏa miššān al-ʕaǧāwīn al yištammūn ar-rīḥa, rīḥt al-burqul.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a17"
                TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts34">
                <ANNOTATION_VALUE>ʕaman ortalaġa yaʕni tihni hā. miššān rīḥt al-burqul ʕaman-he tihni.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a18"
                TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>ᵊngūm ʕād hāḏa ʕugub-ma yistawi, wəḥde tiǧi guṭma yaʕni nxalli guṭma ʕa-n-nār.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a19"
                TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>w nirgi fōg ad-dūr, dūr-ne haš-šakle mā-l-hin, ḥawāle mā-l-hin. hīčiḏ tek ᵊhniyye. bass, bass dūr yaʕni, māmin ḥawāle, qorquluq māmin.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a20"
                TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
                <ANNOTATION_VALUE>hā, w-ᵊnǧīb as-saṭəl. w-ᵊnšidd-ill-u al-maras ʕa-s-saṭəl w-ᵊnḏ̣all wəḥde ttibāwaʕ ᵊmn-asfal yḏ̣all yʕabbi wāḥad yʕabbi wāḥad yinṭi nungul kull-u fōg ad-dūr nšərr-u</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a21"
                TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts42">
                <ANNOTATION_VALUE>ʕugub-ma nšərr-u ʕād ᵊnḏ̣all nahāṛ kull nahāṛ nirgi ʕalē-´, ᵊnḏ̣all nṣūṭ-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a22"
                TIME_SLOT_REF1="ts43" TIME_SLOT_REF2="ts44">
                <ANNOTATION_VALUE>lummunn-u yigḏ̣i, ʕugub-ma yigḏ̣i, ᵊnʕabbī-´ b-al-ʕalāyiǧ niǧi ʕād šī ᵊǧrunne, al-ǧrunne b-al-ḥaǧar, samʕān bī-hin? </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a24"
                TIME_SLOT_REF1="ts47" TIME_SLOT_REF2="ts48">
                <ANNOTATION_VALUE>aǧ-ǧrunne w-al-mīǧane. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a26"
                TIME_SLOT_REF1="ts51" TIME_SLOT_REF2="ts52">
                <ANNOTATION_VALUE>šāyif-hin, hā! niǧi ʕādēne ʕugub-ma yības, w-ᵊnḥuṭṭ čam ʕalīǧe burqul ṣār ʕid-ne, arbaʕ ʕalāyiǧ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a27"
                TIME_SLOT_REF1="ts53" TIME_SLOT_REF2="ts54">
                <ANNOTATION_VALUE>ᵊnǧīb al-arbaʕ ʕalāyiǧ. ᵊnḏ̣all guṭma hīčiḏ nwaddn-u, guṭma yaʕni hniyye, bass nbuxx-u baxxa, mū čiṯīr yaʕni.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a28"
                TIME_SLOT_REF1="ts55" TIME_SLOT_REF2="ts56">
                <ANNOTATION_VALUE>hīčiḏ yaʕni nṣawwl-u, nṣawwl-u hīčiḏ b-al-mayye w rrudd-u bgaḷb aǧ-ǧurun. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a29"
                TIME_SLOT_REF1="ts57" TIME_SLOT_REF2="ts58">
                <ANNOTATION_VALUE>ᵊrrudd-u nimli aǧ-ǧurun ᵊttigābalin ḥurumtēn, b-īdē-hin miyāǧin w wəḥde zād tugʕud, ᵊḏ̣ḏ̣all ᵊtrudd b-īd-he ḏ̣ḏ̣all ᵊtrudd.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a30"
                TIME_SLOT_REF1="ts59" TIME_SLOT_REF2="ts60">
                <ANNOTATION_VALUE>čiṯīr m-al-ḥarīm ᵊḏ̣rabin baʕaḏ̣-hin b-al-miyāǧin, ī alli yfawwtin qaze. ygūmin ʕād ham yqannin ham yihnin ham yduggun al-burqul.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a31"
                TIME_SLOT_REF1="ts61" TIME_SLOT_REF2="ts62">
                <ANNOTATION_VALUE>yḏ̣all yduggunn-u lumunn-u yihni. ygūm-ill-u, ygūm-ill-u miṯil aǧ-ǧanāḥīn. yaʕni al-gišir al-fōgāni al-ikinǧi ygūm.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a32"
                TIME_SLOT_REF1="ts63" TIME_SLOT_REF2="ts64">
                <ANNOTATION_VALUE>ᵊtgūl ʕād ᵊstuwa, w ᵊtfarrq-u ʕād hāḏa ʕād ygūm hīčiḏ ygūm-ill-u xamal, ygūm ʕādēn tirmī-´ uxṛa ᵊḏ̣ḏ̣aḷḷ ᵊddugg hāḏa, ʕa-l-ʕalāyiǧ kull-hin yindaggin.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a33"
                TIME_SLOT_REF1="ts65" TIME_SLOT_REF2="ts66">
                <ANNOTATION_VALUE>ʕugub-ma yindaggin yinḥaṭṭin uxṛa, uxṛa ʕa-š-šamis yinḥaṭṭin. ʕugub-ma yinḥaṭṭin ʕa-š-šamis, </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a34"
                TIME_SLOT_REF1="ts67" TIME_SLOT_REF2="ts68">
                <ANNOTATION_VALUE>uxṛa yinšarrin ʕugub-ma yinšarrin lummun yṣīr hīčiḏ hawa. titni l-hawa tā yṣīr hawa tā tgūm ᵊḏḏarrī-´.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a35"
                TIME_SLOT_REF1="ts69" TIME_SLOT_REF2="ts70">
                <ANNOTATION_VALUE>ᵊḏ̣ḏ̣all tugḏ̣ub ʕād ᵊḏ̣ḏ̣arri ǧ-ǧwāš, aǧ-ǧwāš ʕād al ygūm min haḏāk al… mū yības? ʕugub-ma yindagg mū yības? al-ḥunṭa tibas.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a36"
                TIME_SLOT_REF1="ts71" TIME_SLOT_REF2="ts72">
                <ANNOTATION_VALUE>ygūmin hīčiḏ yfarrkin-he haš-šakle, w yšurrun-he ʕa-š-šamis.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a37"
                TIME_SLOT_REF1="ts73" TIME_SLOT_REF2="ts74">
                <ANNOTATION_VALUE>aš-šamis ʕād ᵊtwaggiʕ ʕa-l-ᵊhniyye haḏāk al… al-ǧanāḥīn ᵊtwaǧǧiḥin m-al-ḥunṭa. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a38"
                TIME_SLOT_REF1="ts75" TIME_SLOT_REF2="ts76">
                <ANNOTATION_VALUE>ygūmin ʕād wakt-in yṣīr hīčiḏ hawa, yigafin ʕād yḏ̣allin al-ḥurma tigaf ṭūl-ha ḏ̣ḏ̣all ᵊḏḏarrī-´.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a39"
                TIME_SLOT_REF1="ts77" TIME_SLOT_REF2="ts78">
                <ANNOTATION_VALUE>w yḏ̣all ʕād haḏāk al-ᵊhniyye  yiǧi ʕala wurič. yḏ̣all ʕād yiǧi ʕala wurč ᵊhnīt aš-šismu, aǧ-ǧwāš.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a40"
                TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts80">
                <ANNOTATION_VALUE>w-al-ḥunṭa ʕād ᵊttiṣaffa hīčiḏ ᵊḏ̣ḏ̣all tuṭluʕ naḏ̣īfe ʕād ʕala wurič. w ttaʕabba uxṛa b-al-ʕalāyiǧ w trūḥ ʕād uxṛa ʕa-l-ᵊhniyye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a41"
                TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts82">
                <ANNOTATION_VALUE>w yiǧi umm aǧ-ǧārūš ʕād yāxḏūn-he ʕa-ǧ-ǧārūša, at təṭḥan, at tuǧruš al-ḥunṭa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a42"
                TIME_SLOT_REF1="ts83" TIME_SLOT_REF2="ts84">
                <ANNOTATION_VALUE>tuǧruš ʕād tiǧi šaklēn al-ḥunṭa: wəḥde ʕēš w wəḥde čīge.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a43"
                TIME_SLOT_REF1="ts85" TIME_SLOT_REF2="ts86">
                <ANNOTATION_VALUE>hiyye ǧaršətt-u qarəšəq, al-ummiyye uxṛa tugḏ̣ub ʕādēne rāʕit al-bēt, tugḏ̣ub uxṛa al-qərbāl, al-munxul.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a44"
                TIME_SLOT_REF1="ts87" TIME_SLOT_REF2="ts88">
                <ANNOTATION_VALUE>munxul al-ʕēš w munxul ač-čīge, ᵊḏ̣ḏ̣all tunxul tunxul an-nāʕim tuṭluʕ-u ʕēš. w-al-xašin tuṭluʕ-u, an-nāʕim tuṭluʕ-u čīge. w-al-xašin tuṭluʕ-u ʕēš.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a45"
                TIME_SLOT_REF1="ts89" TIME_SLOT_REF2="ts90">
                <ANNOTATION_VALUE>hāḏa awwali zaḥmit awwal al-burqul. amma alḥaz min ᵊṭlaʕan al-ḥunṭa ṭlaʕat yaʕni kull-ha ḥāḏ̣ir, xallaṣat al-ḥarīm min at-tʕabe hāḏe.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a46"
                TIME_SLOT_REF1="ts91" TIME_SLOT_REF2="ts92">
                <ANNOTATION_VALUE>w-al… ʕād ᵊhnīt aǧ-ǧirīš zād ǧirīš al-ḥunṭa, aǧ-ǧirīš al-ḥunṭa zād hāḏa zād ʕayne balāy aṭ-ṭabəx.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a47"
                TIME_SLOT_REF1="ts93" TIME_SLOT_REF2="ts94">
                <ANNOTATION_VALUE>min tiǧi l-ḥunṭa ʕayne ttiṣawwal, tinḥaṭṭ ᵊbgaḷb aǧ-ǧurun, w tindagg. ʕayne nafs aš-šī hāḏa tindagg amma balāy aṭ-ṭabəx hāḏi hā.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a48"
                TIME_SLOT_REF1="ts95" TIME_SLOT_REF2="ts96">
                <ANNOTATION_VALUE>ṭabəx mā y… mū ṭabəx yaʕni balāy aṭ-ṭabəx, niyye tiǧi hā, ḥunṭit-in niyye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a49"
                TIME_SLOT_REF1="ts97" TIME_SLOT_REF2="ts98">
                <ANNOTATION_VALUE>tinḥaṭṭ ᵊbgaḷb aǧ-ǧurun w yinḥaṭṭ ʕayne ttiṣawwal haš-šakle w tindagg.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a50"
                TIME_SLOT_REF1="ts99" TIME_SLOT_REF2="ts100">
                <ANNOTATION_VALUE>tindagg w ʕayne hīčiḏ tinḥaṭṭ tinḥaṭṭ b-aš-šamis w tinḏarra, w-ᵊtrūḥ ʕa-ǧ-ǧārūš w tiǧi ʕād hāḏi, ysāwin bī-hin ᵊkbabb w ysāwin-he, ysāwin-he l-al-waǧʕānīn. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a51"
                TIME_SLOT_REF1="ts101" TIME_SLOT_REF2="ts102">
                <ANNOTATION_VALUE>al-ḥurumt at tilid, ysāwū-l-he simīde. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a53"
                TIME_SLOT_REF1="ts105" TIME_SLOT_REF2="ts106">
                <ANNOTATION_VALUE>simīde min-he, min hāḏi l-ḥunṭa al-maǧrūše, hā ygūlūn ḥunṭit-in madgūga.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a54"
                TIME_SLOT_REF1="ts107" TIME_SLOT_REF2="ts108">
                <ANNOTATION_VALUE>hā, al-ḥunṭit al-madgūga ṣṣīr ʕēš liban zād min-he gabəḷ-ma tinǧariš, wakt-in-he lissaḥ-ḥa ḥabb,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a55"
                TIME_SLOT_REF1="ts109" TIME_SLOT_REF2="ts110">
                <ANNOTATION_VALUE>yinʕazil min-he ᵊtgūl: hāḏi arīd axallī-he tā ḏ̣ḏ̣all asāwi bī-he ʕēš liban. ʕēš liban, ʕēš xāṯir aḏ̣all asāwī-he.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a56"
                TIME_SLOT_REF1="ts111" TIME_SLOT_REF2="ts112">
                <ANNOTATION_VALUE>w haḏīč al-uxṛa zād at tinǧariš al-ḥunṭat at tinǧariš ᵊṣṣīr ǧirīš. aǧ-ǧirīš ᵊṣṣīr minn-u ᵊkbabb iḥne nsāwi minn-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a57"
                TIME_SLOT_REF1="ts113" TIME_SLOT_REF2="ts114">
                <ANNOTATION_VALUE>ᵊkbabb, ᵊnsāwi ʕēš ᵊkbabb minn-u b-aš-šte čiṯīr yṣīr zēn, lezzetli, al-ᵊkbabb. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a59"
                TIME_SLOT_REF1="ts117" TIME_SLOT_REF2="ts118">
                <ANNOTATION_VALUE>al-ᵊkbabb. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a60"
                TIME_SLOT_REF1="ts119" TIME_SLOT_REF2="ts120">
                <ANNOTATION_VALUE>hā, w-al-ᵊhniyye, haḏāk zād min ham ǧirīš haḏāk zād yṣīr, al-wāḥad ysāwi minn-u, ᵊhniyyāt yaʕni wakt-in al-ḥurmat ti… aḷḷa yinṭī-he tilid,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a61"
                TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts122">
                <ANNOTATION_VALUE>al nəṭbax minn-u nsāwi simīde w ninṭī-he hāḏa šife, šife li-l-ḥurma yaʕni tākul miṯil al yigūl kalāyli yaʕni hā tākul minn-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a62"
                TIME_SLOT_REF1="ts123" TIME_SLOT_REF2="ts124">
                <ANNOTATION_VALUE>hā w-al-ᵊkbabb zādēne ʕayne al-ᵊkbabb wakt-in ᵊnsāwi aǧ-ǧirīš hāḏa nǧīb-u, aǧ-ǧirīš ᵊnwaddn-u nxalṭ-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a63"
                TIME_SLOT_REF1="ts125" TIME_SLOT_REF2="ts126">
                <ANNOTATION_VALUE>ē, aǧ-ǧirīš nxalṭ-u ʕayne haš-šakil hāḏa nwaddn-u, w nimlaḥ-u, aǧ-ǧirīš. ʕugub-ma nimlaḥ-u w ngūm nəfərk-u, aǧ-ǧirīš.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a64"
                TIME_SLOT_REF1="ts127" TIME_SLOT_REF2="ts128">
                <ANNOTATION_VALUE>nəfərk-u nəfərk-u nsāwi ʕaǧīn, ʕugub-ma nsāwi ʕaǧīn zēn yaʕni nəfərk-u yṣīr nigdar nfukk-u, bala ǧāfi, haš-šakle yaʕni yiftakk.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a65"
                TIME_SLOT_REF1="ts129" TIME_SLOT_REF2="ts130">
                <ANNOTATION_VALUE>hā, w-ᵊnǧīb ʕayne al-qiymāli, mū sāwēna ḥašwut al-qiymāli? ʕayne nugruḏ̣ al-buṣal, nugruḏ̣ istersen laḥm diǧāǧ, istersen laḥm qanam, mā yifrug. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a67"
                TIME_SLOT_REF1="ts133" TIME_SLOT_REF2="ts134">
                <ANNOTATION_VALUE>ī, mā yifrug amma lissaʕ ta-ngūl kuyruk yağı yṣīr yaġli. yingariḏ̣ ʕalē-´ w yingariḏ̣ al-buṣal yinḥaṭṭ aṯ-ṯūm,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a68"
                TIME_SLOT_REF1="ts135" TIME_SLOT_REF2="ts136">
                <ANNOTATION_VALUE>yinḥaṭṭ buṣal, ad-dibis, yinḥaṭṭ ṣōṭ, yinḥaṭṭ filfil ʕayne ḏanne kull-hin yinxalṭin.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a69"
                TIME_SLOT_REF1="ts137" TIME_SLOT_REF2="ts138">
                <ANNOTATION_VALUE>w haḏāk al-ʕaǧīn as sāwēnā-´ aǧ-ǧirīš, ǧirīš al-ʕaǧīn. as sāwēnā-´ nḏ̣all nfukk haš-šakle b-īdē-ne, nfukk-ha w-ᵊnʕabbī-he ḥašwa w-ᵊnčalliṭ-he.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a70"
                TIME_SLOT_REF1="ts139" TIME_SLOT_REF2="ts140">
                <ANNOTATION_VALUE>ᵊkbabb ᵊnsāwi, w nəṭbax al-mayye nfawwir-he b-aǧ-ǧidir ʕa-n-nār. w-ᵊnḏ̣all ᵊnzitt ᵊbgaḷəb-ha al-ᵊkbabb, w nəṭbax al-ᵊkbabb haš-šakle.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a71"
                TIME_SLOT_REF1="ts141" TIME_SLOT_REF2="ts142">
                <ANNOTATION_VALUE>nuṭluʕ haḏanne, haḏanne haḏanne šarha ygūlū-l-hin. haḏiyye ʕaman zahmetli iş kull ḥade mā ʕād ssāwī-´. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a72"
                TIME_SLOT_REF1="ts143" TIME_SLOT_REF2="ts144">
                <ANNOTATION_VALUE>an-nās turkuḏ̣ ʕa-l-qīyme, ʕa-laḥm al-ʕaǧīn. gāmat turkuḏ̣ ʕa-l-fərən ʕayne huwwa nafs aš-šīʸ, amma hāḏe zaḥmet yrīd.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a73"
                TIME_SLOT_REF1="ts145" TIME_SLOT_REF2="ts146">
                <ANNOTATION_VALUE>yrīd ama taʕab yrīd ᵊfukfukān w yrīd ᵊtḥišši w yrīd aṭ-ṭabəx ʕa-n-nār, ʕa-t-tīb mā yṣīr ʕat-tīb yfūš-hin, yrīd nār-in čiṯīre. hāḏa zād al-ᵊkbabb, hā.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
