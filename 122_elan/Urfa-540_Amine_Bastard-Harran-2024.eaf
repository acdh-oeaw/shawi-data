    <TIER LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Corpus:Harran03">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
                <ANNOTATION_VALUE>awwali b-zimānāt al-awwali al-awwalīn, šī wāḥad ta-ngūl huwwa aqa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a2"
                TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>w-al-aqa gāyim mihni, demek ki yiǧi b-as-sine nōba ʕala mart-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3"
                TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>w kull-ma yiǧi ʕidd, ʕind mart-u, huwwa ʕād al-aqa ta-ngūl mū zangīl? ʕind-u qanam ʕind-u ba… ta-ngūl ᵊhniyyāt ta-ngūl bəʕərān ʕind-u, yaʕni ʕind-u xēl, </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a4"
                TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>ʕind-u mḥa… ʕind-u zādēne al ydaḥḥǧūn yaʕni ta-ngūl miṯil al… al… ar-rəʕyān, ʕind-u rəʕyān.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>demek wāḥad hāḏa min az-zilum ar-rəʕyān, yʕarif yaʕni ydaḥḥiǧ ytibaxxaṣ ʕa-l-aqa wakt-inn-u yiǧi, </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>yrūḥ yinām ʕidd mart-u b-as-sine nōba. demek miṯil mihni yaʕni hā daryān bī-´, b-al-aqa. al-aqa demek yrūḥ ta-ngūl, ysāfir.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>wakt-inn-u yrudd yiǧi ʕala mart-u ybāt, nahāṛ-in yibāt ʕidd mart-u, mart-u tḥabal w yṣīr-l-u wlēd haḏīč as-sine.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a8"
                TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>neyse uxṛa dāyir sine uxṛa yiǧi, uxṛa yṣīr-l-u wlēd min-he, msammī-´ Mḥimmad. al-awwali ᵊmsammīt-u Mḥimmad w-at-tāli uxṛa msammīt-u Mḥimmad.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>uxṛa hāḏa, tām ᵊmʕayyir ǧāy, al-aqa mū šāyif w qēr haḏāk as-sāyis yaʕni yrīd ydaḥḥiǧ li-l-hniyyāt, ta-ngūl ar-rāʕi.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a10"
                TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>šāyif al-aqa, huwwa lissaʕ mū šāyif mart-u. w-taʕāl tigallaṭ ʕala mart al-aqa. bass hīčiḏ tāll mart al-aqa w hiyye tḥasib raǧil-he ǧāy w nāyim ʕidd mart al-aġa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>ṯāni nahāṛ hāḏa ᵊzlime ǧāy ta-ngūl šāyfitt-u b-an-nahāṛ w mihnīt-u ygūl: al-wēlād w hīčiḏ w b-al-lēl gāyla: ū igaf hale! ʕaǧal al tāll albāriḥ mū inte? sāwēt? hī!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a12"
                TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>wakt-in hīčiḏ gāyil al-aqa gāyil: hāḏi mart-i. ʕaǧal ᵊmṣāḥbitt-il-ha ḥade? ᵊšnōn gāḷat al-kalām hāḏa? āni xaḏēt šubha min-he.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a13"
                TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>tss, ḥablāne l-ḥurma, ṣāyr al-wlēd, uxṛa ṣāyr-il-he wlēd, uxṛa msammīt-u Mḥimmad. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a14"
                TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>ᵊmdaḥḥiǧ ʕalē-hum huṃṃa aṯ-ṯalāṯe kabrānīn yaʕni ṣāyrīn šibāb, ṯalāṯe.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a15"
                TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>gāyil: ᵊMḥimmad yiriṯ yaʕni yiriṯ-ni yāxuḏ minn-i mirāṯ-i. ᵊMḥimmad yiriṯ, amma Mḥimmad al-āxar at-tāli mā yiriṯ. ʕugub gāḏ̣bitt-u miṯil al-ᵊhniyye. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a16"
                TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>ʕaǧab gāyil: āni haḏōle yaʕni hāy-hu min-hum? axāf in al-awwalīn zād mū ṣaġlam? hāḏa drīt bī-´, at-tāli. amma al-awwalīn zād axāf in-hum mū ṣaġlam?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a17"
                TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts34">
                <ANNOTATION_VALUE>haḏōl arīd arūḥ adarrib-hum, ʕala ʕārfe. tā huṃṃa yaʕni axall-hum tā nšūf hāy min-hum al… az-zanwa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a18"
                TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>neyse, ygūl: wakt-in-hum haḏōle ṭālʕīn gāyil: xayyo, wēlād-i, imšu! ᵊflān məṭraḥ wāḥad šī ʕārfe.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a19"
                TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>arīd-il-kum ti-trūḥūn ʕalē-´, aw šūfu ši-ygūl-il-kum w taʕālu tā tgūlū-l-i! ē, gāylīn: timām!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a20"
                TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
                <ANNOTATION_VALUE>ṭālʕīn al-ʕiǧyān ʕa-d-darib, aṯ-ṯalāṯit-hum gāymīn yimšūn, wakt-in yimšūn ᵊmdaḥḥǧīn ʕa-l-gāʕa šāyfīn aṯar, aṯar yaʕni ǧdūm.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
