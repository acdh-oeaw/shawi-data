            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a69"
                TIME_SLOT_REF1="ts137" TIME_SLOT_REF2="ts138">
                <ANNOTATION_VALUE>rādd al-āxar gāyil: tindall? mū bass al-xubuz damm, hāḏa zād ǧāyb al-laḥam, al-laḥam laḥam čalib. ǧāyb-in-ne.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a70"
                TIME_SLOT_REF1="ts139" TIME_SLOT_REF2="ts140">
                <ANNOTATION_VALUE>al-āxar zād gāyil: hāḏa, waḷḷa al-ʕārfe hāḏa zanwa. az-ziqīr gāyil: hāḏa l-ʕārfe zanwa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a71"
                TIME_SLOT_REF1="ts141" TIME_SLOT_REF2="ts142">
                <ANNOTATION_VALUE>neyse, ygūl wakt-inn-u hāḏa xāšš ʕalē-hum. gāyil: gūlu tā_šūf iš-bī-kum? taw-kum iš-giltu. gāylīn: lā, lā. gāyil: gūlu!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a72"
                TIME_SLOT_REF1="ts143" TIME_SLOT_REF2="ts144">
                <ANNOTATION_VALUE>gāyil: intu giltu al-xubuz, ᵊšnōn al-xubuz bī-´ damm? gāyil: al-xubuz wakt-in hāḏi al-ḥurumt al ʕāǧnitt-u, ʕalē-he al-ḥirmān.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a73"
                TIME_SLOT_REF1="ts145" TIME_SLOT_REF2="ts146">
                <ANNOTATION_VALUE>al ʕāǧne al-ʕaǧīn, min hāḏa iḥne ginne: damm. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a74"
                TIME_SLOT_REF1="ts147" TIME_SLOT_REF2="ts148">
                <ANNOTATION_VALUE>gāyil: hāḏa l-laḥam ḏe šnōn ᵊtgūlūn? iḥne hāḏi nʕaǧe iḥne ḏibaḥnā-ha. ᵊšnōn ᵊtgūlūn hāḏa laḥam čalib? </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a75"
                TIME_SLOT_REF1="ts149" TIME_SLOT_REF2="ts150">
                <ANNOTATION_VALUE>gāyil: hāḏi, wāḥad al-āxar rādd, gāyil: hāḏi lummun-he ᵊhniyye lummun-he ziqīre rāḏ̣ʕe čalib, ṣaḥīḥ zād rāḏ̣ʕe čalib. ʕarfān yaʕni.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a76"
                TIME_SLOT_REF1="ts151" TIME_SLOT_REF2="ts152">
                <ANNOTATION_VALUE>hā gāyil: inte šnōn ᵊtgūlū-l-i? gāyil: āni zād gitt inte min ǧibit haḏanne inte zanwa. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a77"
                TIME_SLOT_REF1="ts153" TIME_SLOT_REF2="ts154">
                <ANNOTATION_VALUE>gāyil: waḷḷa maḥḥad zanwa alle inte awwal fāl ṭāliʕ b-ač-čōl, rāyiḥ ʕād ʕal umm-u. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a78"
                TIME_SLOT_REF1="ts155" TIME_SLOT_REF2="ts156">
                <ANNOTATION_VALUE>gāyil: hāḏa min gāḷ zāne demek ki āni zād mā-ni ṣaġlam, al-ʕārfe.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a79"
                TIME_SLOT_REF1="ts157" TIME_SLOT_REF2="ts158">
                <ANNOTATION_VALUE>gāḏ̣b umm-u gāyim yihni umm-u taʕāli ʕallmī-ni! tā_šūf: āni walda-man? gūlī-l-i! āni walda-man?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a80"
                TIME_SLOT_REF1="ts159" TIME_SLOT_REF2="ts160">
                <ANNOTATION_VALUE>gāyle: waḷḷa, yā wlēd-i, abū-k aqa. hā yaʕni rāʕi bēt-i hā, mū abū-´. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a81"
                TIME_SLOT_REF1="ts161" TIME_SLOT_REF2="ts162">
                <ANNOTATION_VALUE>abū-´ hū demek m-al… zād ǧāybitt-u min ʕidd haḏōl al yištaqlūn ʕind al-xadādīm.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a82"
                TIME_SLOT_REF1="ts163" TIME_SLOT_REF2="ts164">
                <ANNOTATION_VALUE>abū-k inte, ᵊzlimt-i āni aqa w yrīd minn-i ʕiǧyān. w āni inte mā hū mā yṣīr-ill-u gutt tā yihni yaʕni. tā ʕād al-māl hāḏa w-aš-ši hāḏa aṭluʕ ṣāḥib.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a83"
                TIME_SLOT_REF1="ts165" TIME_SLOT_REF2="ts166">
                <ANNOTATION_VALUE>hā w-āni waḷḷa hniyye, inte min, min ᵊflān ʕazab yaʕni. inte ǧibt-ak. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a84"
                TIME_SLOT_REF1="ts167" TIME_SLOT_REF2="ts168">
                <ANNOTATION_VALUE>w xāšš ʕād ʕalē-hum uxṛa b-al-ǧidīd gāyil: rūḥū gūlu l-abū-kum. hāḏa pīč, zanwa, ʕin al-ʕaǧi az-ziqīr. inte b-xēr w-iḥne b-salām!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
