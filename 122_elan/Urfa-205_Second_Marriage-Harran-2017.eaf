        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a2"
                TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>yōm-in ḥabb…, yōm-in ǧidd-ič, yōm-in ǧidd-ič xaḏa ḥabābt-ič, yōm-in xaḏa umm-iʸ. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3"
                TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>ənṭa uxt-u bidāyil dagišš, ənṭa uxt-uʷ, w xaḏa umm-iʸ. ənṭa uxt-u lil xāl-iʸ, w xaḏa ummiʸ bidāl uxt-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a4"
                TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>w tiǧawwaz. ʕugub-ma tiǧawwaz ṣār baqči. baqči yirkab al-faras w yrūḥ ʕa-l-gaṛāye, yrūḥ ʕa-l-gaṛāye ylimm al…</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>al mū msāwi ʕaskariyye yrūḥ miššān al-kōne yrūḥ miššān al-ḥarāmiyye, yōm-in ḥarāmi ybūgūn ḥarām, yrūḥ ydawwir b-al-gaṛāye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>miṯil wāḥad yinbāg bēt-u šinhu awwali šinhi ybūgūn? ybūgūn as-samin, ybūgūn qanam, ybūgūn as-samin, awwali.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>ybūgūn al-xēl, al-faras yāxḏūn-he ybūgūn-he, ḥarāmiyye yiǧūn ybūgūn-he.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a8"
                TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>hā, gām abū-ye gəḏ̣ab min hināk rāḥ, ā taḥawwal an-nōba ṣār ᵊhniyye min ʕugb al-… mā čān baqči, rāḥ ṣār b-al-maḥkama.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>gām ʕind al-ḥākim w-as-sawǧi yištaqil. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>ṣāraw ʕād, ṣār ᵊMḥimmad, ṣār Aḥmad, ṣār Məṣṭafa, ṣār Maḥmūd, ṣirt āni.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a12"
                TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>arbaʕ wēlād w bnayye. xaməs wēlād ṣirne. win ygūl: yā ḥurma, āni arīd arūḥ, arīd arūḥ ataḥawwal, ard-arūḥ ʕala qēr məkān, arūḥ … ṣirit b-al-maḥkama.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a13"
                TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>awwali ʕād ṣārat maḥāčim gāmat al… al-qəšle min Ḥarrān awwali b-Ḥarrān iḥne činne.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a14"
                TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>asāsit-ne w ṣubbut-ne hnīt-ne b-Ḥarrān. w rāḥ rāḥ ʕal Aqčaqale. Aqčaqale rāḥ ʕalē-he winn-u ʕāšiǧ ḥurma.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a15"
                TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>māxiḏ ḥurma, ʕāšiǧ-he w lilhe wlēdēn w bnayye. ʕāšiǧ-he māxiḏ-he w mā nindall umm-iʸ mā tindall mā-l-he xabar.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a16"
                TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>lummun ǧī gāḷ win ygūlin-n-he xawāt-he ǧan-ne: yā wali, xayye, hāḏa z-zlime sātt-ič ᵊb-Ḥarrān w xallā-č inti w qnim-ič w bgarāt-ič w fris-ič.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a17"
                TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts34">
                <ANNOTATION_VALUE>w-az-zlime hāḏa mā ʕād yiǧī-č, awwali čān yiǧī-č yrūḥ w yiǧi han-nōb mā ʕād yiǧi gəḏ̣a min ʕšiǧ mā ʕād yiǧi. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a18"
                TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>w ḏ̣allēne ʕəǧyān ḏ̣allaw win ygūlūn ygūlūn: ᵊrḥalaw! šīl-u tā dā_rīd ašayyil-kum āxuḏ-kum ʕal Aqčaqale.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a20"
                TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts43">
                <ANNOTATION_VALUE>xāl-ič ᵊMḥimmad ʕumr-u siṭṭaʕaš xaməsṭaʕaš hīčiḏ. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a22"
                TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts46">
                <ANNOTATION_VALUE>ač-čibīr. </ANNOTATION_VALUE>
