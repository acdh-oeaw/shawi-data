        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a25"
                TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts50">
                <ANNOTATION_VALUE>yaʕni ᵊlsān-ak ʕalēš ᵊtḥuṭṭ-u b-al-ᵊhniyye? xall b-al-bēt sōlif inte! </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a29"
                TIME_SLOT_REF1="ts56" TIME_SLOT_REF2="ts58">
                <ANNOTATION_VALUE>hā, belčin al-wāḥad mā yištihi b-al-ᵊkrād yitisōlaf.  </ANNOTATION_VALUE>
