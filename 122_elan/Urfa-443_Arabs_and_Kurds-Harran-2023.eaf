    <TIER LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Corpus:Harran02">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts3">
                <ANNOTATION_VALUE>waḷḷa yā ǧimāʕa agul-kum šī? iḥne al-ʕarab, ta-ngūl alḥaz dīru bāl-kum, al-ᵊkrād, tara mā yḏ̣ayyʕūn aṣil-hum, hā ǧiddo? </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5"
                TIME_SLOT_REF1="ts8" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>ʕayne kallt-u lōn-he trūḥ, alle “mi go“ kilmit-u alle ygūl-he.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7"
                TIME_SLOT_REF1="ts12" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>ī. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts16" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>b-al-ᵊkrād. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts20" TIME_SLOT_REF2="ts23">
                <ANNOTATION_VALUE>ē! </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a15"
                TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>ē.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a18"
                TIME_SLOT_REF1="ts34" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>ī, mā_ʕarif āni.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a22"
                TIME_SLOT_REF1="ts42" TIME_SLOT_REF2="ts44">
                <ANNOTATION_VALUE>ṣaḥyān</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a27"
                TIME_SLOT_REF1="ts52" TIME_SLOT_REF2="ts54">
                <ANNOTATION_VALUE>ī, ʕayne ī, alle ysōlif b-al-ᵊkrād. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a31"
                TIME_SLOT_REF1="ts61" TIME_SLOT_REF2="ts62">
                <ANNOTATION_VALUE>ǧirībe ǧirībe, ʕayne ʕayne, ǧaʕad ᵊnqīb ᵊnqīb. alḥaz as-Sūriyyīn rāḥaw ʕala Awrūpa, bir malyon Sūriyyīn rāḥaw ʕala Awrūpa. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a33"
                TIME_SLOT_REF1="ts65" TIME_SLOT_REF2="ts67">
                <ANNOTATION_VALUE>ḏōle mā ʕād yiǧūn mā ʕād yiǧūn. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a35"
                TIME_SLOT_REF1="ts69" TIME_SLOT_REF2="ts70">
                <ANNOTATION_VALUE>mā ʕād yiǧūn ǧiddo.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a36"
                TIME_SLOT_REF1="ts71" TIME_SLOT_REF2="ts72">
                <ANNOTATION_VALUE>āni riḥit šifit-hum qādi ᵊb-ʕēn-i. bi-Awustūrya šifit-hum, bi-Almānya šifit-hum. as-Sūriyyīn ar rāḥaw min hēne, māʕa yiǧūn ʕala lē ǧāy, lā yruddūn ʕala Turkiyye wala yruddūn ʕala Sūriyye. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a38"
                TIME_SLOT_REF1="ts74" TIME_SLOT_REF2="ts76">
                <ANNOTATION_VALUE>lōn Sūriyye ttaʕammar arbaʕīn qāt, mā ʕād yiǧūn ǧiddo, kesin!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a39"
                TIME_SLOT_REF1="ts77" TIME_SLOT_REF2="ts79">
                <ANNOTATION_VALUE>w ḥitta iḥne zād lōn ᵊnrūḥ iḥne zād ᵊnrudd, tā āni agul-l-kum aṣ-ṣaḥīḥ. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a41"
                TIME_SLOT_REF1="ts80" TIME_SLOT_REF2="ts83">
                <ANNOTATION_VALUE>ī, as-Sūriyyīn hā! </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a43"
                TIME_SLOT_REF1="ts85" TIME_SLOT_REF2="ts86">
                <ANNOTATION_VALUE>ā, wāḥad šī bass šifit wāḥad Abu Aḥmad ʕid-ne ǧā ʕal… alḥaz şu anda ᵊb-ʕArab Maydanı. huwwa w ʕiǧyān-u, huwwa zād sāġlikči, emekli min Sūriyye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a44"
                TIME_SLOT_REF1="ts87" TIME_SLOT_REF2="ts88">
                <ANNOTATION_VALUE>gilt-l-u: Abu Aḥmad ʕalē mā riḥit inte mā daššart hal-wēlād? gāḷ: yā Abu Fārūq, āni al-wēlād ᵊšnōn adaššir-hum? gāḷ:  āni in riḥna qādi ᵊnḏ̣īʕ. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a45"
                TIME_SLOT_REF1="ts89" TIME_SLOT_REF2="ts90">
                <ANNOTATION_VALUE>gāl: w-āni in ḏ̣iʕit, āni āni aqayyib qēr ᵊškāl čiṯīr. mā_ǧbil, mā xaḷḷā-hum lā yrūḥūn wala rāḥ. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a48"
                TIME_SLOT_REF1="ts94" TIME_SLOT_REF2="ts96">
                <ANNOTATION_VALUE>abad mā_ǧbil, mā_ǧbil.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a50"
                TIME_SLOT_REF1="ts98" TIME_SLOT_REF2="ts100">
                <ANNOTATION_VALUE>ī, ʕaynen mā xaḷḷā-hum. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a52"
                TIME_SLOT_REF1="ts103" TIME_SLOT_REF2="ts104">
                <ANNOTATION_VALUE>ē. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a54"
                TIME_SLOT_REF1="ts106" TIME_SLOT_REF2="ts108">
                <ANNOTATION_VALUE>ī alle, yā xū-y… hala al-ḥarib mā gəḏ̣a? </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a55"
                TIME_SLOT_REF1="ts109" TIME_SLOT_REF2="ts111">
                <ANNOTATION_VALUE>al-ḥači ḥarb ᵊḏ̣ḏ̣all ᵊb-Sūriyye? awwali ǧaw ᵊnhazmaw min dāʕiš, mū xayyo? mū ygūlūn dāʕiš māʕiš? dāʕiš ḏ̣aḷḷ ᵊb-Sūriyye? </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a57"
                TIME_SLOT_REF1="ts113" TIME_SLOT_REF2="ts115">
                <ANNOTATION_VALUE>dāʕiš, Turkiyye mā yok etmedi mi kendisine? </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a59"
                TIME_SLOT_REF1="ts117" TIME_SLOT_REF2="ts118">
                <ANNOTATION_VALUE>mā ḏ̣rabat-u w rāḥat. dāʕiš māmiš māmiš. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a61"
                TIME_SLOT_REF1="ts120" TIME_SLOT_REF2="ts123">
                <ANNOTATION_VALUE>dāʕiš Amerīqa. dāʕiš Amerīqa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a63"
                TIME_SLOT_REF1="ts125" TIME_SLOT_REF2="ts126">
                <ANNOTATION_VALUE>hā fhimt axū-y? dāʕiš… </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
