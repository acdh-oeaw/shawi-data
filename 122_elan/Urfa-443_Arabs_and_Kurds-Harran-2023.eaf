        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a40"
                TIME_SLOT_REF1="ts78" TIME_SLOT_REF2="ts81">
                <ANNOTATION_VALUE>yā wal, alḥaz walda xālt-i huṃṃa miššān məṣāri, yiḏ̣ayyiʕ ḥāl-u zād. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
