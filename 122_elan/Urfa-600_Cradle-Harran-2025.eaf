    <TIER LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Corpus:Harran03">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
                <ANNOTATION_VALUE>as-sirīr. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3"
                TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>hā, ī. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5"
                TIME_SLOT_REF1="ts8" TIME_SLOT_REF2="ts11">
                <ANNOTATION_VALUE>as-sirīr min zimān, ʕatīǧ, ī. as-sirīr ṣār-ill-u min yōm-in ta-ngūl. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>ī wāḥad w ṯalāṯīn sine ṣār. gabəḷ wāḥad w ṯalāṯīn sine, wakt-in iḥne ʕizanne, ʕizanne m-al-bēt yaʕni, min ʕind ʕiyāl-i.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a8"
                TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>ʕizanne w ǧī rabīʕ Ismāʕīn m-al-ʕaskariyye, wakt-inn-u ǧīʸ, win ygūl iḥne ḏāk al-wakt āni ṣāyre, bnayyt-i ṣāyre ǧidīd, ʕumur-ha alḥaz wāḥad w ṯalāṯīn sine.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>hā w </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>ī bnayyt-i Ǧamīle ṣāyre ǧidīd, win ygūl: xayyo āni as-sirīr ʕa-z-ziġīre hāḏi, āni d-aǧīb-u, ʕalay-ye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a12"
                TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>wunn-u rāyiḥ ʕa-s-sūg w ǧāyb-ill-i sirīr ḥadīd. luwwa hīčiḏ miṯil, luwwa maʕālīǧ. wakt-in yinhazz yaʕni wakt-in yinhazz hīčiḏ miṯil al-lāyliʸ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a13"
                TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>ā, w-as-sirīr ṣārat Ǧamīle bī-´, w hazzēt-he sintēn b-as-sirīr. kubrat w čān yṣīr Melek, w hazzēt-he sintēn b-as-sirīr.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a14"
                TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>ʕugub Melek Fatḥiyye ṣārat, w čān ahizz-he as-sirīr hāḏa ʕayne. w Fārūq ʕugub-hun ṣār, zād sintēn hazzēt-u b-as-sirīr. ʕugub Fārūq Özlēm ṣārat, hazzēt-u b-as-sirīr.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a15"
                TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>ʕugub Özlēm ṣār-in-na tōm. wakt-in ṣār-il-na tōm, as-sirīr mā yāxuḏ-hin. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a17"
                TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts34">
                <ANNOTATION_VALUE>ī, ʕaman-hin tōm.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a18"
                TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>w gimne, ham as-sirīr hāḏa ziġīr ḏ̣all, yaʕni al-ḥadīd, ham zād faṣṣalnā-l-hin, sirīr xašab-in čibīr.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a19"
                TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>hīčiḏ tā yxuššin iṯnēnāt-hin lē hazzēnā-hin ᵊb-nōba wəḥde tā nhizz.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a20"
                TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts40">
                <ANNOTATION_VALUE>w ʕugub-ma ta-ngūl at-tōm ṣārat Sumayye. Sumayye ṣārat sint-in ṣār Ismāʕīn ʕamaliyye. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a21"
                TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts42">
                <ANNOTATION_VALUE>min hāḏa mā ḥitt mā rḏ̣aʕat umm-ha, āni zʕilt ᵊšwayye miṯil sāwēt yaʕni šwayye hnāt üzülme ʕaǧaba az-zlime hāḏa ši-yṣīr ʕalē-´? </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a22"
                TIME_SLOT_REF1="ts43" TIME_SLOT_REF2="ts44">
                <ANNOTATION_VALUE>w sāwēt ī üzülme wakt-in ṣārat Sumayye. Sumayye yaʕni ṣārat, ʕugub sabiʕ tišhur hīčiḏ ʕumur-ha, w abū-ha sāwa ʕamalīt rās. epilepsi ʕamalīt rās ᵊnṭəraḥ w sāwa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a23"
                TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts48">
                <ANNOTATION_VALUE>ʕaǧab ši-yṣīr, ʕaǧab iš-mā yṣīr? </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a25"
                TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts50">
                <ANNOTATION_VALUE>ī, hā! ʕaǧab ši-yṣīr, iš-mā yṣīr?  čān anṭi li-l-ʕaǧiyye ḥalīb zaʕal, ḥalīb xōf.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a26"
                TIME_SLOT_REF1="ts51" TIME_SLOT_REF2="ts52">
                <ANNOTATION_VALUE>anne sütü yaʕni umm, yaʕni az-ziġīre ənṭēt-u, w mā ṣār-il-he yaʕni mā ṣār gelišme. ḏ̣allat ziqīre w ḏ̣allat marbūʕa. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a27"
                TIME_SLOT_REF1="ts53" TIME_SLOT_REF2="ts54">
                <ANNOTATION_VALUE>Sumayye ḏ̣allat yaʕni miṯil waǧʕāne ṣārat m-al-ḥalīb haḏāk. ḥalīb al-xōf, w ḥalīb az-zaʕal, ᵊrḏ̣aʕat-u mā lāg-il-he.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a28"
                TIME_SLOT_REF1="ts55" TIME_SLOT_REF2="ts56">
                <ANNOTATION_VALUE>w-al-ʕaǧiyye gāmat nahāṛ ʕala nahāṛ təḏ̣ʕaf. mā ʕād, yaʕni mā ʕād tirgā-l-he ḥāl. ā, w zād hazzēt-he zād sintēn b-as-sirīr haḏāk. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a29"
                TIME_SLOT_REF1="ts57" TIME_SLOT_REF2="ts59">
                <ANNOTATION_VALUE>ʕugub ᵊhniyye Rayyān, ṣārat ʕugub Sumayye. Sumayye zādēn </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a31"
                TIME_SLOT_REF1="ts60" TIME_SLOT_REF2="ts62">
                <ANNOTATION_VALUE>al-guʕde, al-guʕde zādēne sintēn zād hazzēt-he b-as-sirīr.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a32"
                TIME_SLOT_REF1="ts63" TIME_SLOT_REF2="ts64">
                <ANNOTATION_VALUE>ʕugb as-sirīr hāḏa al-ʕaǧiyyāt mā kull-hin kubran? w čān ašīl as-sirīr, mā zattēt-u. gitt as-sirīr hāḏa ṣār tārīxi eser.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a33"
                TIME_SLOT_REF1="ts65" TIME_SLOT_REF2="ts66">
                <ANNOTATION_VALUE>gilt lummun yṣīrū-l-i an-nōba ḏ̣anne ḏ̣annā-ye. hā, w ṣār Göktuġ. wakt-in tiǧi umm-u ʕalē-ne ssayyir, ᵊnhizz-u b-as-sirīr, ᵊnnawwm-u b-as-sirīr hāḏe. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a35"
                TIME_SLOT_REF1="ts68" TIME_SLOT_REF2="ts70">
                <ANNOTATION_VALUE>Göktuġ wald Malak. Göktuġ wald Malak. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a37"
                TIME_SLOT_REF1="ts73" TIME_SLOT_REF2="ts74">
                <ANNOTATION_VALUE>ī Göktuġ Asaf wald Malak, ta-ngūl mū Ǧamīle al-uxṛa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a38"
                TIME_SLOT_REF1="ts75" TIME_SLOT_REF2="ts76">
                <ANNOTATION_VALUE>ā, mā ygūl iḥna ʕād ygūlū-l-ne aṯ-ṯinu. al-wəḥde, yaʕni ač-čibīre ygūlū-l-ha bičir. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a40"
                TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts80">
                <ANNOTATION_VALUE>ʕa-Ǧamīle ygūlū-l-he al-bičir.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a41"
                TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts82">
                <ANNOTATION_VALUE>way ygūlū-l-he ʕal Malak ygūl aṯ-ṯinu, aṯ-ṯnēne yaʕni. hā, wakt-in ṣār ʕād wlēd Göktuġ ṣār wakt-in wald Malak. hā gimna hazzēnā-´ zād bī-´. w wakt-in tiǧi yaʕni msayyre ʕalē-ne.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a42"
                TIME_SLOT_REF1="ts83" TIME_SLOT_REF2="ts84">
                <ANNOTATION_VALUE>w lummun ta-ngūl Fatḥiyye tiǧi min Rās al-ʕĒn msayyre ʕalē-ne, Fatḥiyye al-üčunǧiyye bnayyt-i, ṣār-il-ha zād wlēd.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a43"
                TIME_SLOT_REF1="ts85" TIME_SLOT_REF2="ts86">
                <ANNOTATION_VALUE>ā w zādēne wakt-in ṣār Činar sammēnā-´, w thizz yaʕni zād hazzēnā-´ b-as-sarīr. wakt-in yiǧi msayyir ʕalē-na yinhazz.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a44"
                TIME_SLOT_REF1="ts87" TIME_SLOT_REF2="ts88">
                <ANNOTATION_VALUE>w-alḥaz wlēd Ǧamīle, Mehmet Akīf. zād daʕ  ᵊnhizz-u b-as-sarīr, mā yiskut ᵊb-sirīr ahal-u, yiǧi yiskut ʕid-ne b-sirīr-ne, hahaha.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a45"
