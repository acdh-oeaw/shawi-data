                TIME_SLOT_REF1="ts147" TIME_SLOT_REF2="ts148">
                <ANNOTATION_VALUE>w-ᵊnkattēt ʕa-l-būri, riḥit tā_rīd āxuḏ hawa s-sontrafīš, waḷḷa šnōn-ma hniyye win-he b-īd-i han-nōba hniyye šī ygūlū-l-he kobān ᵊhniyye.</ANNOTATION_VALUE>
