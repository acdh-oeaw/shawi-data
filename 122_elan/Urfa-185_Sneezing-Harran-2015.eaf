    <TIER LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Corpus:Harran02">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
                <ANNOTATION_VALUE>al-wāḥad yōm-inn-u yʕaṭis, yaʕni al-ʕaṭse, ḥabše yaʕni ngūl, ḥabše.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a2"
                TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>al yʕaṭis huwwa ygūl ḥagg alḥamdilla, ḥagg alḥamdilla.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3"
                TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>w-al yamm-u, inčād yamm-u wāḥad šī, haḏāk ygūl: yirḥam-ne w yirḥam-ak aḷḷa!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a4"
                TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>maʕnāt-he w haḏāk ʕād… uxṛa yrudd ʕalē-´ al yʕaṭis, ygūl mingāḷ yaʕni mingāḷ miṯil-ma gilit mingāḷ, maʕnāt-he yaʕni qabūḷa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>al yʕaṭis, yōm-in yʕaṭis rūḥ bini ādam miṯil al-lamba, miṯil aḏ̣-ḏ̣aww, təṭfi w-ᵊtʕalag təṭfi w-ᵊtʕalag. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>yōm-in-ha tiṭfi w-ᵊtʕalag bini ādam ʕād ygūl ḥagg alḥamdilla yā rabb-i alḥamdilla uxṛa raddadit-ni ənṭēt rūḥ-i liyye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>ar-rūḥ ᵊtrūḥ w tiǧi. ᵊtqammiḏ̣ w-ᵊtfattiḥ. ᵊtqammiḏ̣ w-ᵊtfattiḥ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a8"
                TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>w-al-ādami ʕād yōm-inn-u yʕaṭis, arbaʕīn damār yiftakk-ill-u, min damārāt wuǧūd-u.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>kull ʕaṭse kull bini ādam arbaʕīn damār yiftakkin yaʕni minsaddāt yiftakkin.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a10"
                TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>w-al yamm-u ʕād ygūl-l-u ište: yirḥam-ne w yirḥam-ak aḷḷa! yaʕni aḷḷa yirḥam-ne w yirḥam-ak inte!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>w hāḏa zād ygūl-l-u mingāḷ. al-ʕaṭse maʕnāt-he hāḏi hiyye xōǧam, salāmt-ak w-al-ʕāfye.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
