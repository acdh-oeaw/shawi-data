    <TIER LINGUISTIC_TYPE_REF="default-lt" TIER_ID="Corpus:Ziyara02">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts2">
                <ANNOTATION_VALUE>al-fugara ad-darāwīš al-būsa miṯil ar-ruhhāb, ar-ruhhāb yāklūn ᵊmwāl an-nās  ḏ̣ulm-an haš-šakle ruhhāb yaʕni.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a2"
                TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>inte yōm-in ᵊššūf wāḥad yuḏ̣rub, gūl-ill-u xayyo ʕaš tuḏ̣rub? rawwiḥ waǧǧf-in-ne al-fūze. </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a4"
                TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>hāḏi hiyye ʕaš tā rrūḥ ʕa-l-ḥarib tā rrūḥ ʕala…</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>yā rawwiḥ yā quṭb az-zamān! taʕāl l-at-tank, l-al-fūze! ʕayyir-he xall-ha tuḏ̣rub siṭṭaʕāš miṯil ar-rūs.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts13">
                <ANNOTATION_VALUE>ī yaḷḷa mū ʕind-ak quwwa? mū tgūl ʕind-i ʕilim qēb? ī də-rūḥ ḥuṭṭ īd-ak bī-he! čiḏib ṣaḥīḥ? </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a8"
                TIME_SLOT_REF1="ts14" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>yaw yalan yalan!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>yikḏibūn ʕalē-kum čiḏib. yā sayyid-i, xārǧ al-qurʕān tanzīl min rabb al-ʕālamīn w qawl an-nabi ṣalla llāhu w sallam wa-aṣḥāb-u, kull-u čiḏib. yikḏibūn ʕa-l-ʕibād.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
